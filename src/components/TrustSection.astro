---
const columns = [
  {
    eyebrow: 'Price',
    lead: 'Pay once.',
    italic: 'Own it.',
    body:
      "€8.99 for the whole toolkit. After launch the price rises to €11.99, so if you're going to buy it, buy it early. No subscription, ever.",
  },
  {
    eyebrow: 'Privacy',
    lead: 'No tracking.',
    italic: 'No ads.',
    body: 'Your stash, your patterns, your pace. All on your device, none of it sold to anyone.',
    tint: 'sage',
  },
  {
    eyebrow: 'Languages',
    lead: 'Speaks',
    italic: 'your language.',
    body: "Eleven languages at launch. Because knitting instructions shouldn't need a translator.",
  },
];
---

<section class="trust-triad" aria-labelledby="trust-heading">
  <div class="inner">
    <header class="section-head">
      <div class="num">Nº 02</div>
      <h2 id="trust-heading" class="title">What stays <em>the same.</em></h2>
      <div class="kicker">Price · Privacy · Languages</div>
    </header>

    <div class="cols">
      {
        columns.map((c) => (
          <article class:list={['trust-col', c.tint && `tint-${c.tint}`]}>
            <p class="eyebrow">{c.eyebrow}</p>
            <h3>
              {c.lead}
              <br />
              <em>{c.italic}</em>
            </h3>
            <p class="body">{c.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .trust-triad {
    background: var(--paper);
    color: var(--ink);
    padding: 120px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .section-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: end;
    padding-bottom: 18px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 48px;
  }
  .section-head .num {
    font-family: var(--serif);
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 0.9;
    color: var(--terracotta);
    font-style: italic;
  }
  .section-head .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.75rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .section-head .title em { color: var(--terracotta); font-style: italic; }
  .section-head .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding-bottom: 10px;
    text-align: right;
  }
  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .trust-col {
    background: var(--paper-2);
    border: 1px solid var(--ink);
    padding: 36px 32px;
  }
  .trust-col.tint-sage {
    background: var(--sage);
    color: var(--paper);
  }
  .trust-col.tint-sage .eyebrow { color: var(--paper); opacity: 0.85; }
  .trust-col.tint-sage h3 { color: var(--paper); }
  .trust-col.tint-sage h3 em { color: var(--paper); }
  .trust-col.tint-sage .body { color: rgba(244, 234, 217, 0.9); }

  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    margin: 0 0 18px;
  }
  h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
    color: var(--ink);
  }
  h3 em {
    color: var(--sage);
    font-style: italic;
  }
  .body {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 1023px) {
    .cols { grid-template-columns: 1fr; }
  }
  @media (max-width: 767px) {
    .section-head { grid-template-columns: 1fr; gap: 8px; }
    .section-head .kicker { text-align: left; padding-bottom: 0; }
  }
  @media (max-width: 640px) {
    .trust-triad { padding: 80px 20px; }
  }
</style>
