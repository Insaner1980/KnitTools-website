---
import RegionalPrice from "./RegionalPrice.astro";
import RegionalPricingNote from "./RegionalPricingNote.astro";

const columns = [
  {
    eyebrow: "Privacy",
    lead: "No tracking.",
    italic: "No ads.",
    body: "Your stash, your patterns, your pace. No account needed, nothing sold, nothing tracked.",
    tint: "sage",
  },
  {
    eyebrow: "Languages",
    lead: "Speaks",
    italic: "your language.",
    body: "Eleven languages at launch. Because knitting instructions shouldn't need a translator.",
  },
];
---

<section class="trust-triad" aria-labelledby="trust-heading">
  <div class="inner">
    <header class="section-head" data-reveal>
      <p class="section-label">
        <span class="label-text">Principles</span>
      </p>
      <h2 id="trust-heading" class="title">
        What you can<br /><em>count on.</em>
      </h2>
    </header>

    <div class="cols">
      <article class="trust-col" data-reveal="scale">
        <p class="eyebrow">Price</p>
        <h3>
          Pay once.
          <br />
          <em>Own it.</em>
        </h3>
        <p class="body">
          Launch price <RegionalPrice phase="launch" /> for the whole toolkit. Regular
          price <RegionalPrice phase="permanent" /> later. No subscription, ever.
          <RegionalPricingNote />
        </p>
      </article>
      {
        columns.map((c) => (
          <article
            class:list={["trust-col", c.tint && `tint-${c.tint}`]}
            data-reveal="scale"
          >
            <p class="eyebrow">{c.eyebrow}</p>
            <h3>
              {c.lead}
              <br />
              <em>{c.italic}</em>
            </h3>
            <p class="body">{c.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .trust-triad {
    color: var(--ink);
    padding: 120px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .section-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 48px;
  }
  .section-head .section-label {
    display: inline-flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 10px;
  }
  .section-head .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--landing-section-title-size);
    line-height: var(--landing-section-title-line-height);
    letter-spacing: 0;
    margin: 0;
    color: var(--ink);
  }
  .section-head .title em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }
  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .trust-col {
    background: var(--wheat);
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 36px 32px;
  }
  .trust-col.tint-sage {
    background: var(--sage);
    color: var(--paper);
  }
  .trust-col.tint-sage .eyebrow {
    color: var(--paper);
    opacity: 0.85;
  }
  .trust-col.tint-sage h3 {
    color: var(--paper);
  }
  .trust-col.tint-sage h3 em {
    color: var(--paper);
  }
  .trust-col.tint-sage .body {
    color: rgb(from var(--paper) r g b / 0.9);
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 18px;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1;
    letter-spacing: 0;
    text-transform: none;
    margin: 0 0 20px;
    color: var(--ink);
  }
  h3 em {
    color: var(--ink);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }
  .body {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 1023px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 767px) {
    .section-head .section-label {
      gap: 12px;
    }
  }
  @media (max-width: 640px) {
    .trust-triad {
      padding: 80px 20px;
    }
  }
</style>
