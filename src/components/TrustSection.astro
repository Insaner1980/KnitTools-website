<section class="trust">
  <div class="trust-inner reveal">
    <div class="trust-items">
      <div class="trust-item">
        <span class="trust-label bebas-label">PRICE</span>
        <p class="trust-headline">Pay once. <em class="accent-italic">Own it.</em></p>
        <p class="trust-body">&euro;8.99 for the whole toolkit. After launch the price rises to &euro;11.99, so if you&rsquo;re going to buy it, buy it early. No subscription, ever.</p>
      </div>
      <div class="trust-item">
        <span class="trust-label bebas-label">PRIVACY</span>
        <p class="trust-headline">No tracking. <em class="accent-italic">No ads.</em></p>
        <p class="trust-body">Your stash, your patterns, your pace. All on your device, none of it sold to anyone.</p>
      </div>
      <div class="trust-item">
        <span class="trust-label bebas-label">LANGUAGES</span>
        <p class="trust-headline">Speaks <em class="accent-italic">your language.</em></p>
        <p class="trust-body">Eleven languages at launch. Because knitting instructions shouldn&rsquo;t need a translator.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .trust {
    position: relative;
    isolation: isolate;
    z-index: 1;
    padding: var(--section-padding-y-mobile) var(--section-padding-x-mobile);
  }

  .trust::before {
    content: '';
    position: absolute;
    top: 0;
    right: var(--stripe-width-mobile);
    bottom: 0;
    left: 0;
    background: #5B8072;
    z-index: -1;
  }

  .trust-inner {
    max-width: var(--container-compact-max);
    margin: 0 auto;
    text-align: center;
  }

  .trust-items {
    display: grid;
    grid-template-columns: 1fr;
    justify-items: center;
    gap: 2rem;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 220px;
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .trust-items {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 2rem;
    }
  }

  @media (min-width: 1024px) {
    .trust-items {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .trust-label {
    color: var(--label-on-dark);
  }

  .trust-headline {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.45rem, 2.1vw, 1.75rem);
    color: var(--cream);
    margin: 0;
    line-height: 1.2;
  }

  .trust-body {
    font-family: var(--font-body);
    font-size: var(--type-body-md);
    color: var(--cream-muted);
    line-height: 1.65;
    margin: 0.25rem 0 0;
  }

  @media (min-width: 769px) {
    .trust {
      padding: var(--section-padding-y-desktop) var(--section-padding-x-desktop);
    }
    .trust::before {
      right: var(--stripe-width-desktop);
    }
    .trust-inner {
      padding-right: var(--safe-pr-desktop);
    }
  }

  @media (max-width: 767px) {
    .trust-item {
      max-width: 100%;
    }
  }
</style>
