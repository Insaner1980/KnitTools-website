---
const columns = [
  {
    eyebrow: 'Price',
    lead: 'Pay once.',
    italic: 'Own it.',
    body:
      "€8.99 for the whole toolkit. After launch the price rises to €11.99, so if you're going to buy it, buy it early. No subscription, ever.",
  },
  {
    eyebrow: 'Privacy',
    lead: 'No tracking.',
    italic: 'No ads.',
    body: 'Your stash, your patterns, your pace. All on your device, none of it sold to anyone.',
  },
  {
    eyebrow: 'Languages',
    lead: 'Speaks',
    italic: 'your language.',
    body: "Eleven languages at launch. Because knitting instructions shouldn't need a translator.",
  },
];
---

<section class="trust-triad">
  <div class="inner">
    {
      columns.map((c) => (
        <article class="trust-col">
          <p class="eyebrow">{c.eyebrow}</p>
          <h3>
            {c.lead}
            <br />
            <em>{c.italic}</em>
          </h3>
          <p class="body">{c.body}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .trust-triad {
    background: var(--paper);
    color: var(--ink);
    padding: 120px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .trust-col { max-width: 360px; }
  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sage);
    margin: 0 0 18px;
  }
  h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 3vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
    color: var(--ink);
  }
  h3 em {
    color: var(--sage);
    font-style: italic;
  }
  .body {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  @media (max-width: 1023px) {
    .inner { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .trust-triad { padding: 80px 20px; }
  }
</style>
