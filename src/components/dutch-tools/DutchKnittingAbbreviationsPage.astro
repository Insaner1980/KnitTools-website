---
import LocalizedToolPage from "../LocalizedToolPage.astro";
import { dutchToolRoutes } from "../../i18n/dutchTools";
import { routes } from "../../i18n/routes";

type Category =
  | "cast-on-bind-off"
  | "increases"
  | "decreases"
  | "cables"
  | "lace"
  | "general"
  | "stitch-patterns";

interface Abbreviation {
  abbr: string;
  def: string;
  search: string;
  categories: Category[];
}

const categoryLabels: Record<Category, string> = {
  "cast-on-bind-off": "Opzetten / afkanten",
  increases: "Meerderingen",
  decreases: "Minderingen",
  cables: "Kabels",
  lace: "Ajour",
  general: "Algemeen",
  "stitch-patterns": "Steekpatronen",
};

