---
import { useTranslations } from "../i18n/ui";
import type { Lang } from "../i18n/config";

interface Props {
  variant?: "hero" | "page";
  lang?: Lang;
}

const { variant = "hero", lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<section
  class:list={["closing-cta", `closing-cta--${variant}`]}
  aria-labelledby="closing-heading"
>
  <div class="inner">
    <p class="eyebrow">{t("closingEyebrow")}</p>
    <h2 id="closing-heading">
      {t("closingHeadingStart")}<br /><em>{t("closingHeadingEm")}</em>
    </h2>

    <form
      class="signup"
      id="join"
      action="#"
      method="post"
      data-waitlist-signup
      data-source="knittools"
      data-sending-text={t("sending")}
      data-generic-error={t("genericError")}
      data-network-error={t("networkError")}
    >
      <label for="closing-email" class="visually-hidden"
        >{t("emailAddress")}</label
      >
      <label for="closing-website" class="visually-hidden" aria-hidden="true"
        >{t("honeypot")}</label
      >
      <input
        id="closing-website"
        name="website"
        type="text"
        class="visually-hidden"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <div class="signup-row" data-content>
        <input
          id="closing-email"
          name="email"
          type="email"
          placeholder={t("emailPlaceholder")}
          aria-describedby="closing-signup-success closing-signup-error"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn-primary">{t("notifyAtLaunch")}</button>
      </div>
      <p
        id="closing-signup-success"
        class="signup-success"
        data-success
        role="status"
        aria-live="polite"
        aria-atomic="true"
        aria-hidden="true"
        hidden
      >
        {t("notifySuccess")}
      </p>
      <p
        id="closing-signup-error"
        class="signup-error"
        data-error
        role="alert"
        aria-hidden="true"
        hidden
      >
        {t("genericError")}
      </p>
    </form>

    <p class="meta">{t("closingMeta")}</p>
  </div>
</section>

<style>
  .closing-cta {
    position: relative;
    padding: 160px 40px;
    text-align: center;
  }
  .inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--landing-label-size);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 18px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--closing-cta-heading-size);
    line-height: var(--closing-cta-heading-line-height);
    letter-spacing: var(--closing-cta-heading-letter-spacing);
    margin: var(--closing-cta-heading-margin);
    color: var(--ink);
  }
  .closing-cta--page {
    padding: 96px 40px;
  }
  h2 em {
    color: var(--terracotta);
    font-style: normal;
    font-size: var(--closing-cta-heading-em-size);
    line-height: 1;
    display: inline-block;
    margin-top: var(--closing-cta-heading-em-margin-top);
  }

  .signup {
    max-width: 520px;
    margin: 0 auto;
  }
  .signup-row {
    display: flex;
    gap: 10px;
  }
  .signup input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 16px;
    padding: 14px 20px;
    border: 1.5px solid var(--ink);
    background: var(--paper-2);
    color: var(--ink);
    border-radius: 0;
    min-width: 0;
  }
  .signup input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }
  .btn-primary {
    font-family: var(--font-body);
    font-size: var(--landing-label-size);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 14px 22px;
    border-radius: 0;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .signup-success {
    display: none;
    font-family: var(--font-body);
    font-size: 20px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .signup-error {
    display: none;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--ink-soft, var(--ink));
    margin: 0;
    padding: 8px 0;
  }
  .meta {
    margin: 24px 0 0;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-soft);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .closing-cta {
      padding: 100px 20px;
    }
    .signup-row {
      flex-direction: column;
    }
  }
</style>
