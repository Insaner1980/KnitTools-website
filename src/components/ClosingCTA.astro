---
import { useTranslations } from '../i18n/ui';

interface Props {
  variant?: 'hero' | 'page';
  lang?: 'en' | 'fi';
}

const { variant = 'hero', lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section class:list={['closing-cta', `closing-cta--${variant}`]} aria-labelledby="closing-heading">
  <div class="inner">
    <p class="eyebrow">{t('closingEyebrow')}</p>
    <h2 id="closing-heading">{t('closingHeadingStart')}<br /><em>{t('closingHeadingEm')}</em></h2>

    <form class="signup" id="join" action="#" method="post">
      <label for="closing-email" class="visually-hidden">{t('emailAddress')}</label>
      <label for="closing-website" class="visually-hidden">{t('honeypot')}</label>
      <input
        id="closing-website"
        name="website"
        type="text"
        class="visually-hidden"
        tabindex="-1"
        autocomplete="off"
      />
      <div class="signup-row" data-content>
        <input
          id="closing-email"
          name="email"
          type="email"
          placeholder={t('emailPlaceholder')}
          required
          autocomplete="email"
        />
        <button type="submit" class="btn-primary">{t('reservePrice')}</button>
      </div>
      <p class="signup-success" data-success aria-hidden="true">
        {t('reserved')}
      </p>
      <p class="signup-error" data-error aria-hidden="true">
        {t('genericError')}
      </p>
    </form>

    <p class="meta">{t('closingMeta')}</p>
  </div>
</section>

<script
  is:inline
  define:vars={{
    reservePriceText: t('reservePrice'),
    sendingText: t('sending'),
    genericErrorText: t('genericError'),
    networkErrorText: t('networkError'),
  }}
>
  (() => {
    const ENDPOINT = 'https://api.finnvek.com/subscribe';

    const form = document.getElementById('join');
    if (!form) return;

    const content = form.querySelector('[data-content]');
    const success = form.querySelector('[data-success]');
    const errorEl = form.querySelector('[data-error]');
    const button = form.querySelector('button[type="submit"]');
    const emailInput = form.querySelector('input[type="email"]');
    const honeypot = form.querySelector('input[name="website"]');
    const originalText = button ? button.textContent : reservePriceText;

    const showSuccess = () => {
      if (content) content.style.display = 'none';
      if (errorEl) {
        errorEl.style.display = 'none';
        errorEl.setAttribute('aria-hidden', 'true');
      }
      if (success) {
        success.style.display = 'block';
        success.setAttribute('aria-hidden', 'false');
      }
    };

    const showError = (message) => {
      if (button) {
        button.disabled = false;
        button.textContent = originalText;
      }
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
        errorEl.setAttribute('aria-hidden', 'false');
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      if (button) {
        button.disabled = true;
        button.textContent = sendingText;
      }
      if (errorEl) {
        errorEl.style.display = 'none';
        errorEl.setAttribute('aria-hidden', 'true');
      }

      try {
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput ? emailInput.value.trim() : '',
            source: 'knittools',
            website: honeypot ? honeypot.value : '',
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          showSuccess();
        } else {
          showError(data.error || genericErrorText);
        }
      } catch {
        showError(networkErrorText);
      }
    });
  })();
</script>

<style>
  .closing-cta {
    position: relative;
    padding: 160px 40px;
    text-align: center;
  }
  .inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 18px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 6vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 48px;
    color: var(--ink);
  }
  .closing-cta--page h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 32px;
  }
  .closing-cta--page {
    padding: 96px 40px;
  }
  h2 em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .signup { max-width: 520px; margin: 0 auto; }
  .signup-row {
    display: flex;
    gap: 10px;
  }
  .signup input {
    flex: 1;
    font-family: var(--body-ed);
    font-size: 16px;
    padding: 14px 20px;
    border: 1.5px solid var(--ink);
    background: var(--paper-2);
    color: var(--ink);
    border-radius: 0;
    min-width: 0;
  }
  .signup input:focus { outline: 2px solid var(--terracotta); outline-offset: 2px; }
  .btn-primary {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 14px 22px;
    border-radius: 0;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .signup-success {
    display: none;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 20px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .signup-error {
    display: none;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-soft, var(--ink));
    margin: 0;
    padding: 8px 0;
  }
  .meta {
    margin: 24px 0 0;
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .closing-cta { padding: 100px 20px; }
    .signup-row { flex-direction: column; }
  }
</style>
