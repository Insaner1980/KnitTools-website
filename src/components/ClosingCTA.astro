---
import { Image } from 'astro:assets';
import faqButton from '../assets/images/faq-button.webp';
---

<section id="final-cta" class="closing-cta dot-grid-cream">
  <div class="closing-inner reveal">
    <span class="section-tag">Be there at launch</span>
    <h2 class="cta-heading">Where every stitch <em class="accent-italic">counts.</em></h2>
    <form class="cta-signup waitlist-form" id="cta-signup-form" action="#" method="post">
      <div class="waitlist-content-layer" id="cta-content-layer">
        <div class="signup-row waitlist-row">
          <input type="email" placeholder="your@email.com" required class="signup-input waitlist-input" />
          <button type="submit" class="signup-btn waitlist-btn">Reserve my price</button>
        </div>
      </div>

      <div class="waitlist-loading-state" id="cta-loading" aria-hidden="true">
        <Image src={faqButton} alt="Loading..." width={112} height={112} class="big-spinner" />
      </div>

      <div class="waitlist-success" id="cta-success" aria-hidden="true">
        <p class="success-text">
          <span class="success-label">You're in!</span>
          <span class="success-sub">We'll email you at launch.</span>
        </p>
      </div>
    </form>
    <div class="plan-grid">
      <article class="plan plan-free">
        <p class="plan-name">Free</p>
        <p class="plan-value">Forever</p>
        <ul class="plan-features" role="list">
          <li>Row counter</li>
          <li>Ravelry</li>
          <li>Calculators</li>
          <li>Three projects</li>
          <li>Reference library</li>
        </ul>
        <p class="plan-foot">No account, no trial expiry, no card.</p>
      </article>

      <article class="plan plan-pro">
        <p class="plan-name">Pro</p>
        <p class="plan-value">&euro;8.99 <span class="plan-once">one-time</span></p>
        <ul class="plan-features" role="list">
          <li>Unlimited projects</li>
          <li>Voice commands</li>
          <li>AI</li>
          <li>Yarn stash</li>
          <li>Everything else</li>
        </ul>
        <p class="plan-foot">14-day free trial. No credit card. Rises to &euro;11.99 in two months.</p>
      </article>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('cta-signup-form') as HTMLFormElement | null;
  const contentLayer = document.getElementById('cta-content-layer');
  const loading = document.getElementById('cta-loading');
  const success = document.getElementById('cta-success');

  if (form && contentLayer && loading && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const height = form.offsetHeight;
      form.style.minHeight = `${height}px`;

      contentLayer.classList.add('is-hidden');
      loading.classList.add('is-visible');

      setTimeout(() => {
        loading.classList.remove('is-visible');
        loading.classList.add('is-hidden');
        success.classList.add('is-visible');
      }, 1500);
    });
  }
</script>

<style>
  .closing-cta {
    padding: var(--section-padding-y-mobile) var(--section-padding-x-mobile);
  }

  .closing-inner {
    max-width: var(--container-narrow-max);
    margin: 0 auto;
    text-align: center;
  }

  .cta-heading {
    color: var(--text-on-light);
    font-size: clamp(3rem, 6.5vw, 6.875rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 2.5rem;
  }

  .closing-cta .section-tag {
    margin-bottom: 1.25rem;
  }

  .cta-signup {
    margin: 0 auto 1rem;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: var(--container-form-max);
  }

  .waitlist-content-layer,
  .waitlist-loading-state,
  .waitlist-success {
    transition: opacity 400ms cubic-bezier(0.4, 0, 0.2, 1), transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .waitlist-content-layer {
    width: 100%;
  }

  .waitlist-content-layer.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.96);
    position: absolute;
  }

  .waitlist-loading-state {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.6);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .waitlist-loading-state.is-visible {
    position: relative;
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  .waitlist-loading-state.is-hidden {
    position: absolute;
    opacity: 0;
    transform: scale(1.2);
    pointer-events: none;
  }

  .big-spinner {
    animation: ctaSpin 1.2s cubic-bezier(0.6, 0.1, 0.4, 0.9) infinite;
  }

  @keyframes ctaSpin {
    100% { transform: rotate(360deg); }
  }

  .waitlist-success {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.98);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .waitlist-success.is-visible {
    opacity: 1;
    position: relative;
    transform: translateY(0) scale(1);
    pointer-events: auto;
    transition-delay: 100ms;
  }

  .success-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 12px 0;
    text-align: center;
  }

  .success-label {
    font-family: var(--font-label);
    font-size: var(--bebas-display-size);
    color: var(--accent);
    line-height: 1;
    letter-spacing: var(--bebas-display-tracking);
    text-transform: uppercase;
  }

  .success-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-on-light-muted);
    margin-top: 0.5rem;
  }

  .plan-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
    text-align: left;
  }

  .plan {
    padding: 28px 28px 24px;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .plan-free {
    background: var(--cream-muted);
    color: var(--text-on-light);
  }

  .plan-pro {
    background: var(--dark);
    color: var(--cream);
  }

  .plan-name {
    font-family: var(--font-label);
    font-size: var(--bebas-ui-size);
    font-weight: var(--bebas-ui-weight);
    letter-spacing: var(--bebas-ui-tracking);
    text-transform: uppercase;
    margin: 0;
  }

  .plan-free .plan-name { color: var(--text-on-light-muted); }
  .plan-pro .plan-name { color: var(--mustard); }

  .plan-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1;
    margin: 0;
  }

  .plan-once {
    display: block;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--text-on-light-muted);
    margin-top: 0.4rem;
  }

  .plan-pro .plan-once { color: var(--cream-muted); }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .plan-free .plan-features { color: var(--text-on-light); }
  .plan-pro .plan-features { color: var(--cream); }

  .plan-foot {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  .plan-free .plan-foot { color: var(--text-on-light-muted); }
  .plan-pro .plan-foot { color: var(--cream-muted); }

  @media (min-width: 769px) {
    .plan-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 4rem;
    }

    .closing-cta {
      padding: var(--section-padding-y-desktop) var(--section-padding-x-desktop);
    }

    .closing-inner {
      padding-right: var(--safe-pr-desktop);
    }
  }
</style>
