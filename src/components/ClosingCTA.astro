---
---

<section class="closing-cta" aria-labelledby="closing-heading">
  <div class="inner">
    <p class="eyebrow">Be there at launch</p>
    <h2 id="closing-heading">Where every stitch<br /><em>counts.</em></h2>

    <form class="signup" id="join" action="#" method="post">
      <label for="closing-email" class="visually-hidden">Email address</label>
      <div class="signup-row" data-content>
        <input
          id="closing-email"
          type="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn-primary">Reserve my price</button>
      </div>
      <p class="signup-success" data-success aria-hidden="true">
        Reserved. See you at launch.
      </p>
    </form>

    <p class="meta">Free tier from day one. No card required.</p>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById('join');
    if (!form) return;
    const content = form.querySelector('[data-content]');
    const success = form.querySelector('[data-success]');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      content.style.display = 'none';
      success.style.display = 'block';
      success.setAttribute('aria-hidden', 'false');
    });
  })();
</script>

<style>
  .closing-cta {
    position: relative;
    background: var(--paper);
    padding: 160px 40px;
    text-align: center;
  }
  .inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 18px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3rem, 6vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 48px;
    color: var(--ink);
  }
  h2 em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .signup { max-width: 520px; margin: 0 auto; }
  .signup-row {
    display: flex;
    gap: 10px;
  }
  .signup input {
    flex: 1;
    font-family: var(--body-ed);
    font-size: 16px;
    padding: 14px 20px;
    border: 1.5px solid var(--ink);
    background: var(--paper-2);
    color: var(--ink);
    border-radius: 0;
    min-width: 0;
  }
  .signup input:focus { outline: 2px solid var(--terracotta); outline-offset: 2px; }
  .btn-primary {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 14px 22px;
    border-radius: 0;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .signup-success {
    display: none;
    font-family: var(--serif);
    font-style: italic;
    font-size: 28px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .meta {
    margin: 24px 0 0;
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .closing-cta { padding: 100px 20px; }
    .signup-row { flex-direction: column; }
  }
</style>
