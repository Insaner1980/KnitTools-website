---
import LocalizedToolPage from "./LocalizedToolPage.astro";
import type { Lang } from "../i18n/config";
import type { LocalizedPath } from "../i18n/routes";

interface Faq {
  q: string;
  a: string;
}

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  alternates: LocalizedPath;
  lang?: Lang;
  eyebrow?: string;
  intro: string;
  schemaName: string;
  schemaDescription: string;
  faqs: Faq[];
  variant?: "terracotta" | "rust" | "teal" | "sand" | "brown";
}

const props = Astro.props;
---

<LocalizedToolPage {...props} lang="fi">
  <Fragment slot="tool">
    <slot name="tool" />
  </Fragment>
  <Fragment slot="content">
    <slot name="content" />
  </Fragment>
</LocalizedToolPage>
