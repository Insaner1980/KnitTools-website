---
import type { Lang } from "../i18n/config";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const usesDecimalComma = lang === "fr" || lang === "nl" || lang === "da";
const metricOnly = lang === "fr" || lang === "nl" || lang === "da";
const numericInputType = usesDecimalComma ? "text" : "number";
const copy = {
  en: {
    legend: "Cast On Calculator",
    gauge: "Gauge (stitches per 10 cm / 4 in)",
    decreaseGauge: "Decrease gauge",
    increaseGauge: "Increase gauge",
    gaugePlaceholder: "e.g. 20",
    width: "Desired width",
    decreaseWidth: "Decrease width",
    increaseWidth: "Increase width",
    widthPlaceholder: "e.g. 50",
    unitSelection: "Unit selection",
    inches: "inches",
    calculate: "Calculate",
    error: "Please enter valid gauge and width values.",
    resultLabel: "stitches to cast on",
  },
  fi: {
    legend: "Silmukkalaskuri",
    gauge: "Neuletiheys (silmukkaa / 10 cm tai 4 in)",
    decreaseGauge: "Pienennä neuletiheyttä",
    increaseGauge: "Suurenna neuletiheyttä",
    gaugePlaceholder: "esim. 20",
    width: "Haluttu leveys",
    decreaseWidth: "Pienennä leveyttä",
    increaseWidth: "Suurenna leveyttä",
    widthPlaceholder: "esim. 50",
    unitSelection: "Mittayksikkö",
    inches: "tuumaa",
    calculate: "Laske",
    error: "Syötä kelvollinen neuletiheys ja leveys.",
    resultLabel: "luotavaa silmukkaa",
  },
  de: {
    legend: "Maschenanschlag-Rechner",
    gauge: "Maschenprobe (Maschen pro 10 cm / 4 in)",
    decreaseGauge: "Maschenprobe verkleinern",
    increaseGauge: "Maschenprobe vergrößern",
    gaugePlaceholder: "z. B. 20",
    width: "Gewünschte Breite",
    decreaseWidth: "Breite verkleinern",
    increaseWidth: "Breite vergrößern",
    widthPlaceholder: "z. B. 50",
    unitSelection: "Einheit",
    inches: "Zoll",
    calculate: "Berechnen",
    error: "Gib eine gültige Maschenprobe und Breite ein.",
    resultLabel: "anzuschlagende Maschen",
  },
  sv: {
    legend: "Uppläggningskalkylator",
    gauge: "Stickfasthet (maskor per 10 cm)",
    decreaseGauge: "Minska stickfasthet",
    increaseGauge: "Öka stickfasthet",
    gaugePlaceholder: "t.ex. 20",
    width: "Önskad bredd",
    decreaseWidth: "Minska bredd",
    increaseWidth: "Öka bredd",
    widthPlaceholder: "t.ex. 50",
    unitSelection: "Måttenhet",
    inches: "tum",
    calculate: "Räkna ut",
    error: "Ange giltiga värden för stickfasthet och bredd.",
    resultLabel: "maskor att lägga upp",
  },
  no: {
    legend: "Oppleggskalkulator",
    gauge: "Strikkefasthet (masker per 10 cm / 4 in)",
    decreaseGauge: "Senk strikkefasthet",
    increaseGauge: "Øk strikkefasthet",
    gaugePlaceholder: "f.eks. 20",
    width: "Ønsket bredde",
    decreaseWidth: "Senk bredde",
    increaseWidth: "Øk bredde",
    widthPlaceholder: "f.eks. 50",
    unitSelection: "Måleenhet",
    inches: "tommer",
    calculate: "Beregn",
    error: "Skriv inn gyldig strikkefasthet og bredde.",
    resultLabel: "masker å legge opp",
  },
  fr: {
    legend: "Calculateur de mailles à monter",
    gauge: "Échantillon (mailles pour 10 cm)",
    decreaseGauge: "Réduire l'échantillon",
    increaseGauge: "Augmenter l'échantillon",
    gaugePlaceholder: "ex. 20",
    width: "Largeur souhaitée (cm)",
    decreaseWidth: "Réduire la largeur",
    increaseWidth: "Augmenter la largeur",
    widthPlaceholder: "ex. 50",
    unitSelection: "Unité",
    inches: "pouces",
    calculate: "Calculer",
    error: "Entre un échantillon et une largeur valides.",
    resultLabel: "mailles à monter",
  },
  nl: {
    legend: "Opzetcalculator",
    gauge: "Stekenverhouding (steken per 10 cm)",
    decreaseGauge: "Stekenverhouding verlagen",
    increaseGauge: "Stekenverhouding verhogen",
    gaugePlaceholder: "bijv. 20",
    width: "Gewenste breedte (cm)",
    decreaseWidth: "Breedte verlagen",
    increaseWidth: "Breedte verhogen",
    widthPlaceholder: "bijv. 50",
    unitSelection: "Maateenheid",
    inches: "inch",
    calculate: "Berekenen",
    error: "Vul een geldige stekenverhouding en breedte in.",
    resultLabel: "op te zetten steken",
  },
  da: {
    legend: "Opslagsberegner",
    gauge: "Strikkefasthed (masker pr. 10 cm)",
    decreaseGauge: "Sænk strikkefastheden",
    increaseGauge: "Øg strikkefastheden",
    gaugePlaceholder: "fx 20",
    width: "Ønsket bredde (cm)",
    decreaseWidth: "Sænk bredden",
    increaseWidth: "Øg bredden",
    widthPlaceholder: "fx 50",
    unitSelection: "Måleenhed",
    inches: "inch",
    calculate: "Beregn",
    error: "Skriv en gyldig strikkefasthed og bredde.",
    resultLabel: "masker der skal slås op",
  },
}[lang];
---

<div
  class="cast-on-calculator"
  data-error={copy.error}
  data-result-label={copy.resultLabel}
>
  <fieldset>
    <legend class="sr-only">{copy.legend}</legend>

    <div class="form-group">
      <label for="gauge">{copy.gauge}</label>
      <div class="number-input-wrap">
        <button
          type="button"
          class="spin-btn spin-down"
          aria-label={copy.decreaseGauge}>−</button
        >
        <input
          type={numericInputType}
          inputmode="decimal"
          id="gauge"
          min="1"
          max="100"
          step="0.5"
          placeholder={copy.gaugePlaceholder}
        />
        <button
          type="button"
          class="spin-btn spin-up"
          aria-label={copy.increaseGauge}>+</button
        >
      </div>
    </div>

    <div class="form-group">
      <label for="width">{copy.width}</label>
      <div class="number-input-wrap">
        <button
          type="button"
          class="spin-btn spin-down"
          aria-label={copy.decreaseWidth}>−</button
        >
        <input
          type={numericInputType}
          inputmode="decimal"
          id="width"
          min="0.1"
          max="1000"
          step="0.1"
          placeholder={copy.widthPlaceholder}
        />
        <button
          type="button"
          class="spin-btn spin-up"
          aria-label={copy.increaseWidth}>+</button
        >
      </div>
    </div>

    {
      !metricOnly && (
        <div class="form-group">
          <div
            class="unit-toggle"
            role="radiogroup"
            aria-label={copy.unitSelection}
          >
            <label class="unit-option">
              <input type="radio" name="unit" value="cm" checked />
              <span>cm</span>
            </label>
            <label class="unit-option">
              <input type="radio" name="unit" value="inches" />
              <span>{copy.inches}</span>
            </label>
          </div>
        </div>
      )
    }

    <button type="button" class="btn-primary calc-btn">{copy.calculate}</button>

    <div class="result-area" aria-live="polite">
      <div class="result-wrapper">
        <div class="result-value" id="cast-on-result"></div>
      </div>
    </div>
  </fieldset>
</div>

<script>
  function initCastOnCalculator() {
    const calculators = document.querySelectorAll(".cast-on-calculator");

    calculators.forEach((calc) => {
      const gaugeInput = calc.querySelector("#gauge") as HTMLInputElement;
      const widthInput = calc.querySelector("#width") as HTMLInputElement;
      const unitRadios = calc.querySelectorAll('input[name="unit"]');
      const calcBtn = calc.querySelector(".calc-btn") as HTMLButtonElement;
      const resultEl = calc.querySelector("#cast-on-result") as HTMLElement;
      const resultArea = calc.querySelector(".result-area") as HTMLElement;

      if (!gaugeInput || !widthInput || !calcBtn || !resultEl || !resultArea)
        return;

      const id = Math.random().toString(36).slice(2, 8);
      gaugeInput.id = `gauge-${id}`;
      (gaugeInput.previousElementSibling as HTMLElement).setAttribute(
        "for",
        gaugeInput.id,
      );
      widthInput.id = `width-${id}`;
      (widthInput.previousElementSibling as HTMLElement).setAttribute(
        "for",
        widthInput.id,
      );
      resultEl.id = `cast-on-result-${id}`;
      unitRadios.forEach((r) => {
        (r as HTMLInputElement).name = `unit-${id}`;
      });

      const parseInputNumber = (raw: string) => {
        const normalized = raw.trim().replace(/\s+/g, "").replace(",", ".");
        const value = Number(normalized);
        return Number.isFinite(value) ? value : NaN;
      };

      calcBtn.addEventListener("click", () => {
        const gauge = parseInputNumber(gaugeInput.value);
        const width = parseInputNumber(widthInput.value);
        const unit =
          (
            calc.querySelector(
              `input[name="unit-${id}"]:checked`,
            ) as HTMLInputElement
          )?.value || "cm";

        resultEl.textContent = "";
        resultEl.className = "result-value";

        if (!gauge || gauge <= 0 || !width || width <= 0) {
          const errorSpan = document.createElement("span");
          errorSpan.className = "form-error";
          errorSpan.setAttribute("role", "alert");
          errorSpan.textContent = calc.getAttribute("data-error") || "";
          resultEl.appendChild(errorSpan);
          resultArea.classList.add("is-open");
          return;
        }

        let stitches: number;
        if (unit === "cm") {
          stitches = (gauge / 10) * width;
        } else {
          stitches = (gauge / 4) * width;
        }
        stitches = Math.round(stitches / 2) * 2;

        const wrapper = document.createElement("div");
        wrapper.className = "tool-result";
        const numberEl = document.createElement("span");
        numberEl.className = "result-number";
        numberEl.textContent = "0";
        const labelEl = document.createElement("span");
        labelEl.className = "result-label";
        labelEl.textContent = calc.getAttribute("data-result-label") || "";
        wrapper.appendChild(numberEl);
        wrapper.appendChild(labelEl);
        resultEl.appendChild(wrapper);

        resultArea.classList.add("is-open");

        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (prefersReducedMotion) {
          numberEl.textContent = String(stitches);
        } else {
          const duration = 800;
          const start = performance.now();
          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            numberEl.textContent = String(Math.round(eased * stitches));
            if (progress < 1) requestAnimationFrame(animate);
          };
          requestAnimationFrame(animate);
        }
      });
    });
  }

  initCastOnCalculator();

  document.querySelectorAll(".spin-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const wrap = btn.closest(".number-input-wrap");
      if (!wrap) return;
      const input = wrap.querySelector("input") as HTMLInputElement;
      if (!input) return;
      const usesDecimalComma = input.type === "text";
      const parseInputNumber = (raw: string | null) => {
        const normalized = (raw || "")
          .trim()
          .replace(/\s+/g, "")
          .replace(",", ".");
        const value = Number(normalized);
        return Number.isFinite(value) ? value : NaN;
      };
      const formatInputNumber = (value: number) => {
        const formatted = String(Number(value.toFixed(2)));
        return usesDecimalComma ? formatted.replace(".", ",") : formatted;
      };

      const step = parseInputNumber(input.getAttribute("step")) || 1;
      const min = parseInputNumber(input.getAttribute("min"));
      const max = parseInputNumber(input.getAttribute("max"));
      let val = parseInputNumber(input.value) || 0;
      if (btn.classList.contains("spin-up")) {
        val += step;
        if (!isNaN(max) && val > max) val = max;
      } else {
        val -= step;
        if (!isNaN(min) && val < min) val = min;
      }
      input.value = formatInputNumber(val);
      input.dispatchEvent(new Event("input"));
    });
  });
</script>

<style>
  .cast-on-calculator fieldset {
    border: 0;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .form-group {
    margin-top: 16px;
  }
  .form-group:first-child {
    margin-top: 0;
  }

  .cast-on-calculator label {
    display: block;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 10px;
  }

  .number-input-wrap {
    display: flex;
    align-items: stretch;
    max-width: 380px;
    border: 1.5px solid var(--ink);
    background: transparent;
    transition:
      background-color 300ms ease,
      border-color 300ms ease,
      box-shadow 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .number-input-wrap:focus-within {
    background: var(--paper-2);
    border-color: var(--terracotta);
    box-shadow: 0 4px 16px rgba(160, 80, 56, 0.15);
  }

  .cast-on-calculator input:is([type="number"], [type="text"]) {
    flex: 1;
    background: transparent;
    border: 0;
    border-left: 1.5px solid var(--ink);
    border-right: 1.5px solid var(--ink);
    border-radius: 0;
    height: 48px;
    padding: 0 18px;
    font-size: 16px;
    color: var(--ink);
    font-family: var(--body-ed);
    box-sizing: border-box;
    transition: border-color 300ms ease;
    appearance: none;
    -moz-appearance: textfield;
    text-align: center;
    min-width: 0;
  }

  .cast-on-calculator input[type="number"]::-webkit-inner-spin-button,
  .cast-on-calculator input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .spin-btn {
    width: 44px;
    background: transparent;
    border: 0;
    color: var(--terracotta);
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    transition:
      background-color 200ms,
      color 200ms,
      transform 100ms;
    font-family: var(--body-ed);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .spin-btn:hover {
    background: var(--terracotta);
    color: var(--paper);
  }

  .spin-btn:active {
    transform: scale(0.92);
  }

  .cast-on-calculator input::placeholder {
    color: var(--ink-soft);
  }

  .cast-on-calculator input:focus {
    outline: none;
  }

  .number-input-wrap:focus-within input:is([type="number"], [type="text"]) {
    border-color: var(--terracotta);
  }

  /* Unit Toggle — text-based with terracotta underline */
  .unit-toggle {
    display: inline-flex;
    margin-top: 20px;
    gap: 28px;
    background: transparent;
    border: 0;
    padding: 0;
    width: max-content;
  }

  .unit-option {
    cursor: pointer;
    margin: 0;
    position: relative;
  }

  .unit-option input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .unit-option span {
    display: block;
    padding: 6px 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    border-bottom: 1.5px solid transparent;
    transition:
      color 200ms ease,
      border-color 200ms ease;
    line-height: 1;
  }

  .unit-option:hover span {
    color: var(--ink);
  }

  .unit-option input:checked + span {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  .unit-option input:focus-visible + span {
    outline: 2px solid var(--terracotta);
    outline-offset: 4px;
  }

  /* Calculate button — landing hero style */
  .calc-btn {
    display: inline-block;
    margin-top: 28px;
    padding: 14px 26px;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 0;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease !important;
  }

  .calc-btn:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
    color: var(--paper);
  }

  /* Result Area Subtly Expanding */
  .result-area {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 500ms cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 16px;
  }

  .result-area.is-open {
    grid-template-rows: 1fr;
  }

  .result-wrapper {
    overflow: hidden;
  }

  :global(.tool-result) {
    background: none;
    border: none;
    padding: 16px 0;
    text-align: left;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 400ms ease 200ms,
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1) 200ms;
  }

  .result-area.is-open :global(.tool-result) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.result-number) {
    display: block;
    font-family: var(--mono);
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: var(--terracotta);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  :global(.result-label) {
    display: block;
    font-family: var(--body-ed);
    font-size: 1rem;
    color: var(--ink);
    opacity: 0.7;
    margin-top: 4px;
  }

  .form-error {
    color: var(--terracotta);
    font-size: 0.85rem;
    display: block;
    padding-top: 12px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
