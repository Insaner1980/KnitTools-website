---
import { PRICING_TIERS, getPrice, type PricePhase } from "../config/pricing";

interface Props {
  phase: PricePhase;
}

const { phase } = Astro.props;
const priceDataAttributes = Object.fromEntries(
  Object.entries(PRICING_TIERS).map(([tier, prices]) => [
    `data-${tier.toLowerCase()}`,
    prices[phase],
  ]),
);
---

<span data-regional-price={phase} {...priceDataAttributes}
  >{getPrice(phase)}</span
>
