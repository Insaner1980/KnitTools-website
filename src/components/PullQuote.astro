---
export interface Props {
  quote: string;
  attribution?: string;
}
const { quote, attribution } = Astro.props;
---

<aside class="pull-quote" aria-label="Pull quote">
  <div class="inner">
    <div class="rule-top" aria-hidden="true"></div>
    <blockquote>
      <p>{quote}</p>
    </blockquote>
    <div class="rule-bottom" aria-hidden="true"></div>
  </div>
</aside>

<style>
  .pull-quote {
    padding: 72px 40px;
    background: var(--paper);
  }
  .inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .rule-top, .rule-bottom {
    width: 72px;
    height: 1px;
    background: var(--ink);
    margin: 0 auto;
    opacity: 0.6;
  }
  blockquote {
    margin: 28px 0;
    padding: 0;
  }
  blockquote p {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
  }
  blockquote p::before {
    content: "\201C";
    color: var(--terracotta);
    margin-right: 0.1em;
  }
  blockquote p::after {
    content: "\201D";
    color: var(--terracotta);
    margin-left: 0.05em;
  }
  @media (max-width: 640px) {
    .pull-quote { padding: 48px 20px; }
    blockquote { margin: 20px 0; }
  }
</style>
