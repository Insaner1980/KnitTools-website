---
import { SITE_URL } from "../config/brand";

interface Faq {
  q: string;
  a: string;
}

interface Props {
  name: string;
  description: string;
  canonicalPath: string;
  faqs?: readonly Faq[];
  priceCurrency?: string;
}

const {
  name,
  description,
  canonicalPath,
  faqs = [],
  priceCurrency = "USD",
} = Astro.props;

const webApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name,
  description,
  url: `${SITE_URL}${canonicalPath}`,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency,
  },
};

const faqSchema =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((faq) => ({
          "@type": "Question",
          name: faq.q,
          acceptedAnswer: { "@type": "Answer", text: faq.a },
        })),
      }
    : undefined;
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(webApplicationSchema)}
/>

{
  faqSchema && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(faqSchema)}
    />
  )
}
