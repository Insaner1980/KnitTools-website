---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  screenshot: ImageMetadata;
  alt: string;
  theme?: 'light' | 'dark';
  class?: string;
}

const { screenshot, alt, theme = 'light', class: className } = Astro.props;
const isDark = theme === 'dark';
---

<div class:list={['phone-mockup', `phone-${theme}`, className]}>
  <div class="phone-body">
    <div class="phone-screen">
      {/* Android status bar */}
      <div class="status-bar">
        <span class="status-time">14:32</span>
        <div class="status-icons">
          {/* Signal */}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M2 22h4V12H2v10zm6 0h4V7H8v15zm6 0h4V2h-4v20z"/></svg>
          {/* WiFi */}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
          {/* Battery */}
          <svg width="14" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M15.67 4H14V2h-4v2H8.33C7.6 4 7 4.6 7 5.33v15.33C7 21.4 7.6 22 8.33 22h7.33c.74 0 1.34-.6 1.34-1.33V5.33C17 4.6 16.4 4 15.67 4z"/></svg>
        </div>
      </div>
      {/* Punch-hole camera */}
      <div class="punch-hole"></div>
      {/* App screenshot */}
      <Image
        src={screenshot}
        alt={alt}
        widths={[360, 720]}
        sizes="360px"
        loading="lazy"
      />
      {/* Optional overlay content (e.g. animated counter) */}
      <slot />
      {/* Android gesture navigation bar */}
      <div class="nav-bar">
        <div class="gesture-line"></div>
      </div>
    </div>
    {/* Side edges for 3D depth */}
    <div class="phone-side-right"></div>
    <div class="phone-side-bottom"></div>
  </div>
</div>

<style>
  .phone-mockup {
    position: relative;
    width: 280px;
    flex-shrink: 0;
    transform-style: preserve-3d;
    perspective: 1200px;
  }

  .phone-body {
    position: relative;
    transform-style: preserve-3d;
    border-radius: 36px;
    background: #1a1816;
    padding: 8px;
    box-shadow:
      0 20px 60px rgba(0,0,0,0.3),
      0 8px 24px rgba(0,0,0,0.2);
  }

  .phone-screen {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    background: #f5f3ee;
    z-index: 1;
  }

  /* Android status bar */
  .status-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 16px 0;
    z-index: 3;
    font-family: 'Roboto', sans-serif;
    font-size: 11px;
    font-weight: 500;
  }

  .phone-light .status-bar {
    color: #2E2A26;
  }

  .phone-dark .status-bar {
    color: #E8E4D0;
  }

  .status-time {
    letter-spacing: 0.3px;
  }

  .status-icons {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .status-icons svg {
    opacity: 0.8;
  }

  /* Punch-hole camera (Android style) */
  .punch-hole {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 10px;
    height: 10px;
    background: #1a1816;
    border-radius: 50%;
    z-index: 4;
  }

  /* App screenshot */
  .phone-screen :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Android gesture navigation bar */
  .nav-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
  }

  .gesture-line {
    width: 35%;
    height: 4px;
    border-radius: 4px;
  }

  .phone-light .gesture-line {
    background: rgba(46, 42, 38, 0.25);
  }

  .phone-dark .gesture-line {
    background: rgba(232, 228, 208, 0.3);
  }

  /* 3D side edges — visible when phone is tilted */
  .phone-side-right {
    position: absolute;
    top: 4px;
    right: -8px;
    width: 8px;
    height: calc(100% - 8px);
    background: linear-gradient(to right, #2a2724, #1a1816);
    border-radius: 0 4px 4px 0;
    transform: rotateY(90deg);
    transform-origin: left center;
  }

  .phone-side-bottom {
    position: absolute;
    bottom: -8px;
    left: 4px;
    width: calc(100% - 8px);
    height: 8px;
    background: linear-gradient(to bottom, #2a2724, #1a1816);
    border-radius: 0 0 4px 4px;
    transform: rotateX(-90deg);
    transform-origin: top center;
  }

  @media (max-width: 768px) {
    .phone-mockup {
      width: 220px;
    }

    .phone-body {
      padding: 6px;
      border-radius: 30px;
    }

    .phone-screen {
      border-radius: 24px;
    }

    .status-bar {
      height: 22px;
      font-size: 9px;
      padding: 3px 12px 0;
    }

    .punch-hole {
      width: 8px;
      height: 8px;
      top: 6px;
    }

    .status-icons svg {
      width: 10px;
      height: 10px;
    }

    .nav-bar {
      height: 20px;
    }

    .gesture-line {
      height: 3px;
    }
  }
</style>
