---

<section class="free-tools" id="free-tools">
  <div class="free-tools-inner reveal">
    <h2 class="free-tools-heading">Try our free knitting calculators</h2>
    <div class="free-tools-links">
      <a href="/tools/cast-on-calculator">Cast On Calculator &rarr;</a>
      <a href="/tools/yarn-estimator">Yarn Estimator &rarr;</a>
    </div>
  </div>
</section>

<style>
  .free-tools {
    background: var(--cream);
    padding: 4rem 20px;
  }

  .free-tools-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .free-tools-heading {
    color: var(--text-on-light);
    margin-bottom: 1.5rem;
  }

  .free-tools-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .free-tools-links a {
    color: var(--accent);
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 200ms;
  }

  .free-tools-links a:hover {
    color: var(--accent-hover);
  }

  @media (min-width: 769px) {
    .free-tools {
      padding: 6rem 48px;
    }

    .free-tools-links {
      flex-direction: row;
      gap: 40px;
      justify-content: center;
    }
  }
</style>
