---
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const latest = articles
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const placeholders = [
  {
    tag: 'Technique',
    title: 'Reading a pattern without losing the thread',
    description: 'A plain-language walk-through of how a written pattern really works, stitch by stitch.',
    href: '/articles',
  },
  {
    tag: 'Reference',
    title: 'Yarn weights, meters, and what the label is telling you',
    description: 'From lace to super bulky, what the numbers on a ball band actually mean for a finished piece.',
    href: '/articles',
  },
  {
    tag: 'Yarn',
    title: 'On stash, dye lots, and why it matters',
    description: 'A short guide to keeping a stash that behaves, so the next project starts on good footing.',
    href: '/articles',
  },
];

const useReal = latest.length >= 3;
const items = useReal
  ? latest.map((a) => ({
      tag: a.data.tags[0] ?? 'Article',
      title: a.data.title,
      description: a.data.description,
      href: `/articles/${a.id}`,
    }))
  : placeholders;
---

<section class="articles-teaser" aria-labelledby="teaser-heading">
  <div class="inner">
    <header class="teaser-head">
      <p class="section-label">
        <span class="label-text">Further reading</span>
      </p>
      <h2 id="teaser-heading" class="title">From the<br /><em>Journal.</em></h2>
    </header>

    <ol class="teaser-grid">
      {
        items.map((item, idx) => (
          <li class="teaser-card">
            <p class="card-tag">
              <span class="card-num">Nº {String(idx + 1).padStart(2, '0')}</span>
              <span class="card-cat">{item.tag}</span>
            </p>
            <h3 class="card-title">
              <a href={item.href}>{item.title}</a>
            </h3>
            <p class="card-desc">{item.description}</p>
            <a class="card-link" href={item.href}>Continue reading →</a>
          </li>
        ))
      }
    </ol>

    {
      !useReal && (
        <p class="placeholder-note">
          <em>Articles forthcoming. Full journal opens with launch.</em>
        </p>
      )
    }
  </div>
</section>

<style>
  .articles-teaser {
    background: var(--paper);
    padding: 100px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .teaser-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 48px;
  }
  .section-label {
    display: inline-flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 10px;
  }
  .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.75rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .title em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .teaser-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }

  .teaser-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-right: 32px;
    border-right: 1px solid rgba(42, 30, 23, 0.2);
  }
  .teaser-card:last-child {
    border-right: 0;
    padding-right: 0;
  }

  .card-tag {
    display: flex;
    align-items: baseline;
    gap: 14px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
  }
  .card-num { color: var(--ink-soft); }
  .card-cat { color: var(--terracotta); }

  .card-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.5rem, 1.8vw, 1.85rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    color: var(--ink);
  }
  .card-title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .card-title a:hover {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  .card-desc {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }

  .card-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    margin-top: 8px;
    align-self: flex-start;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .card-link:hover {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  .placeholder-note {
    margin: 40px 0 0;
    padding-top: 20px;
    border-top: 1px solid rgba(42, 30, 23, 0.2);
    text-align: center;
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
  }

  @media (max-width: 960px) {
    .teaser-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .teaser-card {
      padding-right: 0;
      border-right: 0;
      padding-bottom: 32px;
      border-bottom: 1px solid rgba(42, 30, 23, 0.2);
    }
    .teaser-card:last-child {
      padding-bottom: 0;
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .articles-teaser { padding: 72px 20px; }
  }
</style>
