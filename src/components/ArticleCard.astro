---
import type { CollectionEntry } from "astro:content";
import {
  CATEGORY_COLORS,
  getCategoryLabel,
  type CategorySlug,
} from "../lib/categories";
import { getArticlePath } from "../i18n/articles";
import type { Lang } from "../i18n/config";

interface Props {
  article: CollectionEntry<"articles">;
  featured?: boolean;
  showCategory?: boolean;
  lang?: Lang;
  headingLevel?: 2 | 3;
}

const {
  article,
  featured = false,
  showCategory = true,
  lang = article.data.lang ?? "en",
  headingLevel = 3,
} = Astro.props;
const category = article.data.category as CategorySlug;
const colorClass = CATEGORY_COLORS[category];
const label = getCategoryLabel(category, lang);
const articlePath = getArticlePath(article, lang);
const HeadingTag = `h${headingLevel}` as const;
const dateLocale =
  lang === "fi"
    ? "fi-FI"
    : lang === "de"
      ? "de-DE"
      : lang === "sv"
        ? "sv-SE"
        : lang === "no"
          ? "nb-NO"
          : lang === "fr"
            ? "fr-FR"
            : lang === "nl"
              ? "nl-NL"
              : lang === "da"
                ? "da-DK"
                : "en-US";
---

<a
  href={articlePath}
  class:list={[
    "article-card",
    colorClass,
    featured ? "card-featured" : "card-half",
  ]}
>
  {showCategory && <span class="tag">{label}</span>}
  <HeadingTag class="card-title">{article.data.title}</HeadingTag>
  <p class="card-desc">{article.data.description}</p>
  <div class="card-meta">
    <time datetime={article.data.publishDate.toISOString()}>
      {
        article.data.publishDate.toLocaleDateString(dateLocale, {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </time>
  </div>
</a>

<style>
  .card-featured {
    grid-column: 1 / -1;
    min-height: 260px;
  }
  .card-half {
    grid-column: span 4;
    min-height: 280px;
  }

  .card-terracotta {
    --card-bg: var(--stripe-terracotta);
    --card-bg-hover: var(--stripe-terracotta);
    --card-fg: var(--paper);
  }
  .card-rust {
    --card-bg: var(--stripe-rust-accessible);
    --card-bg-hover: var(--stripe-rust-accessible);
    --card-fg: var(--paper);
  }
  .card-sand {
    --card-bg: var(--stripe-sand);
    --card-bg-hover: var(--stripe-sand);
    --card-fg: var(--ink);
  }
  .card-teal {
    --card-bg: var(--stripe-teal-accessible);
    --card-bg-hover: var(--stripe-teal-accessible);
    --card-fg: var(--paper);
  }
  .card-brown {
    --card-bg: var(--stripe-brown);
    --card-bg-hover: var(--stripe-brown);
    --card-fg: var(--paper);
  }

  .article-card {
    background-color: var(--card-bg);
    border-radius: 0;
    padding: 30px 28px 28px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 14px;
    transition: background-color 0.2s ease;
  }

  .article-card:hover {
    background-color: var(--card-bg-hover);
  }
  .article-card:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 2px;
  }

  .article-card .tag {
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--paper);
    padding: 4px 12px;
    border-radius: 9999px;
  }

  .card-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.35rem, 1.45vw, 1.7rem);
    color: var(--card-fg);
    margin: 0 0 4px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    padding-bottom: 0.04em;
    text-transform: none;
  }

  .card-featured .card-title {
    font-size: clamp(1.85rem, 2.6vw, 2.6rem);
  }

  .card-desc {
    font-family: var(--body-ed);
    font-weight: 400;
    font-size: 14px;
    color: var(--card-fg);
    line-height: 1.5;
    margin: 0;
  }

  .card-featured .card-desc {
    font-size: 16px;
    max-width: 620px;
  }

  .card-meta {
    margin-top: auto;
    padding-top: 12px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--card-fg);
  }

  @media (max-width: 1024px) {
    .card-half {
      grid-column: span 1;
    }
  }

  @media (max-width: 768px) {
    .card-featured,
    .card-half {
      grid-column: span 1;
      min-height: auto;
      padding: 28px 24px;
    }

    .card-title {
      font-size: clamp(1.5rem, 7vw, 1.9rem);
    }
  }
</style>
