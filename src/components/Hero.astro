---
import { PRICING } from "../config/pricing";
import RegionalPrice from "./RegionalPrice.astro";
import RegionalPricingNote from "./RegionalPricingNote.astro";
---

<section class="hero-editorial" aria-labelledby="hero-heading">
  <div class="hero-inner">
    <div class="hero-text">
      <p class="eyebrow">An Android app for knitters</p>
      <h1 id="hero-heading" class="wordmark" aria-label="KnitTools">
        <span class="wordmark-line">Knit</span>
        <span class="wordmark-line">Tools</span>
      </h1>
      <p class="tagline">
        <em
          >From cast on to bind off,<br /><span class="accent"
            >one app keeps up.</span
          ></em
        >
      </p>
    </div>

    <aside class="signup-card" aria-label="Launch signup">
      <h2 class="card-head">Coming {PRICING.launchMonthLabel}</h2>
      <p class="card-copy">
        Be first to know when KnitTools launches on Google Play.
      </p>

      <form class="signup" id="hero-signup" action="#" method="post">
        <label for="hero-email" class="visually-hidden">Email address</label>
        <label for="hero-website" class="visually-hidden"
          >Leave this field empty</label
        >
        <input
          id="hero-website"
          name="website"
          type="text"
          class="visually-hidden"
          tabindex="-1"
          autocomplete="off"
        />
        <div class="signup-rows" data-content>
          <input
            id="hero-email"
            type="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn-notify">Notify me at launch</button>
        </div>
        <p class="signup-success" data-success aria-hidden="true">
          You're in. We'll email you at launch.
        </p>
        <p class="signup-error" data-error aria-hidden="true">
          Something went wrong. Please try again.
        </p>
        <p class="card-caption">
          Launch price <RegionalPrice phase="launch" />. Regular price <RegionalPrice
            phase="permanent"
          /> later. {PRICING.trialDays}-day free trial. <RegionalPricingNote />
        </p>
      </form>
    </aside>
  </div>
</section>

<script is:inline>
  (() => {
    const ENDPOINT = "https://api.finnvek.com/subscribe";

    const form = document.getElementById("hero-signup");
    if (!form) return;

    const content = form.querySelector("[data-content]");
    const success = form.querySelector("[data-success]");
    const errorEl = form.querySelector("[data-error]");
    const button = form.querySelector('button[type="submit"]');
    const emailInput = form.querySelector('input[type="email"]');
    const honeypot = form.querySelector('input[name="website"]');
    const originalText = button ? button.textContent : "Notify me at launch";

    const showSuccess = () => {
      if (content) content.style.display = "none";
      if (errorEl) {
        errorEl.style.display = "none";
        errorEl.setAttribute("aria-hidden", "true");
      }
      if (success) {
        success.style.display = "block";
        success.setAttribute("aria-hidden", "false");
      }
    };

    const showError = (message) => {
      if (button) {
        button.disabled = false;
        button.textContent = originalText;
      }
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = "block";
        errorEl.setAttribute("aria-hidden", "false");
      }
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      if (button) {
        button.disabled = true;
        button.textContent = "Sending…";
      }
      if (errorEl) {
        errorEl.style.display = "none";
        errorEl.setAttribute("aria-hidden", "true");
      }

      try {
        const res = await fetch(ENDPOINT, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email: emailInput ? emailInput.value.trim() : "",
            source: "knittools",
            website: honeypot ? honeypot.value : "",
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          showSuccess();
        } else {
          showError(data.error || "Something went wrong. Please try again.");
        }
      } catch {
        showError("Network error. Please check your connection.");
      }
    });
  })();
</script>

<style>
  .hero-editorial {
    position: relative;
    padding: 0.75rem 2rem;
    overflow: hidden;
    /* 80px body padding + ~70px marquee reserved so the strip is fully
       visible in the first desktop viewport. */
    min-height: calc(100svh - 150px);
    display: flex;
    align-items: center;
  }

  .hero-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .hero-text {
    min-width: 0;
    padding-right: 0;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 28px;
    text-align: left;
  }

  .wordmark {
    font-family: var(--font-logo);
    font-weight: 500;
    font-size: clamp(64px, 12vw, 180px);
    line-height: 0.75;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
    padding: 0;
    text-align: left;
  }
  .wordmark-line {
    display: block;
    line-height: 0.75;
    margin: 0;
    padding: 0;
  }

  .tagline {
    font-family: var(--body-ed);
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.2;
    color: var(--ink);
    width: 100%;
    margin: 16px 0 0;
    padding: 0;
    text-align: left;
  }
  .tagline em {
    font-style: italic;
  }
  .tagline .accent {
    color: var(--terracotta);
    font-weight: 700;
  }

  .signup-card {
    background: var(--paper-2);
    border: 1.5px solid var(--ink);
    padding: 2.25rem 2rem;
    max-width: 460px;
    width: 100%;
    justify-self: end;
    align-self: center;
  }

  .card-head {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 12px;
  }

  .card-copy {
    font-family: var(--body-ed);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 20px;
  }

  .signup {
    margin: 0;
    width: 100%;
  }
  .signup-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .signup input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--body-ed);
    font-size: 16px;
    padding: 14px 16px;
    border: 1.5px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    border-radius: 0;
    min-width: 0;
  }
  .signup input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }
  .btn-notify {
    width: 100%;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 14px 22px;
    border-radius: 0;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .btn-notify:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .btn-notify:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }

  .signup-success {
    display: none;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 18px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .signup-error {
    display: none;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-soft, var(--ink));
    margin: 0;
    padding: 8px 0;
  }
  .card-caption {
    margin: 14px 0 0;
    font-family: var(--body-ed);
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-soft);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .hero-editorial {
      min-height: auto;
      padding: 5rem 1.5rem 3.5rem;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .signup-card {
      justify-self: stretch;
      max-width: 100%;
    }
    .wordmark {
      font-size: clamp(64px, 18vw, 140px);
    }
  }
</style>
