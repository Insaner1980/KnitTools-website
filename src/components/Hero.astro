---
---

<section class="hero-editorial" aria-labelledby="hero-heading">
  <div class="hero-inner">
    <div class="hero-text">
      <p class="eyebrow">An Android app for knitters</p>
      <h1 id="hero-heading" class="hero-head">
        <span class="head-line head-1">Every</span>
        <span class="head-line head-2">knitting tool.</span>
        <span class="head-line head-3"><em>One app.</em></span>
      </h1>
      <p class="dek">The row you were on, the yarn you forgot, the pattern that made no sense at midnight. <strong>KnitTools remembers it all</strong>, so the only thing you do is keep knitting.</p>

      <form class="signup" id="hero-signup" action="#" method="post">
        <label for="hero-email" class="visually-hidden">Email address</label>
        <div class="signup-row" data-content>
          <input
            id="hero-email"
            type="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn-primary">Notify me at launch</button>
        </div>
        <p class="signup-success" data-success aria-hidden="true">
          You're in. We'll email you at launch.
        </p>
        <p class="signup-meta">
          Coming 2026 to Google Play. 14-day free trial.<br>
          Launch price <strong>$8.99</strong>, rises to $11.99 after two months.
        </p>
      </form>
    </div>

    <div class="hero-badge" aria-hidden="true">
      <svg class="hero-badge-svg" viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Coming soon">
        <circle cx="140" cy="140" r="130" class="badge-circle" />
        <text x="140" y="135" text-anchor="middle" class="badge-text">COMING</text>
        <text x="140" y="190" text-anchor="middle" class="badge-text">SOON</text>
      </svg>
    </div>
  </div>

</section>

<script is:inline>
  (() => {
    const form = document.getElementById('hero-signup');
    if (!form) return;
    const content = form.querySelector('[data-content]');
    const success = form.querySelector('[data-success]');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      content.style.display = 'none';
      success.style.display = 'block';
      success.setAttribute('aria-hidden', 'false');
    });
  })();
</script>


<style>
  .hero-editorial {
    position: relative;
    padding: 6rem 2rem;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    max-width: 60ch;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 20px;
    text-align: left;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.005em;
    margin: 0 0 28px;
    color: var(--ink);
  }
  .hero-head {
    display: block;
    text-align: left;
    line-height: 1.0;
    margin: 0 0 28px;
  }
  .hero-head .head-line {
    display: block;
    text-align: left;
    margin-left: 0 !important;
    padding-left: 0 !important;
    text-indent: 0 !important;
    color: var(--ink);
  }
  .hero-head .head-1,
  .hero-head .head-2 {
    font-size: clamp(3rem, 6vw, 6.5rem);
    line-height: 1.05;
    letter-spacing: -0.005em;
    font-style: normal;
    color: var(--ink);
  }
  .hero-head .head-3 {
    font-size: clamp(4rem, 8vw, 8rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin-top: 0.05em;
    color: var(--terracotta);
  }
  .hero-head .head-3 em {
    display: inline-block;
    font-style: italic;
    color: var(--terracotta);
    margin-left: -0.18em;
  }

  .dek {
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.6;
    color: var(--ink);
    max-width: 50ch;
    margin: 3rem 0 0;
    text-align: left;
  }
  .dek strong {
    color: var(--terracotta);
    font-weight: 600;
  }

  .signup {
    max-width: 480px;
    margin: 2rem 0 0;
    width: 100%;
  }
  .signup-row {
    display: flex;
    gap: 0;
    align-items: stretch;
  }
  .signup input {
    flex: 1;
    font-family: var(--body-ed);
    font-size: 16px;
    padding: 14px 20px;
    border: 1.5px solid var(--ink);
    border-right: 0;
    background: var(--paper-2);
    color: var(--ink);
    border-radius: 0;
    min-width: 0;
  }
  .signup input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }
  .btn-primary {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 14px 22px;
    border-radius: 0;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .btn-primary:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .btn-primary:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }

  .signup-success {
    display: none;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 18px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .signup-meta {
    max-width: 50ch;
    margin: 1.5rem 0 0;
    text-align: left;
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
  }
  .signup-meta strong { color: var(--terracotta); font-weight: 600; }

  .hero-badge {
    display: flex;
    justify-content: center;
    align-items: center;
    transform: translate(-150px, -130px);
  }
  .hero-badge-svg {
    width: 280px;
    height: 280px;
    display: block;
    transform: rotate(-10deg);
  }
  .badge-circle {
    fill: var(--terracotta);
  }
  .badge-text {
    fill: var(--paper);
    font-family: var(--body-ed);
    font-size: 44px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 768px) {
    .hero-editorial {
      padding: 4rem 1.5rem;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-text {
      max-width: 100%;
    }
    .head-1,
    .head-2 {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }
    .head-3 {
      font-size: clamp(3rem, 13vw, 5rem);
    }
    .hero-badge {
      order: -1;
    }
    .hero-badge-svg {
      width: 180px;
      height: 180px;
    }
    .signup-row { flex-direction: column; }
    .signup input { border-right: 1.5px solid var(--ink); border-bottom: 0; }
  }
</style>
