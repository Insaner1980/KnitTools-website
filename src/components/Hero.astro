---
import PhoneMockup from './PhoneMockup.astro';
import counterLight from '../assets/images/counter-light.png';
---

<section class="hero-editorial dot-grid-paper" aria-labelledby="hero-heading">
  <div class="hero-meta-strip">
    <div class="rule-double"></div>
    <div class="meta-row">
      <span>Vol. 01 · Pre-launch</span>
      <span>"Pick up where you left off."</span>
      <span>EST. 2026</span>
    </div>
    <div class="rule-double"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-text">
      <p class="eyebrow">A knitting toolkit for Android · Launching soon</p>
      <h1 id="hero-heading">Pick up where<br />you <em>left off.</em></h1>
      <p class="dek">
        The row you were on, the yarn you forgot, the pattern that made no sense at midnight. KnitTools remembers it
        all — so the only thing you need to do is keep knitting.
      </p>

      <form class="signup" id="hero-signup" action="#" method="post">
        <label for="hero-email" class="visually-hidden">Email address</label>
        <div class="signup-row" data-content>
          <input
            id="hero-email"
            type="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn-primary">Join the list</button>
        </div>
        <p class="signup-success" data-success aria-hidden="true">
          You're in. We'll email you at launch.
        </p>
        <p class="signup-meta">
          Lock in the launch price: <strong>€8.99</strong> → €11.99 two months after launch.
        </p>
      </form>
    </div>

    <div class="hero-phone">
      <div class="phone-glow" aria-hidden="true"></div>
      <PhoneMockup
        screenshot={counterLight}
        alt="KnitTools row counter showing an active project"
        theme="light"
      />
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById('hero-signup');
    if (!form) return;
    const content = form.querySelector('[data-content]');
    const success = form.querySelector('[data-success]');
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      content.style.display = 'none';
      success.style.display = 'block';
      success.setAttribute('aria-hidden', 'false');
    });
  })();
</script>

<style>
  .hero-editorial {
    position: relative;
    padding: 100px 40px 80px;
    overflow: hidden;
  }
  .hero-meta-strip {
    max-width: 1280px;
    margin: 0 auto 56px;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    gap: 24px;
    flex-wrap: wrap;
  }
  .meta-row span:nth-child(2) {
    font-style: italic;
    font-family: var(--serif);
    font-size: 13px;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink);
  }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text { max-width: 640px; }

  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(3.5rem, 8vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--ink);
  }
  h1 em {
    color: var(--terracotta);
    font-style: italic;
  }

  .dek {
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 32px;
    max-width: 560px;
  }
  .dek::first-letter {
    font-family: var(--serif);
    font-size: 64px;
    float: left;
    line-height: 0.85;
    padding: 6px 10px 0 0;
    color: var(--terracotta);
  }

  .signup { max-width: 520px; }
  .signup-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }
  .signup input {
    flex: 1;
    font-family: var(--body-ed);
    font-size: 16px;
    padding: 14px 20px;
    border: 1.5px solid var(--ink);
    background: var(--paper-2);
    color: var(--ink);
    border-radius: 999px;
    min-width: 0;
  }
  .signup input:focus {
    outline: 2px solid var(--amber);
    outline-offset: 2px;
  }
  .btn-primary {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--amber);
    color: var(--paper);
    border: 2px solid var(--ink);
    padding: 14px 22px;
    border-radius: 999px;
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .btn-primary:hover { background: var(--amber-hover); transform: scale(1.02); }
  .btn-primary:focus-visible {
    outline: 2px solid var(--amber);
    outline-offset: 3px;
  }

  .signup-success {
    display: none;
    font-family: var(--serif);
    font-style: italic;
    font-size: 24px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
  }
  .signup-meta {
    margin: 14px 0 0;
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
  }
  .signup-meta strong { color: var(--terracotta); font-weight: 600; }

  .hero-phone {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-phone :global(.phone-mockup) {
    width: 320px;
    transform: rotate(-2deg);
  }
  .phone-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(160, 80, 56, 0.15) 0 40%, transparent 70%);
    filter: blur(40px);
    z-index: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1023px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-phone { justify-content: center; }
  }
  @media (max-width: 640px) {
    .hero-editorial { padding: 90px 20px 60px; }
    .meta-row { font-size: 10px; gap: 12px; justify-content: center; text-align: center; }
    .meta-row span:nth-child(2) { order: 3; flex-basis: 100%; }
    .signup-row { flex-direction: column; }
    .hero-phone :global(.phone-mockup) { width: min(72vw, 280px); }
  }
</style>
