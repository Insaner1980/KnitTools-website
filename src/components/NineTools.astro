---
import RegionalPrice from "./RegionalPrice.astro";

const languages = [
  "English",
  "Suomi",
  "Svenska",
  "Dansk",
  "Norsk",
  "Nederlands",
  "Deutsch",
  "Français",
  "Italiano",
  "Português",
  "Español",
];

const cards = [
  {
    tag: "Counter",
    tier: "free",
    title: "Saved row counter",
    body: "A big round button where your thumb already is. Miscount? Undo. Your row count stays with the project.",
    chips: true,
    span: 2,
  },
  {
    tag: "Pattern",
    tier: "free",
    title: "Pattern viewer with row notes",
    body: "PDF or Ravelry pull-in. Annotate rows, mark your place, and return to the spot you saved.",
    tint: "amber",
  },
  {
    tag: "Calc",
    tier: "free",
    title: "Four knitting calculators",
    body: "Cast on, gauge, increases, yardage. The math your knitting already asked you to do.",
  },
  {
    tag: "Ravelry",
    tier: "free",
    title: "Ravelry, the way it should feel",
    body: "Search, save, start a project in one tap. Log in through Ravelry itself. Your password never touches this app.",
    tint: "walnut",
  },
  {
    tag: "Reference",
    tier: "free",
    title: "Reference library",
    body: "Needles, sizes, chart symbols, and abbreviations, ready when you need them.",
  },
  {
    tag: "Photos",
    tier: "pro",
    title: "Progress photos, just for you",
    body: "One folder per project. Full resolution, on your device, nothing uploaded anywhere.",
  },
  {
    tag: "Stats",
    tier: "pro",
    title: "Project stats without the pressure",
    body: "Hours at the needles. Rows per hour. Streaks. No leaderboards, no nudges, no comparing.",
    tint: "sage",
  },
  {
    tag: "Widget",
    tier: "pro",
    title: "A widget on your home screen",
    body: "Tap to count. No app launch, no loading. The exact amount of friction a row counter should have, which is zero.",
    tint: "terracotta",
  },
];

const freeCards = cards.filter((c) => c.tier === "free");
const proCards = cards.filter((c) => c.tier === "pro");
---

<section class="nine-tools" aria-labelledby="nine-heading">
  <div class="nine-inner">
    <header class="section-head">
      <p class="section-label">
        <span class="label-text">Features</span>
      </p>
      <h2 id="nine-heading" class="title">
        Your knitting tools,<br /><em>in one project home.</em>
      </h2>
    </header>

    <p class="manifesto">
      Keep your counter, pattern, notes, photos, and tools together in one
      project home, so you can pick up where you left off.
    </p>

    <div class="tier-head" aria-hidden="true">
      <span class="tier-label">Free forever</span>
      <span class="tier-count">{freeCards.length} tools</span>
      <span class="tier-line"></span>
    </div>

    <div class="nine-grid">
      {
        freeCards.map((c) => (
          <article
            class:list={[
              "tool-card",
              c.tint && `tint-${c.tint}`,
              c.span === 2 && "span-2",
            ]}
          >
            <div class="card-meta">
              <span class="tag">{c.tag}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
            {c.chips && (
              <ul class="chip-row" aria-label="Supported languages">
                {languages.map((lang) => (
                  <li class="chip">{lang}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </div>

    <div class="tier-head tier-head-pro" aria-hidden="true">
      <span class="tier-label">Pro <RegionalPrice phase="launch" /></span>
      <span class="tier-count">{proCards.length} tools</span>
      <span class="tier-line"></span>
    </div>

    <div class="nine-grid pro-feature-grid">
      {
        proCards.map((c) => (
          <article
            class:list={[
              "tool-card",
              c.tint && `tint-${c.tint}`,
              c.span === 2 && "span-2",
            ]}
          >
            <div class="card-meta">
              <span class="tag">{c.tag}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .nine-tools {
    color: var(--ink);
    padding: 120px 40px;
  }
  .nine-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 28px;
  }

  .manifesto {
    font-family: var(--body-ed);
    font-size: 17px;
    line-height: 1.6;
    font-weight: 400;
    color: var(--ink);
    max-width: 580px;
    margin: 0 0 40px;
  }
  .manifesto em {
    font-style: italic;
    font-weight: 500;
    color: var(--terracotta);
  }
  .section-head .section-label {
    display: inline-flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 10px;
  }
  .section-head .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .section-head .title em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .tier-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .tier-head-pro {
    margin-top: 64px;
  }
  .tier-head .tier-label {
    color: var(--terracotta);
    white-space: nowrap;
  }
  .tier-head .tier-count {
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .tier-head .tier-line {
    flex: 1;
    height: 1px;
    background: var(--ink);
    opacity: 0.4;
  }

  .nine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .nine-grid + .nine-grid {
    margin-top: 20px;
  }
  .nine-grid + .tier-head-pro {
    margin-top: 48px;
  }

  .tool-card {
    background: var(--wheat);
    color: #2a1e17;
    border: 1px solid #2a1e17;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-radius: 0;
  }
  .tool-card.span-2 {
    grid-column: span 2;
  }

  .tool-card.tint-sage {
    background: var(--sage);
    color: #f4ead9;
    border-color: var(--sage);
  }
  .tool-card.tint-sage h3 {
    color: #f4ead9;
  }
  .tool-card.tint-sage p {
    color: rgba(244, 234, 217, 0.9);
  }

  .tool-card.tint-walnut {
    background: var(--walnut);
    color: #f4ead9;
    border-color: var(--walnut);
  }
  .tool-card.tint-walnut h3 {
    color: #f4ead9;
  }
  .tool-card.tint-walnut p {
    color: rgba(244, 234, 217, 0.88);
  }

  .tool-card.tint-amber {
    background: var(--amber);
    color: #f4ead9;
    border-color: var(--amber);
  }
  .tool-card.tint-amber h3 {
    color: #f4ead9;
  }
  .tool-card.tint-amber p {
    color: rgba(244, 234, 217, 0.92);
  }

  .tool-card.tint-terracotta {
    background: #a05038;
    color: #f4ead9;
    border-color: #a05038;
  }
  .tool-card.tint-terracotta h3 {
    color: #f4ead9;
  }
  .tool-card.tint-terracotta p {
    color: rgba(244, 234, 217, 0.92);
  }

  .tool-card.tint-ink {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .tool-card.tint-ink h3 {
    color: var(--paper);
  }
  .tool-card.tint-ink p {
    color: var(--paper);
    opacity: 0.85;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .tag {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2a1e17;
  }
  .pill {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid var(--ink);
  }
  .pill-free {
    background: var(--paper);
    color: var(--ink);
  }
  .pill-pro {
    background: var(--terracotta);
    color: var(--paper);
    border-color: var(--terracotta);
  }
  .tool-card.tint-sage .pill-free,
  .tool-card.tint-walnut .pill-free,
  .tool-card.tint-ink .pill-free {
    background: transparent;
    color: var(--paper);
    border-color: var(--paper);
  }

  .tool-card h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 1.9vw, 1.9rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-transform: none;
    margin: 0;
    color: #2a1e17;
  }
  .tool-card p {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.55;
    color: #2a1e17;
    margin: 0;
  }

  .chip-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: 4px 0 0;
  }
  .chip {
    font-family: var(--body-ed);
    font-size: 11px;
    color: var(--ink);
    background: var(--paper);
    border: 0;
    padding: 4px 11px;
    border-radius: 999px;
  }

  @media (max-width: 1024px) {
    .nine-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .tool-card.span-2 {
      grid-column: 1 / -1;
    }
    .pro-feature-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 767px) {
    .nine-tools {
      padding: 80px 20px;
    }
    .section-head .section-label {
      gap: 12px;
    }
    .nine-grid {
      grid-template-columns: 1fr;
    }
    .tool-card.span-2 {
      grid-column: auto;
    }
    .tool-card {
      padding: 24px 22px 28px;
    }
  }
</style>
