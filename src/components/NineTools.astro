</style>

<script is:inline>
  (() => {
    const wave = document.getElementById("ai-waveform");
    if (wave) {
      const bars = 44;
      const variants = ["", "v-b", "v-c", "v-d"];
      for (let i = 0; i < bars; i++) {
        const bar = document.createElement("span");
        const h = 18 + Math.round(Math.random() * 82);
        const dur = (0.7 + Math.random() * 1.6).toFixed(2);
        const delay = (Math.random() * 1.8).toFixed(2);
        const v = variants[Math.floor(Math.random() * variants.length)];
        bar.style.height = h + "%";
        bar.style.setProperty("--wave-dur", dur + "s");
        bar.style.setProperty("--wave-delay", delay + "s");
        if (v) bar.className = v;
        wave.appendChild(bar);
      }
    }

    const pairs = [
      {
        you: '"Next row."',
        ai: "Row 85. Two more before your sleeve increase.",
      },
      {
        you: '"What\'s sl1 k2tog psso?"',
        ai: "Slip one, knit two together, pass the slipped stitch over.",
      },
      {
        you: '"Set row to 100."',
        ai: "Counter set to 100. You are halfway through the yoke.",
      },
    ];

    const youEl = document.querySelector('[data-msg="you"]');
    const aiEl = document.querySelector('[data-msg="ai"]');
    if (!youEl || !aiEl) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    async function typeInto(el, text) {
      el.classList.add("typing");
      el.textContent = "";
      for (let i = 0; i < text.length; i++) {
        el.textContent += text[i];
        await sleep(22 + Math.random() * 24);
      }
      el.classList.remove("typing");
    }

    async function loop() {
      let idx = 0;
      if (prefersReduced) {
        youEl.textContent = pairs[0].you;
        aiEl.textContent = pairs[0].ai;
        return;
      }
      while (true) {
        const p = pairs[idx];
        youEl.textContent = "\u00A0";
        aiEl.textContent = "\u00A0";
        await sleep(400);
        await typeInto(youEl, p.you);
        await sleep(700);
        await typeInto(aiEl, p.ai);
        await sleep(3200);
        idx = (idx + 1) % pairs.length;
      }
    }

    const io = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loop();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.25 },
    );
    io.observe(document.querySelector(".ai-broadcast"));
  })();
</script>
