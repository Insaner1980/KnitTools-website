---
const languages = [
  'English',
  'Finnish',
  'Danish',
  'Dutch',
  'French',
  'German',
  'Italian',
  'Norwegian',
  'Portuguese',
  'Spanish',
  'Swedish',
];

const cards = [
  {
    lead: 'Row counter',
    rest: ' with memory',
    body:
      'A big round button where your thumb already is. Tap without looking. Miscount? Undo. Say "add three" or "next row" — works with no signal.',
    chips: true,
  },
  {
    lead: 'Pattern viewer',
    rest: ' that follows along',
    body:
      "PDF or Ravelry pull-in. The row you're on highlights itself. Tap sl1, k2tog, psso. AI explains what it does, step by step.",
  },
  {
    lead: 'Yarn scanner',
    rest: ' for the label graveyard',
    body:
      'Point the camera at the ball band. AI reads fiber, weight, meters, needle size, gauge, dye lot. Filed in your stash with a photo. That mystery skein finally has a name.',
  },
  {
    lead: 'Four calculators',
    rest: ', quietly working',
    body: 'Cast on, gauge, increases, yardage. The math your knitting already asked you to do.',
  },
  {
    lead: 'Ravelry',
    rest: ', the way it should feel',
    body:
      'Search, save, start a project in one tap. Log in through Ravelry itself. Your password never touches this app.',
  },
  {
    lead: 'Reference',
    rest: ', one tap away',
    body:
      'Needles, sizes, chart symbols, abbreviations. Right there in your library, before you remember you needed it.',
  },
  {
    lead: 'Progress photos',
    rest: ', just for you',
    body: 'One folder per project. Full resolution, on your device, nothing uploaded anywhere.',
  },
  {
    lead: 'Insights',
    rest: ' without the pressure',
    body:
      'Hours at the needles. Rows per hour. Streaks. No leaderboards, no nudges, no comparing. The stats are yours.',
  },
  {
    lead: 'A widget',
    rest: ' on your home screen',
    body:
      'Tap to count. No app launch, no loading. The exact amount of friction a row counter should have, which is zero.',
  },
];
---

<section class="nine-tools" aria-labelledby="nine-heading">
  <div class="nine-inner">
    <div class="nine-head">
      <p class="eyebrow">What's inside</p>
      <h2 id="nine-heading">Every tool,<br /><em>talking to each other.</em></h2>
    </div>

    <div class="nine-grid">
      {
        cards.map((c) => (
          <article class="tool-card">
            <h3>
              <span class="lead">{c.lead}</span>
              <span class="rest">{c.rest}</span>
            </h3>
            <p>{c.body}</p>
            {c.chips && (
              <ul class="chip-row" aria-label="Supported languages">
                {languages.map((lang) => (
                  <li class="chip">{lang}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .nine-tools {
    background: var(--walnut);
    color: var(--paper);
    padding: 120px 40px;
  }
  .nine-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .nine-head {
    margin-bottom: 56px;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--wheat);
    margin: 0 0 18px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 5vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--paper);
  }
  h2 em {
    color: var(--wheat);
    font-style: italic;
  }

  .nine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .tool-card {
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--ink);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-radius: 0;
  }

  .tool-card h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .tool-card h3 .lead { color: var(--wheat); font-style: italic; }
  .tool-card h3 .rest { color: var(--ink); }
  .tool-card p {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }

  .chip-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: 4px 0 0;
  }
  .chip {
    font-family: var(--body-ed);
    font-size: 11px;
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--ink);
    padding: 3px 10px;
    border-radius: 999px;
  }

  @media (max-width: 1024px) {
    .nine-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 767px) {
    .nine-tools { padding: 80px 20px; }
    .nine-grid { grid-template-columns: 1fr; }
    .tool-card { padding: 28px 24px; }
  }
</style>
