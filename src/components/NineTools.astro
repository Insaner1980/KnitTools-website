---
import RegionalPrice from "./RegionalPrice.astro";

const languages = [
  "English",
  "Suomi",
  "Svenska",
  "Dansk",
  "Norsk",
  "Nederlands",
  "Deutsch",
  "Français",
  "Italiano",
  "Português",
  "Español",
];

const cards = [
  {
    tag: "Counter",
    tier: "free",
    title: "Row counter with memory",
    body: 'A big round button where your thumb already is. Tap without looking. Miscount? Undo. Say "add three" or "next row" without putting your needles down.',
    chips: true,
    span: 2,
  },
  {
    tag: "Pattern",
    tier: "free",
    title: "Pattern viewer that follows along",
    body: "PDF or Ravelry pull-in. Annotate rows, mark your place, find your way back when life interrupts.",
    tint: "amber",
  },
  {
    tag: "Calc",
    tier: "free",
    title: "Four calculators, quietly working",
    body: "Cast on, gauge, increases, yardage. The math your knitting already asked you to do.",
  },
  {
    tag: "Ravelry",
    tier: "free",
    title: "Ravelry, the way it should feel",
    body: "Search, save, start a project in one tap. Log in through Ravelry itself. Your password never touches this app.",
    tint: "walnut",
  },
  {
    tag: "Reference",
    tier: "free",
    title: "Reference, one tap away",
    body: "Needles, sizes, chart symbols, abbreviations. Right there in your library, before you remember you needed it.",
  },
  {
    tag: "Stash",
    tier: "pro",
    title: "Yarn scanner for the label graveyard",
    body: "Point the camera at the ball band. AI reads fiber, weight, meters, needle size, gauge, dye lot. Filed in your stash with a photo. That mystery skein finally has a name.",
    tint: "sage",
    span: 2,
  },
  {
    tag: "Photos",
    tier: "pro",
    title: "Progress photos, just for you",
    body: "One folder per project. Full resolution, on your device, nothing uploaded anywhere.",
  },
  {
    tag: "Insights",
    tier: "pro",
    title: "Insights without the pressure",
    body: "Hours at the needles. Rows per hour. Streaks. No leaderboards, no nudges, no comparing. The stats are yours.",
  },
  {
    tag: "Widget",
    tier: "pro",
    title: "A widget on your home screen",
    body: "Tap to count. No app launch, no loading. The exact amount of friction a row counter should have, which is zero.",
    tint: "terracotta",
  },
];

const freeCards = cards.filter((c) => c.tier === "free");
const proCards = cards.filter((c) => c.tier === "pro");

const aiFeatures = [
  {
    t: "Live voice on the counter",
    d: 'Say "next row", "set row to 100", or ask "what\'s sl1 k2tog psso" without putting the needles down. Basic commands stay offline.',
  },
  {
    t: "Pattern intelligence",
    d: "Pattern viewer reads each row aloud for you. Tap any instruction for a plain-language explanation. Paste a gnarly increase sentence and the calculator fills itself.",
  },
  {
    t: "Stash and project memory",
    d: "Scan a yarn label. Fiber, weight, meters, dye lot filed automatically. Ask for a project summary and the AI picks up where you left off, yarn compatibility and all.",
  },
  {
    t: "Voice or text journal",
    d: "Mumble a session note into the mic or type a quick line. The AI adds date and row, keeps your own words intact.",
  },
];
---

<section class="nine-tools" aria-labelledby="nine-heading">
  <div class="nine-inner">
    <header class="section-head">
      <p class="section-label">
        <span class="label-text">Features</span>
      </p>
      <h2 id="nine-heading" class="title">
        Every tool,<br /><em>talking to each other.</em>
      </h2>
    </header>

    <p class="manifesto">
      The row you were on, the yarn you forgot, the pattern that made no sense
      at midnight. <em>KnitTools remembers it all,</em> so the only thing you do is
      keep knitting.
    </p>

    <div class="tier-head" aria-hidden="true">
      <span class="tier-label">Free forever</span>
      <span class="tier-count">{freeCards.length} tools</span>
      <span class="tier-line"></span>
    </div>

    <div class="nine-grid">
      {
        freeCards.map((c) => (
          <article
            class:list={[
              "tool-card",
              c.tint && `tint-${c.tint}`,
              c.span === 2 && "span-2",
            ]}
          >
            <div class="card-meta">
              <span class="tag">{c.tag}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
            {c.chips && (
              <ul class="chip-row" aria-label="Supported languages">
                {languages.map((lang) => (
                  <li class="chip">{lang}</li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </div>

    <div class="tier-head tier-head-pro" aria-hidden="true">
      <span class="tier-label">Pro <RegionalPrice phase="launch" /></span>
      <span class="tier-count">{proCards.length} tools + AI</span>
      <span class="tier-line"></span>
    </div>

    <div class="nine-grid">
      {
        proCards.slice(0, 2).map((c) => (
          <article
            class:list={[
              "tool-card",
              c.tint && `tint-${c.tint}`,
              c.span === 2 && "span-2",
            ]}
          >
            <div class="card-meta">
              <span class="tag">{c.tag}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </article>
        ))
      }
    </div>

    <div class="nine-grid nine-grid-halves">
      {
        proCards.slice(2).map((c) => (
          <article class:list={["tool-card", c.tint && `tint-${c.tint}`]}>
            <div class="card-meta">
              <span class="tag">{c.tag}</span>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </article>
        ))
      }
    </div>

    <div class="nine-grid">
      <article class="tool-card tint-sage wide ai-card">
        <div class="card-meta">
          <span class="tag">AI</span>
        </div>
        <div class="ai-grid">
          <div class="ai-intro">
            <div class="intro-text">
              <h3>AI that <em>knows knitting</em></h3>
              <p>
                Voice that listens, eyes that read, memory that connects the
                dots across your projects. In all eleven languages.
              </p>
            </div>
            <div class="mic-area" aria-hidden="true">
              <div class="mic-stack">
                <span class="mic-ring"></span>
                <span class="mic-ring"></span>
                <span class="mic-ring"></span>
                <svg
                  class="mic-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="9" y="2" width="6" height="12" rx="3"></rect>
                  <path d="M5 10a7 7 0 0 0 14 0"></path>
                  <line x1="12" y1="19" x2="12" y2="22"></line>
                </svg>
              </div>
              <span class="bc-status">Listening</span>
            </div>
          </div>

          <ol class="ai-list">
            {
              aiFeatures.map((f) => (
                <li>
                  <div class="body">
                    <div class="t">{f.t}</div>
                    <div class="d">{f.d}</div>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <div class="ai-broadcast" aria-hidden="true">
          <div class="bc-center">
            <div class="big-wave" id="ai-waveform" aria-hidden="true"></div>
          </div>

          <div class="bc-right">
            <div class="bc-meta">
              <span class="bc-live"
                ><span class="bc-dot"></span>Transcript · Live</span
              >
              <span class="bc-row">Row 85</span>
            </div>
            <div class="bc-dialogue">
              <div class="bc-line you">
                <span class="av">You</span>
                <span class="msg" data-msg="you">&nbsp;</span>
              </div>
              <div class="bc-line ai">
                <span class="av">AI</span>
                <span class="msg" data-msg="ai">&nbsp;</span>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .nine-tools {
    color: var(--ink);
    padding: 120px 40px;
  }
  .nine-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 28px;
  }

  .manifesto {
    font-family: var(--body-ed);
    font-size: 17px;
    line-height: 1.6;
    font-weight: 400;
    color: var(--ink);
    max-width: 580px;
    margin: 0 0 40px;
  }
  .manifesto em {
    font-style: italic;
    font-weight: 500;
    color: var(--terracotta);
  }
  .section-head .section-label {
    display: inline-flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 10px;
  }
  .section-head .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .section-head .title em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .tier-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .tier-head-pro {
    margin-top: 64px;
  }
  .tier-head .tier-label {
    color: var(--terracotta);
    white-space: nowrap;
  }
  .tier-head .tier-count {
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .tier-head .tier-line {
    flex: 1;
    height: 1px;
    background: var(--ink);
    opacity: 0.4;
  }

  .nine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .nine-grid + .nine-grid {
    margin-top: 20px;
  }
  .nine-grid-halves {
    grid-template-columns: repeat(2, 1fr);
  }
  .nine-grid + .tier-head-pro {
    margin-top: 48px;
  }

  .tool-card {
    background: var(--wheat);
    color: #2a1e17;
    border: 1px solid #2a1e17;
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-radius: 0;
  }
  .tool-card.wide {
    grid-column: 1 / -1;
  }
  .tool-card.span-2 {
    grid-column: span 2;
  }

  .tool-card.tint-sage {
    background: var(--sage);
    color: #f4ead9;
    border-color: var(--sage);
  }
  .tool-card.tint-sage h3 {
    color: #f4ead9;
  }
  .tool-card.tint-sage p {
    color: rgba(244, 234, 217, 0.9);
  }

  .tool-card.tint-walnut {
    background: var(--walnut);
    color: #f4ead9;
    border-color: var(--walnut);
  }
  .tool-card.tint-walnut h3 {
    color: #f4ead9;
  }
  .tool-card.tint-walnut p {
    color: rgba(244, 234, 217, 0.88);
  }

  .tool-card.tint-amber {
    background: var(--amber);
    color: #f4ead9;
    border-color: var(--amber);
  }
  .tool-card.tint-amber h3 {
    color: #f4ead9;
  }
  .tool-card.tint-amber p {
    color: rgba(244, 234, 217, 0.92);
  }

  .tool-card.tint-terracotta {
    background: #a05038;
    color: #f4ead9;
    border-color: #a05038;
  }
  .tool-card.tint-terracotta h3 {
    color: #f4ead9;
  }
  .tool-card.tint-terracotta p {
    color: rgba(244, 234, 217, 0.92);
  }

  .tool-card.tint-ink {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .tool-card.tint-ink h3 {
    color: var(--paper);
  }
  .tool-card.tint-ink p {
    color: var(--paper);
    opacity: 0.85;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .tag {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2a1e17;
  }
  .pill {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid var(--ink);
  }
  .pill-free {
    background: var(--paper);
    color: var(--ink);
  }
  .pill-pro {
    background: var(--terracotta);
    color: var(--paper);
    border-color: var(--terracotta);
  }
  .tool-card.tint-sage .pill-free,
  .tool-card.tint-walnut .pill-free,
  .tool-card.tint-ink .pill-free {
    background: transparent;
    color: var(--paper);
    border-color: var(--paper);
  }

  .tool-card h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 1.9vw, 1.9rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-transform: none;
    margin: 0;
    color: #2a1e17;
  }
  .tool-card p {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.55;
    color: #2a1e17;
    margin: 0;
  }

  .chip-row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0;
    margin: 4px 0 0;
  }
  .chip {
    font-family: var(--body-ed);
    font-size: 11px;
    color: var(--ink);
    background: var(--paper);
    border: 0;
    padding: 4px 11px;
    border-radius: 999px;
  }

  /* ---------- AI wide card ---------- */
  .ai-card {
    padding: 40px 44px;
    position: relative;
    overflow: hidden;
  }
  .ai-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: stretch;
    margin-top: 14px;
    position: relative;
    z-index: 1;
  }
  .ai-intro {
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }
  .mic-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 24px 0;
  }
  .ai-intro h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 2.8vw, 2.75rem);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: none;
    margin: 0 0 14px;
    color: #f4ead9;
  }
  .ai-intro h3 em {
    color: #f4ead9;
    font-style: italic;
  }
  .ai-intro p {
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.6;
    color: rgba(244, 234, 217, 0.88);
    margin: 0 0 22px;
    max-width: 360px;
  }
  @keyframes wave-a {
    0%,
    100% {
      transform: scaleY(0.22);
    }
    50% {
      transform: scaleY(1.2);
    }
  }
  @keyframes wave-b {
    0%,
    100% {
      transform: scaleY(0.3);
    }
    32% {
      transform: scaleY(0.65);
    }
    58% {
      transform: scaleY(1.15);
    }
    82% {
      transform: scaleY(0.4);
    }
  }
  @keyframes wave-c {
    0%,
    100% {
      transform: scaleY(0.18);
    }
    22% {
      transform: scaleY(1.05);
    }
    44% {
      transform: scaleY(0.32);
    }
    70% {
      transform: scaleY(1.35);
    }
    88% {
      transform: scaleY(0.55);
    }
  }
  @keyframes wave-d {
    0%,
    100% {
      transform: scaleY(0.42);
    }
    18% {
      transform: scaleY(0.85);
    }
    48% {
      transform: scaleY(0.28);
    }
    76% {
      transform: scaleY(1.22);
    }
  }

  .ai-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ai-list li {
    padding: 12px 0;
    border-top: 1px solid rgba(244, 234, 217, 0.2);
  }
  .ai-list li:last-child {
    border-bottom: 1px solid rgba(244, 234, 217, 0.2);
  }
  .ai-list .t {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    line-height: 1.3;
    color: #f4ead9;
    margin-bottom: 4px;
  }
  .ai-list .d {
    font-family: var(--body-ed);
    font-size: 13px;
    line-height: 1.5;
    color: rgba(244, 234, 217, 0.78);
  }

  /* ---------- AI broadcast strip ---------- */
  .ai-broadcast {
    margin: 40px 0 0;
    padding: 0;
    background: transparent;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    column-gap: 44px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .mic-stack {
    position: relative;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f4ead9;
  }
  .mic-icon {
    width: 34px;
    height: 34px;
    position: relative;
    z-index: 2;
  }
  .mic-ring {
    position: absolute;
    inset: 0;
    border: 1.5px solid #f4ead9;
    border-radius: 50%;
    opacity: 0;
    transform: scale(1);
    animation: sonar 2.6s cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
  }
  .mic-ring:nth-child(1) {
    animation-delay: 0s;
  }
  .mic-ring:nth-child(2) {
    animation-delay: 0.85s;
  }
  .mic-ring:nth-child(3) {
    animation-delay: 1.7s;
  }
  @keyframes sonar {
    0% {
      transform: scale(1);
      opacity: 0.7;
    }
    80% {
      opacity: 0;
    }
    100% {
      transform: scale(2.6);
      opacity: 0;
    }
  }
  .bc-status {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #f4ead9;
    opacity: 0.82;
  }

  .big-wave {
    display: flex;
    align-items: center;
    gap: 3px;
    height: 140px;
    width: 100%;
  }
  .big-wave :global(span) {
    display: block;
    flex: 1 1 0;
    min-width: 2px;
    background: #f4ead9;
    border-radius: 2px;
    transform-origin: center;
    animation-name: wave-a;
    animation-duration: var(--wave-dur, 1.1s);
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-delay: var(--wave-delay, 0s);
  }
  .big-wave :global(span.v-b) {
    animation-name: wave-b;
  }
  .big-wave :global(span.v-c) {
    animation-name: wave-c;
  }
  .big-wave :global(span.v-d) {
    animation-name: wave-d;
  }

  .bc-right {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bc-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #f4ead9;
  }
  .bc-live {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .bc-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--terracotta);
    box-shadow: 0 0 0 0 rgba(194, 112, 62, 0.7);
    animation: dotPulse 1.6s ease-out infinite;
  }
  @keyframes dotPulse {
    0% {
      box-shadow: 0 0 0 0 rgba(194, 112, 62, 0.7);
    }
    70% {
      box-shadow: 0 0 0 10px rgba(194, 112, 62, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(194, 112, 62, 0);
    }
  }
  .bc-row {
    opacity: 0.7;
  }

  .bc-dialogue {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 90px;
  }
  .bc-line {
    display: grid;
    grid-template-columns: 38px 1fr;
    gap: 10px;
    align-items: baseline;
  }
  .bc-line .av {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .bc-line.you .av {
    color: #f4ead9;
  }
  .bc-line.ai .av {
    color: #f4ead9;
    opacity: 0.7;
  }
  .bc-line .msg {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.4;
    color: #f4ead9;
    min-height: 1.4em;
  }
  .bc-line.you .msg {
    font-style: italic;
  }
  .bc-line .msg::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 1em;
    margin-left: 3px;
    background: #f4ead9;
    transform: translateY(2px);
    animation: caret 0.9s steps(2) infinite;
    opacity: 0;
  }
  .bc-line .msg.typing::after {
    opacity: 1;
  }
  @keyframes caret {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .big-wave :global(span),
    .mic-ring,
    .bc-dot,
    .bc-line .msg::after {
      animation: none;
    }
    .big-wave :global(span) {
      transform: scaleY(0.8);
    }
  }

  @media (max-width: 1024px) {
    .nine-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .tool-card.wide {
      grid-column: 1 / -1;
    }
    .tool-card.span-2 {
