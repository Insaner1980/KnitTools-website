---
import { getArticlesIndexPath } from "../i18n/articles";
import { getToolsIndexPath } from "../i18n/tools";
import { useTranslations } from "../i18n/ui";
import type { Lang } from "../i18n/config";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const homeHref = "/";
const toolsIndexHref = getToolsIndexPath(lang);
const joinHref = lang === "en" ? "/#join" : `${toolsIndexHref}#join`;
const articlesHref = getArticlesIndexPath(lang);
---

<header class="nav-editorial" data-nav>
  <a href={homeHref} class="brand-mark" aria-label={t("navHome")}>KnitTools</a>
  <nav class="nav-links">
    <a href={toolsIndexHref}>{t("navTools")}</a>
    <a href={articlesHref}>{t("navArticles")}</a>
    <a href={joinHref} class="waitlist" aria-label={t("navJoin")}>
      <span class="label-full">{t("navJoin")}</span>
      <span class="label-short" aria-hidden="true">{t("navJoinShort")}</span>
    </a>
  </nav>
</header>

<script is:inline>
  (() => {
    const nav = document.querySelector("[data-nav]");
    if (!nav) return;
    const onScroll = () => {
      if (window.scrollY > 80) nav.classList.add("scrolled");
      else nav.classList.remove("scrolled");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>

<style>
  .nav-editorial {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 18px 40px;
    background: transparent;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
    border-bottom: 1px solid transparent;
  }
  .nav-editorial.scrolled {
    background: var(--paper);
    border-bottom-color: var(--ink);
  }
  .brand-mark {
    font-family: var(--font-logo);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    flex: 0 0 auto;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
    flex: 0 1 auto;
    min-width: 0;
  }
  .nav-links a {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color 0.15s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--terracotta);
  }

  .nav-links a.waitlist {
    padding: 8px 16px;
    border: 1.5px solid var(--ink);
    border-radius: 0;
    background: transparent;
    color: var(--ink);
  }
  .nav-links a.waitlist:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .label-short {
    display: none;
  }

  @media (max-width: 640px) {
    .nav-editorial {
      gap: 12px;
      padding: 14px 20px;
    }
    .brand-mark {
      font-size: 22px;
    }
    .nav-links {
      gap: 14px;
    }
    .nav-links a {
      font-size: 12px;
      letter-spacing: 0.12em;
    }
    .nav-links a.waitlist {
      padding: 6px 12px;
    }
    .label-full {
      display: none;
    }
    .label-short {
      display: inline;
    }
  }

  @media (max-width: 430px) {
    .nav-editorial {
      gap: 10px;
      padding: 14px 12px;
    }
    .brand-mark {
      font-size: 20px;
    }
    .nav-links {
      gap: 10px;
    }
    .nav-links a {
      font-size: 11px;
      letter-spacing: 0.08em;
    }
    .nav-links a.waitlist {
      padding: 5px 10px;
    }
  }
</style>
