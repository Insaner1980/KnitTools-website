---
const tools = [
  { label: 'Cast On Calculator', href: '/tools/cast-on-calculator' },
  { label: 'Yarn Estimator', href: '/tools/yarn-estimator' },
  { label: 'Needle Size Chart', href: '/tools/needle-size-chart' },
  { label: 'Yarn Weight Chart', href: '/tools/yarn-weight-chart' },
  { label: 'Knitting Abbreviations', href: '/tools/knitting-abbreviations' },
  { label: 'Knitting Size Charts', href: '/tools/knitting-size-charts' },
];

const articles = [
  { label: 'Gauge & Calculations', href: '/articles/category/gauge-calculations' },
  { label: 'Yarn', href: '/articles/category/yarn' },
  { label: 'Needles', href: '/articles/category/needles' },
  { label: 'Techniques', href: '/articles/category/techniques' },
  { label: 'App & Tools', href: '/articles/category/app-tools' },
];

const languages = [
  'English',
  'Suomi',
  'Svenska',
  'Dansk',
  'Norsk',
  'Nederlands',
  'Deutsch',
  'Français',
  'Italiano',
  'Português',
  'Español',
];
---

<footer class="footer-editorial">
  <div class="inner">
    <div class="cols-row">
      <div class="cols">
        <section>
          <h4>Tools</h4>
          <ul>
            {tools.map((t) => <li><a href={t.href}>{t.label}</a></li>)}
          </ul>
        </section>
        <section>
          <h4>Articles</h4>
          <ul>
            {articles.map((a) => <li><a href={a.href}>{a.label}</a></li>)}
          </ul>
        </section>
        <section>
          <h4>App</h4>
          <ul>
            <li><span class="muted">Launching soon</span></li>
            <li><a href="#">Privacy Policy</a></li>
          </ul>
        </section>
      </div>

      <img
        src="/logo.webp"
        alt=""
        class="footer-seal"
        width="220"
        height="220"
        aria-hidden="true"
      />
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © MMXXVI KnitTools. <a href="https://finnvek.com" target="_blank" rel="noopener">Finnvek</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-editorial {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .cols-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
    padding-bottom: 24px;
  }
  .cols {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
  }
  .cols section { min-width: 0; }
  h4 {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 16px;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  ul li {
    padding: 6px 0;
    font-family: var(--body-ed);
    font-size: 14px;
  }
  ul li a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  ul li a:hover { color: var(--terracotta); }
  .muted { color: var(--ink-soft); font-style: italic; }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid rgba(42, 30, 23, 0.12);
  }
  .footer-seal {
    display: block;
    width: 220px;
    height: 220px;
    opacity: 0.9;
    flex-shrink: 0;
  }
  .copyright {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 0;
  }
  .copyright a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(42, 30, 23, 0.25);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .copyright a:hover {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  @media (max-width: 767px) {
    .footer-editorial { padding: 60px 20px 32px; }
    .cols-row { flex-direction: column; align-items: center; gap: 32px; padding-bottom: 20px; }
    .cols { flex-direction: column; gap: 32px; }
    .footer-seal { width: 140px; height: 140px; }
  }
</style>
