<style>
  footer {
    padding: 40px 20px 32px;
    background: var(--stripe-brown);
    color: var(--cream);
  }

  .footer-inner {
    max-width: var(--container-page-max);
    margin: 0 auto;
  }

  .footer-columns {
    display: flex;
    gap: 4rem;
    margin-bottom: 2rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-heading {
    color: var(--mustard);
    margin-bottom: 0.5rem;
  }

  .footer-col a,
  .footer-plain {
    font-family: var(--font-body);
    font-size: var(--type-body-sm);
    color: var(--cream);
    text-decoration: none;
    transition: color 200ms;
  }

  .footer-col a:hover {
    color: var(--mustard);
  }

  .footer-bottom {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(232, 228, 208, 0.5);
  }

  .footer-bottom a {
    color: rgba(232, 228, 208, 0.5);
    text-decoration: none;
    transition: color 200ms;
  }

  .footer-bottom a:hover {
    color: var(--cream);
  }

  @media (min-width: 769px) {
    footer {
      padding: 48px 20px 32px;
    }

    .footer-columns,
    .footer-bottom {
      margin-right: clamp(0px, calc(290px - (100vw - 1400px) / 2), 290px);
    }
  }

  @media (max-width: 768px) {
    .footer-columns {
      flex-direction: column;
      gap: 2rem;
      margin-right: 145px;
    }

    .footer-bottom {
      margin-right: 145px;
    }
  }
</style>
