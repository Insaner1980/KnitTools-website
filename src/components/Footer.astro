---
import { getArticleCategoryLinks } from "../i18n/articles";
import { getToolLinks } from "../i18n/tools";
import { useTranslations } from "../i18n/ui";
import type { Lang } from "../i18n/config";
import { CONTACT_EMAIL, CONTACT_MAILTO, FINNVEK_URL } from "../config/brand";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const tools = getToolLinks(lang);
const articles = getArticleCategoryLinks(lang);
---

<footer class="footer-editorial">
  <div class="inner">
    <div class="cols-row">
      <div class="cols">
        <section>
          <h2>{t("tools")}</h2>
          <ul>
            {
              tools.map((t) => (
                <li>
                  <a href={t.href}>{t.label}</a>
                </li>
              ))
            }
          </ul>
        </section>
        <section>
          <h2>{t("articles")}</h2>
          <ul>
            {
              articles.map((a) => (
                <li>
                  <a href={a.href}>{a.label}</a>
                </li>
              ))
            }
          </ul>
        </section>
        <section>
          <h2>{t("app")}</h2>
          <ul>
            <li><span class="muted">{t("launchingSoon")}</span></li>
            <li><a href="/about/">About</a></li>
            <li>
              <a
                href="https://finnvek.com/privacy#knittools"
                target="_blank"
                rel="noopener">{t("privacyPolicy")}</a
              >
            </li>
          </ul>
        </section>
      </div>

      <img
        src="/logo.webp"
        alt="KnitTools"
        class="footer-seal"
        width="220"
        height="220"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © MMXXVI KnitTools. <a href={FINNVEK_URL} target="_blank" rel="noopener"
          >Finnvek</a
        >. <a href={CONTACT_MAILTO}>{CONTACT_EMAIL}</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-editorial {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .cols-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
    padding-bottom: 24px;
  }
  .cols {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
  }
  .cols section {
    min-width: 0;
  }
  h2 {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 16px;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  ul li {
    padding: 6px 0;
    font-family: var(--body-ed);
    font-size: 14px;
  }
  ul li a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  ul li a:hover {
    color: var(--terracotta);
  }
  .muted {
    color: var(--ink-soft);
    font-style: italic;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    padding-top: 20px;
    border-top: 1px solid rgba(42, 30, 23, 0.12);
  }
  .footer-seal {
    display: block;
    width: 220px;
    height: 220px;
    opacity: 0.9;
    flex-shrink: 0;
  }
  .copyright {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 0;
  }
  .copyright a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(42, 30, 23, 0.25);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .copyright a:hover {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  @media (max-width: 767px) {
    .footer-editorial {
      padding: 60px 20px 32px;
    }
    .cols-row {
      flex-direction: column;
      align-items: center;
      gap: 32px;
      padding-bottom: 20px;
    }
    .cols {
      flex-direction: column;
      gap: 32px;
    }
    .footer-seal {
      width: 140px;
      height: 140px;
    }
    .footer-bottom {
      gap: 12px;
    }
    .copyright {
      text-align: center;
    }
  }
</style>
