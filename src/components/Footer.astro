---
const tools = [
  { label: 'Cast On Calculator', href: '/tools/cast-on-calculator' },
  { label: 'Yarn Estimator', href: '/tools/yarn-estimator' },
  { label: 'Needle Size Chart', href: '/tools/needle-size-chart' },
  { label: 'Yarn Weight Chart', href: '/tools/yarn-weight-chart' },
  { label: 'Knitting Abbreviations', href: '/tools/knitting-abbreviations' },
  { label: 'Knitting Size Charts', href: '/tools/knitting-size-charts' },
];

const articles = [
  { label: 'Gauge & Calculations', href: '/articles' },
  { label: 'Yarn', href: '/articles' },
  { label: 'Needles', href: '/articles' },
  { label: 'Techniques', href: '/articles' },
  { label: 'App & Tools', href: '/articles' },
];

const languages = [
  'English',
  'Suomi',
  'Svenska',
  'Dansk',
  'Norsk',
  'Nederlands',
  'Deutsch',
  'Français',
  'Italiano',
  'Português',
  'Español',
];
---

<footer class="footer-editorial">
  <div class="inner">
    <div class="cols">
      <section>
        <h4>Tools</h4>
        <ul>
          {tools.map((t) => <li><a href={t.href}>{t.label}</a></li>)}
        </ul>
      </section>
      <section>
        <h4>Articles</h4>
        <ul>
          {articles.map((a) => <li><a href={a.href}>{a.label}</a></li>)}
        </ul>
      </section>
      <section>
        <h4>App</h4>
        <ul>
          <li><span class="muted">Launching soon</span></li>
          <li><a href="#">Privacy Policy</a></li>
        </ul>
      </section>
    </div>

    <div class="bottom-bar">
      <p class="tagline">
        A quiet companion for the long row ahead. Built for Android, priced once, yours forever.
      </p>
      <p class="langs">{languages.join(' · ')}</p>
    </div>

    <p class="copyright">
      © MMXXVI KnitTools · Finnvek · Vol. 01 · Pre-launch · Made with two needles and a soldering iron
    </p>
  </div>
</footer>

<style>
  .footer-editorial {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    padding-bottom: 48px;
  }
  h4 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 16px;
    font-weight: 400;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  ul li {
    padding: 6px 0;
    font-family: var(--body-ed);
    font-size: 14px;
  }
  ul li a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  ul li a:hover { color: var(--terracotta); }
  .muted { color: var(--ink-soft); font-style: italic; }

  .bottom-bar {
    border-top: 1px solid rgba(42, 30, 23, 0.2);
    padding: 24px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: baseline;
  }
  .tagline {
    font-family: var(--body-ed);
    font-style: italic;
    font-size: 14px;
    color: var(--ink);
    margin: 0;
    max-width: 440px;
  }
  .langs {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--ink-soft);
    margin: 0;
    text-align: right;
  }

  .copyright {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-align: center;
    color: var(--ink-soft);
    margin: 24px 0 0;
    padding-top: 16px;
    border-top: 1px solid rgba(42, 30, 23, 0.1);
  }

  @media (max-width: 767px) {
    .footer-editorial { padding: 60px 20px 32px; }
    .cols { grid-template-columns: 1fr; gap: 32px; padding-bottom: 32px; }
    .bottom-bar { grid-template-columns: 1fr; }
    .langs { text-align: left; }
  }
</style>
