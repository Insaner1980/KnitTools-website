---
import { routes } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/config';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const tools = lang === 'fi'
  ? [
      { label: 'Silmukkalaskuri', href: routes.tool.castOnCalculator.fi },
      { label: 'Lankamuunnin', href: routes.tool.yarnEstimator.fi },
      { label: 'Puikkokoot', href: routes.tool.needleSizeChart.fi },
      { label: 'Lankavahvuudet', href: routes.tool.yarnWeightChart.fi },
      { label: 'Neulelyhenteet', href: routes.tool.knittingAbbreviations.fi },
      { label: 'Neulekokotaulukot', href: routes.tool.knittingSizeCharts.fi },
    ]
  : lang === 'de'
    ? [
        { label: 'Maschenanschlag-Rechner', href: routes.tool.castOnCalculator.de },
        { label: 'Garnbedarfsrechner', href: routes.tool.yarnEstimator.de },
        { label: 'Nadelstärken-Tabelle', href: routes.tool.needleSizeChart.de },
        { label: 'Garnstärken-Tabelle', href: routes.tool.yarnWeightChart.de },
        { label: 'Strickabkürzungen', href: routes.tool.knittingAbbreviations.de },
        { label: 'Größentabellen fürs Stricken', href: routes.tool.knittingSizeCharts.de },
      ]
    : [
      { label: 'Cast On Calculator', href: routes.tool.castOnCalculator.en },
      { label: 'Yarn Estimator', href: routes.tool.yarnEstimator.en },
      { label: 'Needle Size Chart', href: routes.tool.needleSizeChart.en },
      { label: 'Yarn Weight Chart', href: routes.tool.yarnWeightChart.en },
      { label: 'Knitting Abbreviations', href: routes.tool.knittingAbbreviations.en },
      { label: 'Knitting Size Charts', href: routes.tool.knittingSizeCharts.en },
    ];

const articles = lang === 'fi'
  ? [
      { label: 'Neuletiheys ja laskurit', href: routes.category['gauge-calculations'].fi },
      { label: 'Langat', href: routes.category.yarn.fi },
      { label: 'Puikot', href: routes.category.needles.fi },
      { label: 'Tekniikat', href: routes.category.techniques.fi },
      { label: 'Sovellus ja työkalut', href: routes.category['app-tools'].fi },
    ]
  : lang === 'de'
    ? [
        { label: 'Maschenprobe und Rechner', href: routes.category['gauge-calculations'].de },
        { label: 'Garn', href: routes.category.yarn.de },
        { label: 'Nadeln', href: routes.category.needles.de },
        { label: 'Techniken', href: routes.category.techniques.de },
        { label: 'App und Tools', href: routes.category['app-tools'].de },
      ]
  : [
      { label: 'Gauge & Calculations', href: routes.category['gauge-calculations'].en },
      { label: 'Yarn', href: routes.category.yarn.en },
      { label: 'Needles', href: routes.category.needles.en },
      { label: 'Techniques', href: routes.category.techniques.en },
      { label: 'App & Tools', href: routes.category['app-tools'].en },
    ];
---

<footer class="footer-editorial">
  <div class="inner">
    <div class="cols-row">
      <div class="cols">
        <section>
          <h4>{t('tools')}</h4>
          <ul>
            {tools.map((t) => <li><a href={t.href}>{t.label}</a></li>)}
          </ul>
        </section>
        <section>
          <h4>{t('articles')}</h4>
          <ul>
            {articles.map((a) => <li><a href={a.href}>{a.label}</a></li>)}
          </ul>
        </section>
        <section>
          <h4>{t('app')}</h4>
          <ul>
            <li><span class="muted">{t('launchingSoon')}</span></li>
            <li><a href="https://finnvek.com/privacy#knittools" target="_blank" rel="noopener">{t('privacyPolicy')}</a></li>
          </ul>
        </section>
      </div>

      <img
        src="/logo.webp"
        alt="KnitTools sealing logo"
        class="footer-seal"
        width="220"
        height="220"
      />
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © MMXXVI KnitTools. <a href="https://finnvek.com" target="_blank" rel="noopener">Finnvek</a>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-editorial {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .cols-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
    padding-bottom: 24px;
  }
  .cols {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
  }
  .cols section { min-width: 0; }
  h4 {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 16px;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  ul li {
    padding: 6px 0;
    font-family: var(--body-ed);
    font-size: 14px;
  }
  ul li a {
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  ul li a:hover { color: var(--terracotta); }
  .muted { color: var(--ink-soft); font-style: italic; }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid rgba(42, 30, 23, 0.12);
  }
  .footer-seal {
    display: block;
    width: 220px;
    height: 220px;
    opacity: 0.9;
    flex-shrink: 0;
  }
  .copyright {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    margin: 0;
  }
  .copyright a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(42, 30, 23, 0.25);
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .copyright a:hover {
    color: var(--terracotta);
    border-bottom-color: var(--terracotta);
  }

  @media (max-width: 767px) {
    .footer-editorial { padding: 60px 20px 32px; }
    .cols-row { flex-direction: column; align-items: center; gap: 32px; padding-bottom: 20px; }
    .cols { flex-direction: column; gap: 32px; }
    .footer-seal { width: 140px; height: 140px; }
  }
</style>
