const faqs = [
  {
    q: "Er strikkeforkortelser ens i US- og UK-opskrifter?",
    a: 'De fleste er ens. k, p, yo og k2tog betyder det samme på begge sider af Atlanten. Forskellene samler sig om nogle få termer: US "bind off" er UK "cast off", US "gauge" er UK "tension", og US "stockinette" er UK "stocking stitch". På dansk kigger du især efter strikkefasthed og definitionen af maskemønstret. "Seed stitch" og "moss stitch" kan også skifte betydning efter kilde, så stol på maskedefinitionen frem for navnet.',
  },
  {
    q: "Hvad betyder stjernen i en strikkeopskrift?",
    a: 'Den markerer en gentagelse. Alt mellem stjernen og den tilhørende instruktion, ofte "rep from *", strikkes igen og igen hen over pinden. Parenteser og klammer gør det samme: de samler en række handlinger, der gentages et bestemt antal gange. At overse en gentagelsesmarkering er en hurtig vej til forkert maskeantal.',
  },
  {
