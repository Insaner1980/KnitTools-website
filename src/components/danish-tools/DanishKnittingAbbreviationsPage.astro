  },
];
---

<LocalizedToolPage
  title="Strikkeforkortelser: søgbar ordliste"
  description="Slå en strikkeforkortelse eller teknik op. Komplet ordliste med opskriftstermer fra k2tog til psso, ordnet efter kategori."
  canonicalPath={danishToolRoutes.knittingAbbreviations}
  lang="da"
  alternates={danishToolAlternates.tool.knittingAbbreviations}
  intro="Søg en forkortelse for at se, hvad den betyder, eller søg på en teknik for at finde de tilhørende forkortelser."
  schemaName="Strikkeforkortelser"
  schemaDescription="Søgbar ordliste med strikkeforkortelser og tekniske termer."
  faqs={faqs}
  variant="brown"
>
  <div slot="tool">
    <div class="abbr-wrapper">
      <input
        type="text"
        id="abbr-search"
        class="search-input"
        placeholder='Søg forkortelse eller teknik, fx "ssk" eller "indtagning"'
        autocomplete="off"
      />

      <div
        class="category-filters"
        role="group"
        aria-label="Filtrer efter kategori"
      >
        {
          filterOrder.map((cat, index) => (
            <button
              type="button"
              class={`cat-btn${index === 0 ? " is-active" : ""}`}
              data-cat={cat}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {cat === "all" ? "Alle" : categoryLabels[cat as Category]}
            </button>
          ))
        }
      </div>

      <ul class="abbr-list" id="abbr-list" aria-label="Strikkeforkortelser">
        {
          abbreviations.map((item) => (
            <li
              class="abbr-row"
              data-abbr={item.abbr.toLowerCase()}
              data-def={item.def.toLowerCase()}
              data-search={item.search.toLowerCase()}
              data-cats={item.categories.join(" ")}
              data-catlabels={item.categories
                .map((cat) => categoryLabels[cat].toLowerCase())
                .join(" ")}
            >
              <span class="abbr-term">{item.abbr}</span>
              <span class="abbr-def">{item.def}</span>
            </li>
          ))
        }
      </ul>

      <p class="no-results" id="no-results" hidden>
        Ingen passende forkortelser fundet.
      </p>
    </div>
  </div>

  <div slot="content">
    <h2>Forkortelser læst i sammenhæng</h2>
    <p>
      De fleste forkortelser falder i nogle få grupper, og det hjælper mere at
      genkende gruppen end at lære hvert udtryk udenad.
    </p>
    <p>
      <strong>Grundmasker</strong> er enkelte bogstaver. <code>k</code> betyder knit,
      altså strikke ret, og <code>p</code> betyder purl, altså strikke vrang. Et tal
      efter bogstavet fortæller hvor mange: <code>k5</code> betyder strik fem masker
      ret. Det er hele systemet for de enkleste forkortelser.
    </p>
    <p>
      <strong>Kombinerede handlinger</strong> stabler bogstaver og tal. <code
        >k2tog</code
      > betyder to masker ret sammen. <code>p2tog</code> er samme idé, men vrang.
      Mange opskriftsforkortelser fungerer sådan. Læs langsomt og bogstaveligt.
    </p>
    <p>
      <strong>Sidemarkeringer</strong> fortæller, hvilken side af arbejdet du er på.
      <code>RS</code> er retsiden, <code>WS</code> er vrangsiden. Det betyder noget,
      fordi samme håndbevægelse kan give forskelligt resultat afhængigt af, om du
      arbejder på den synlige side eller bagsiden.
    </p>
    <p>
      <strong>Formgivningsforkortelser</strong> styrer, hvordan arbejdet bliver bredere
      eller smallere. <code>M1</code>, <code>M1L</code>, <code>M1R</code> og <code
        >kfb</code
      > lægger masker til. <code>k2tog</code> og <code>ssk</code> fjerner dem. At
      vide hvilke der hælder mod venstre, hvilke der hælder mod højre, og hvilke der
      bare lægger til eller trækker fra, gør opskrifter hurtigere at læse.
    </p>
    <p>
      <strong>Strukturtermer</strong> holder instruktionerne korte. <code
        >rep</code
      >, <code>st(s)</code>, <code>beg</code>, <code>rem</code>, <code
        >cont</code
      >. Det er rammen, ikke maskerne.
    </p>
    <p>
      Tegnsætning tæller også. Stjerner og semikoloner er ikke pynt. <code
        >*k2, p2; rep from *</code
      > betyder, at alt mellem stjernen og semikolonet gentages. Parenteser og klammer
      fungerer på samme måde og samler handlinger, der gentages et bestemt antal gange.
      At overse en gentagelsesmarkering er en af de hurtigste måder at ende med forkert
      maskeantal.
    </p>

    <h2>Forskelle mellem US og UK</h2>
    <p>Nogle få termer flytter sig over Atlanten. De vigtigste:</p>
    <p>
      US "bind off" er UK "cast off". US "gauge" er UK "tension"; på dansk taler
      man normalt om strikkefasthed. US "stockinette" er UK "stocking stitch".
      Og den klassiske fælde: "seed stitch" og "moss stitch" kan skifte
      betydning efter kilde, så en udskrevet maskedefinition vinder altid over
      navnet alene.
    </p>
    <p>
      De fleste almindelige forkortelser, som <code>k</code>, <code>p</code>, <code
        >yo</code
      > og <code>k2tog</code>, er ens i begge systemer. Hvis en opskrift ikke
      siger, om den bruger US- eller UK-konventioner, gør afsnittet med
      maskedefinitioner det som regel klart. Er det afsnit der ikke, er
      designerens placering ofte det bedste spor.
    </p>

    <h2>Opskriftsspecifikke forkortelser</h2>
    <p>
      Her bliver det interessant, for mange forkortelser står ikke i nogen
      standardliste. Det er normalt. De er genveje, designeren har lavet til den
      konkrete opskrift, og de bør forklares nær begyndelsen af instruktionerne.
    </p>
    <p>
      Snoningsmønstre er den største kilde. En diagramnøgle kan definere <code
        >C4F</code
      >, <code>C6B</code> eller noget mere specifikt for designet. Tallet angiver
      typisk, hvor mange masker der krydser. Bogstavet til sidst, F eller B, angiver
      retningen: front eller back, altså hvor du holder snoningspinden, mens du krydser.
      Men designere er ikke altid konsekvente med den konvention. Nogle bruger L og
      R. Nogle tæller alle involverede masker, andre kun dem der flytter sig. Opskriftens
      egen definition er det, der tæller.
    </p>
    <p>
      Hulmønstre bygger også sammensatte forkortelser. En opskrift skriver <code
        >CDD</code
      > for en centreret dobbeltindtagning. En anden skriver samme idé som <code
        >sl2-k1-p2sso</code
      >. En tredje bruger <code>s2kp</code>. Alle tre peger på samme grundidé,
      men den præcise udførelse kan variere mellem designere, og nogle
      forkortelser bruges til lidt forskellige indtagninger afhængigt af kilden.
      Ser en forkortelse ukendt ud, så tjek opskriftsnøglen, før du antager, at
      den svarer til den mest almindelige version.
    </p>
    <p>
      Mønsterstrik forkorter nogle gange farvenavne eller farvetildelinger. Du
      ser MC, main color, og CC, contrast color, eller CC1 og CC2 når der er
      flere kontrastfarver. Nogle designs bruger A, B, C. Forkortelserne er
      enkle, men blander du farverne sammen, kan det ses i det færdige arbejde.
    </p>
    <p>
      Nogle designere laver også forkortelser for gentagne maskesekvenser, som
      kun findes i deres design. En opskrift kan definere "MB" for en bestemt
      knop, eller "cluster" for en bestemt kombination af omslag og
      overtrækninger, der kun gælder i det projekt. Så slipper designeren for at
      skrive en flertrinsinstruktion ud hver gang. De genveje giver kun mening
      inde i den opskrift.
    </p>
    <p>
      Den praktiske regel: finder du ikke en forkortelse i en standardreference,
      står den næsten sikkert i opskriftens begyndelse. Rul op, før du søger
      andre steder.
    </p>

    <h2>Hvad symboler i diagrammer betyder</h2>
    <p>
      Diagrammer bruger symboler i stedet for udskrevne pinde. Hver rude er én
      maske, og symbolet i ruden fortæller, hvad du skal gøre.
    </p>
    <p>
      Der findes ingen universel standard for alle diagramsymboler, men mange
      designere holder sig tæt på Craft Yarn Councils konventioner. En tom rude
      betyder ofte ret på retsiden og vrang på vrangsiden. En streg betyder
      vrang på retsiden. En cirkel er <code>yo</code>. En højrehældende
      skråstreg markerer <code>k2tog</code>, og en venstrehældende markerer <code
        >ssk</code
      >.
    </p>
    <p>
      Diagrammer læses nedefra og op, fordi strik vokser opad. Ved fladstrik
      læses pinde på retsiden fra højre mod venstre og pinde på vrangsiden fra
      venstre mod højre, i samme retning som pindene bevæger sig. Ved rundstrik
      læses hver omgang fra højre mod venstre, fordi du altid arbejder på
      retsiden.
    </p>
    <p>
      Hvis en opskrift har både skrevne instruktioner og diagram, bør de være
      enige. Hvis de ikke er det, og det sker oftere end behageligt, bør
      opskriftsnoterne sige, hvad der har forrang. Står det ikke der, så strik
      én rapport som prøve, før du stoler på den ene eller den anden version.
    </p>

    <h2>Nogle forkortelser der er værd at kende tidligt</h2>
    <p>
      Du behøver ikke lære alt udenad, før du slår masker op. Et første tørklæde
      bruger måske kun <code>k</code> og <code>p</code>. En simpel hue tilføjer
      et par indtagninger. Resten kommer naturligt med de opskrifter, du vælger,
      og de samme tolv forkortelser dækker det meste af det, du strikker.
    </p>
    <p>
      Et par mange snubler over: <code>ssk</code> og <code>skp</code> er begge venstrehældende
      indtagninger. <code>ssk</code> er den moderne standard. <code>skp</code> står
      oftere i ældre opskrifter. Resultatet ligner hinanden, men udførelsen er lidt
      forskellig, så følg opskriften, som den er skrevet, medmindre den giver lov
      til at skifte.
    </p>
    <p>
      En anden, der er værd at markere: <code>psso</code>, pass slipped stitch
      over, optræder både alene og som del af sammensatte forkortelser som <code
        >sl1-k2tog-psso</code
      >. Når du ser den alene, følger den som regel efter en maske, der blev
      taget løst af i forrige trin.
    </p>
    <p>
      Craft Yarn Council udgiver en meget brugt standardliste over forkortelser,
      og de fleste designere følger den for almindelige termer. Derudover tager
      regionale vaner og opskriftsspecifikke genveje over. "Tjek
      opskriftsnøglen" er bedre råd end "lær en komplet liste udenad".
    </p>
    <p>
      Hold en reference åben, mens du strikker. <a href="/">KnitTools-appen</a> har
      en søgbar forkortelsesreference, hurtigere end at skifte mellem faner midt på
      en pind. Hvis du også er ved at finde pindestørrelser eller <a
        href="/da/artikler/maal-strikkefasthed/">måle strikkefasthed</a
      >, passer de referencer godt sammen med ordlisten. Og hvis du er ny til at <a
        href="/da/artikler/laes-strikkeopskrift/">læse strikkeopskrifter</a
      >, er forkortelseslisten i opskriften det første afsnit, du bør skimme,
      før du slår masker op.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const searchInput = document.getElementById(
    "abbr-search",
  ) as HTMLInputElement | null;
  const list = document.getElementById("abbr-list");
  const noResults = document.getElementById("no-results");
  const catButtons = document.querySelectorAll<HTMLButtonElement>(".cat-btn");

  let activeCategory = "all";

  function applyFilters() {
    if (!list || !noResults) return;
    const rows = list.querySelectorAll<HTMLElement>(".abbr-row");
    const query = (searchInput?.value || "").trim().toLowerCase();
    let visibleCount = 0;

    rows.forEach((row) => {
      const cats = (row.dataset.cats || "").split(" ");
      const haystack = [
        row.dataset.abbr,
        row.dataset.def,
        row.dataset.search,
        row.dataset.catlabels,
      ].join(" ");

      const matchesCategory =
        activeCategory === "all" || cats.includes(activeCategory);
      const matchesSearch = !query || haystack.includes(query);
      const visible = matchesCategory && matchesSearch;

      row.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    noResults.hidden = visibleCount > 0;
  }

  searchInput?.addEventListener("input", applyFilters);

  catButtons.forEach((button) => {
    button.addEventListener("click", () => {
      catButtons.forEach((item) => {
        item.classList.remove("is-active");
        item.setAttribute("aria-pressed", "false");
      });

      button.classList.add("is-active");
      button.setAttribute("aria-pressed", "true");
      activeCategory = button.dataset.cat || "all";
      applyFilters();
    });
  });
</script>
