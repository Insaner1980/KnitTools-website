---
import PhoneMockup from './PhoneMockup.astro';
import toolsDark from '../assets/images/tools-dark.png';
import counterLight from '../assets/images/counter-light.png';
---

<section class="feature-organize">
  <div class="feature-inner">
    <div class="feature-row">
      <div class="feature-phones reveal reveal-left reveal-delay-2">
        <div class="phone-left">
          <PhoneMockup screenshot={toolsDark} alt="Project list screen" theme="dark" class="phone-a" />
        </div>
        <div class="phone-right">
          <PhoneMockup screenshot={counterLight} alt="Library screen" theme="light" class="phone-b" />
        </div>
      </div>
      <div class="feature-text reveal reveal-right">
        <span class="section-tag tag-avocado">PROJECTS</span>
        <h2>Your Projects</h2>
        <p>Manage all your knitting projects with linked yarns, notes, progress photos, and session history. Browse Ravelry patterns and save them to your Library. Track your stats in Insights.</p>
        <div class="feature-pills">
          <span class="pill">Project Management</span>
          <span class="pill">Library</span>
          <span class="pill">Yarn Stash</span>
          <span class="pill">Progress Photos</span>
          <span class="pill">Ravelry</span>
          <span class="pill">Insights</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-organize {
    position: relative;
    z-index: 1;
    padding: 120px 20px;
  }

  /* Diagonal background — from right, terracotta */
  .feature-organize::before {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 45%;
    left: 0;
    right: 275px;
    background-color: var(--stripe-terracotta);
    clip-path: polygon(62% 0%, 100% 0%, 100% 100%, 55% 100%);
    z-index: 0;
  }

  .feature-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .feature-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .tag-avocado { color: var(--avocado); }

  .feature-text {
    position: relative;
    z-index: 2;
  }

  .feature-text h2 {
    color: var(--text-on-light);
    margin-bottom: 1.5rem;
  }

  .feature-text p {
    color: var(--text-on-light-muted);
    max-width: 480px;
    line-height: 1.7;
  }

  .feature-pills {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .pill {
    display: inline-block;
    padding: 6px 16px;
    background: var(--cream-muted);
    border-radius: 9999px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.8rem;
    color: var(--text-on-light-muted);
  }

  .feature-phones {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .phone-left {
    z-index: 2;
    position: relative;
  }

  .phone-right {
    transform: translateY(-16px);
    z-index: 1;
    position: relative;
  }

  .phone-left :global(.phone-a) { width: 270px; }
  .phone-right :global(.phone-b) { width: 270px; }

  @media (min-width: 769px) {
    .feature-organize { padding: 140px 0 140px 20px; }

    .feature-row {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }

    .feature-phones {
      flex: 1;
      order: 1;
    }

    .feature-text { flex: 1.3; }

    .phone-left :global(.phone-a) { width: 280px; }
    .phone-right :global(.phone-b) { width: 280px; }
  }

  @media (max-width: 768px) {
    .feature-organize { padding: 80px 20px; }

    .feature-organize::before {
      height: 40%;
      right: 135px;
      clip-path: polygon(0% 5%, 100% 0%, 100% 100%, 0% 95%);
    }

    .feature-text { text-align: center; }
    .feature-pills { justify-content: center; }
    .feature-text p { margin: 0 auto; }

    .phone-left :global(.phone-a) { width: 200px; }
    .phone-right :global(.phone-b) { width: 200px; }
  }
</style>
