      'baby-sweater': { 'Preemie': 125, 'Newborn': 150, '3M': 175, '6M': 200, '12M': 250, '18M': 300, '24M': 350 },
      'baby-cardigan': { 'Preemie': 150, 'Newborn': 175, '3M': 200, '6M': 250, '12M': 300, '18M': 350, '24M': 400 },
      'baby-booties': { 'Preemie': 25, 'Newborn': 30, '3-6M': 40, '6-12M': 50, '12-24M': 60 },
      'adult-hat': { 'S': 100, 'M': 125, 'L': 150 },
      'child-hat': { 'Toddler': 60, 'Child': 80, 'Teen': 100 },
      'baby-hat': { 'Preemie': 25, 'Newborn': 35, '3-6M': 45, '6-12M': 55, '12-24M': 65 },
      'headband': { 'Child': 30, 'Adult': 50 },
      'adult-mittens': { 'S': 100, 'M': 125, 'L': 150 },
      'child-mittens': { 'Toddler': 45, 'Child': 65, 'Teen': 85 },
      'adult-gloves': { 'S': 150, 'M': 175, 'L': 200 },
      'fingerless-mitts': { 'S': 75, 'M': 90, 'L': 110 },
      'adult-socks': { 'S (EU 36-38)': 175, 'M (EU 39-41)': 200, 'L (EU 42-44)': 225, 'XL (EU 45-47)': 250 },
      'child-socks': { 'Toddler': 75, 'Child': 100, 'Teen': 140 },
      'slippers': { 'S': 100, 'M': 125, 'L': 150 },
      'scarf': { 'Short (120cm)': 200, 'Medium (150cm)': 275, 'Long (180cm)': 350, 'Extra Long (200cm+)': 425 },
      'cowl': { 'Short': 125, 'Tall': 200 },
      'shawl': { 'Small': 350, 'Medium': 550, 'Large': 750 },
      'wrap': { 'Small': 500, 'Medium': 700, 'Large': 900 },
      'baby-blanket': { 'Small (60×75cm)': 550, 'Standard (75×100cm)': 750, 'Large (100×100cm)': 950 },
      'throw-blanket': { 'Small (100×125cm)': 1200, 'Standard (125×150cm)': 1600, 'Large (150×175cm)': 2100 },
      'lap-blanket': { 'One Size (90×120cm)': 1000 },
      'afghan': { 'Twin (170×225cm)': 2750, 'Full (195×225cm)': 3200, 'Queen (230×250cm)': 4000, 'King (270×250cm)': 4800 },
      'dishcloth': { 'One Size': 60 },
      'pillow-cover': { 'Small (30×30cm)': 150, 'Medium (40×40cm)': 250, 'Large (50×50cm)': 375 },
    };

    const MULTIPLIERS: Record<string, number> = {
      'lace': 1.5, 'fingering': 1.35, 'sport': 1.2, 'dk': 1.1,
      'worsted': 1.0, 'aran': 0.95, 'bulky': 0.8, 'super-bulky': 0.6, 'jumbo': 0.45,
    };

    document.querySelectorAll('.yarn-estimator').forEach(est => {
      const projectSelect = est.querySelector('#project-type') as HTMLSelectElement;
      const sizeSelect = est.querySelector('#project-size') as HTMLSelectElement;
      const weightSelect = est.querySelector('#yarn-weight') as HTMLSelectElement;
      const estimateBtn = est.querySelector('.estimate-btn') as HTMLButtonElement;
      const resultEl = est.querySelector('#yarn-result') as HTMLElement;
      const resultArea = est.querySelector('.result-area') as HTMLElement;
      if (!projectSelect || !sizeSelect || !weightSelect || !estimateBtn || !resultEl || !resultArea) return;
      const sizeLabels = JSON.parse(est.getAttribute('data-size-labels') || '{}') as Record<string, string>;

      const id = Math.random().toString(36).slice(2, 8);
      projectSelect.id = `project-type-${id}`;
      (projectSelect.previousElementSibling as HTMLElement).setAttribute('for', projectSelect.id);
      sizeSelect.id = `project-size-${id}`;
      (sizeSelect.previousElementSibling as HTMLElement).setAttribute('for', sizeSelect.id);
      weightSelect.id = `yarn-weight-${id}`;
      (weightSelect.previousElementSibling as HTMLElement).setAttribute('for', weightSelect.id);
      resultEl.id = `yarn-result-${id}`;

      function updateSizes() {
        const project = PROJECTS[projectSelect.value];
        if (!project) return;
        const sizes = Object.keys(project);
        sizeSelect.textContent = '';
        sizes.forEach(size => {
          const option = document.createElement('option');
          option.value = size;
          option.textContent = sizeLabels[size] || size;
          sizeSelect.appendChild(option);
        });
      }
      updateSizes();
      projectSelect.addEventListener('change', updateSizes);

      estimateBtn.addEventListener('click', () => {
        const project = PROJECTS[projectSelect.value];
        const size = sizeSelect.value;
        const yarnWeight = weightSelect.value;
        resultEl.textContent = '';
        resultEl.className = 'result-value';

        if (!project || !project[size] || !MULTIPLIERS[yarnWeight]) {
          const errorSpan = document.createElement('span');
          errorSpan.className = 'form-error';
          errorSpan.setAttribute('role', 'alert');
          errorSpan.textContent = est.getAttribute('data-error') || '';
          resultEl.appendChild(errorSpan);
          resultArea.classList.add('is-open');
          return;
        }

        const baseMeters = project[size];
        const multiplier = MULTIPLIERS[yarnWeight];
        const meters = Math.round(baseMeters * multiplier);
        const yards = Math.round(meters * 1.094);

        const wrapper = document.createElement('div');
        wrapper.className = 'tool-result';
        const numberEl = document.createElement('span');
        numberEl.className = 'result-number';
        numberEl.textContent = '0';
        const labelEl = document.createElement('span');
        labelEl.className = 'result-label';
        const metersLabel = est.getAttribute('data-meters-label') || '';
        const yardsLabel = est.getAttribute('data-yards-label') || '';
        const showSecondaryYards = est.getAttribute('data-show-secondary-yards') === 'true';
        labelEl.textContent = showSecondaryYards ? `${metersLabel} (~${yards} ${yardsLabel})` : metersLabel;
        wrapper.appendChild(numberEl);
        wrapper.appendChild(labelEl);

        const disclaimer = document.createElement('div');
        disclaimer.className = 'result-disclaimer';
        disclaimer.textContent = est.getAttribute('data-disclaimer') || '';
        wrapper.appendChild(disclaimer);

        resultEl.appendChild(wrapper);
        resultArea.classList.add('is-open');

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) {
          numberEl.textContent = String(meters);
        } else {
          const duration = 800;
          const start = performance.now();
          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            numberEl.textContent = String(Math.round(eased * meters));
            if (progress < 1) requestAnimationFrame(animate);
          };
          requestAnimationFrame(animate);
        }
      });
    });
  }
  initYarnEstimator();
</script>

<style>
