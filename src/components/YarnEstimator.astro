      'sweater': { 'XS': 1000, 'S': 1100, 'M': 1200, 'L': 1350, 'XL': 1500, '2XL': 1650, '3XL': 1800, '4XL': 1950, '5XL': 2100 },
      'cardigan': { 'XS': 1100, 'S': 1250, 'M': 1400, 'L': 1550, 'XL': 1700, '2XL': 1850, '3XL': 2050, '4XL': 2200, '5XL': 2400 },
      'vest': { 'XS': 550, 'S': 625, 'M': 700, 'L': 800, 'XL': 900, '2XL': 1000, '3XL': 1100 },
      'poncho': { 'S/M': 900, 'L/XL': 1100, '2XL+': 1300 },
