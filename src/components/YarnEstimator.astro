    background-color: #F2ECDC;
  }

  :global(.yarn-estimator select option) {
    font-weight: 400;
    color: #2A1E17;
    background-color: #F2ECDC;
  }

  /* Estimate button — landing hero style (matches cast-on calc-btn) */
  .estimate-btn {
    display: inline-block;
    margin-top: 28px;
    padding: 14px 26px;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 0;
    font-family: var(--mono);
    font-size: 12px;
