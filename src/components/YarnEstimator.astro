<div
  class="yarn-estimator"
  data-error={copy.error}
  data-meters-label={copy.metersLabel}
  data-yards-label={copy.yardsLabel}
  data-show-secondary-yards={showSecondaryYards ? 'true' : 'false'}
  data-size-labels={JSON.stringify(sizeLabelsByLang[lang] ?? {})}
  data-disclaimer={copy.disclaimer}
>
  <fieldset>
    <legend class="sr-only">{copy.legend}</legend>

    <div class="form-group">
      <label for="project-type">{copy.projectType}</label>
      <select id="project-type">
        <optgroup label={copy.adultGarments}>
          <option value="sweater">{copy.options.sweater}</option>
          <option value="cardigan">{copy.options.cardigan}</option>
          <option value="vest">{copy.options.vest}</option>
          <option value="poncho">Poncho</option>
        </optgroup>
        <optgroup label={copy.childGarments}>
          <option value="child-sweater">{copy.options.childSweater}</option>
          <option value="child-cardigan">{copy.options.childCardigan}</option>
        </optgroup>
        <optgroup label={copy.babyGarments}>
          <option value="baby-sweater">{copy.options.babySweater}</option>
          <option value="baby-cardigan">{copy.options.babyCardigan}</option>
          <option value="baby-booties">{copy.options.babyBooties}</option>
        </optgroup>
        <optgroup label={copy.hats}>
          <option value="adult-hat">{copy.options.adultHat}</option>
          <option value="child-hat">{copy.options.childHat}</option>
          <option value="baby-hat">{copy.options.babyHat}</option>
          <option value="headband">{copy.options.headband}</option>
        </optgroup>
        <optgroup label={copy.hands}>
          <option value="adult-mittens">{copy.options.adultMittens}</option>
          <option value="child-mittens">{copy.options.childMittens}</option>
          <option value="adult-gloves">{copy.options.adultGloves}</option>
          <option value="fingerless-mitts">{copy.options.fingerlessMitts}</option>
        </optgroup>
        <optgroup label={copy.feet}>
          <option value="adult-socks">{copy.options.adultSocks}</option>
          <option value="child-socks">{copy.options.childSocks}</option>
          <option value="slippers">{copy.options.slippers}</option>
        </optgroup>
        <optgroup label={copy.neck}>
          <option value="scarf">{copy.options.scarf}</option>
          <option value="cowl">{copy.options.cowl}</option>
          <option value="shawl">{copy.options.shawl}</option>
          <option value="wrap">{copy.options.wrap}</option>
        </optgroup>
        <optgroup label={copy.blankets}>
          <option value="baby-blanket">{copy.options.babyBlanket}</option>
          <option value="throw-blanket">{copy.options.throwBlanket}</option>
          <option value="lap-blanket">{copy.options.lapBlanket}</option>
          <option value="afghan">{copy.options.afghan}</option>
        </optgroup>
        <optgroup label={copy.home}>
          <option value="dishcloth">{copy.options.dishcloth}</option>
          <option value="pillow-cover">{copy.options.pillowCover}</option>
        </optgroup>
      </select>
    </div>

    <div class="form-group">
      <label for="project-size">{copy.size}</label>
      <select id="project-size">
        <option value="M">M</option>
      </select>
    </div>

    <div class="form-group">
      <label for="yarn-weight">{copy.yarnWeight}</label>
      <select id="yarn-weight">
        <option value="lace">{yarnWeightLabels.lace}</option>
        <option value="fingering">{yarnWeightLabels.fingering}</option>
        <option value="sport">{yarnWeightLabels.sport}</option>
        <option value="dk">{yarnWeightLabels.dk}</option>
        <option value="worsted" selected>{yarnWeightLabels.worsted}</option>
        <option value="aran">{yarnWeightLabels.aran}</option>
        <option value="bulky">{yarnWeightLabels.bulky}</option>
        <option value="super-bulky">{yarnWeightLabels.superBulky}</option>
        <option value="jumbo">{yarnWeightLabels.jumbo}</option>
      </select>
    </div>

    <button type="button" class="btn-primary estimate-btn">{copy.estimate}</button>

    <div class="result-area" aria-live="polite">
      <div class="result-wrapper">
        <div class="result-value" id="yarn-result"></div>
      </div>
    </div>
  </fieldset>
</div>

<script>
  function initYarnEstimator() {
