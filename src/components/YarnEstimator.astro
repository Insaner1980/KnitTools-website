  }

  /* Result Area — grid-expanding like cast-on calculator */
  .result-area {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 500ms cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 16px;
  }

  .result-area.is-open {
    grid-template-rows: 1fr;
  }

  .result-wrapper {
    overflow: hidden;
  }

  :global(.tool-result) {
    background: none;
    border: none;
    padding: 16px 0;
    text-align: left;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 400ms ease 200ms, transform 400ms cubic-bezier(0.16, 1, 0.3, 1) 200ms;
  }

  .result-area.is-open :global(.tool-result) {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.result-number) {
    display: block;
    font-family: var(--mono);
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: var(--terracotta);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  :global(.result-label) {
    display: block;
    font-family: var(--body-ed);
