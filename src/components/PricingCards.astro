---
const freeBullets = [
  'Row counter + session history',
  'Ravelry sign-in',
  'Four calculators (gauge, cast-on, increase, yardage)',
  'Reference library (needles, sizes, abbreviations)',
  'Three projects',
  'Eleven languages',
];

const proBullets = [
  'Unlimited projects',
  'Voice commands (EN · FI)',
  'Live AI assistant',
  'Pattern viewer with AI stitch explanations',
  'Yarn OCR scanner · unlimited stash',
  'Insights, streaks, pace-over-time',
  'Progress photos, row-tagged',
  'Home-screen counter widget',
];
---

<section class="pricing-section" aria-label="Pricing">
  <div class="inner">
    <article class="card free">
      <p class="label">Free</p>
      <h3>Forever</h3>
      <ul>
        {freeBullets.map((b) => <li>{b}</li>)}
      </ul>
      <p class="footnote">No account. No trial expiry. No card.</p>
    </article>

    <article class="card pro">
      <p class="label">Pro</p>
      <h3>€8.99 <span class="suffix">one-time</span></h3>
      <ul>
        {proBullets.map((b) => <li>{b}</li>)}
      </ul>
      <p class="footnote">
        14-day free trial. No credit card. Rises to €11.99 two months after launch — permanently. No subscription,
        ever.
      </p>
    </article>
  </div>
</section>

<style>
  .pricing-section {
    background: var(--paper);
    padding: 120px 40px;
  }
  .inner {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .card {
    border: 1px solid var(--ink);
    padding: 40px;
  }
  .card.free {
    background: var(--paper-2);
    color: var(--ink);
  }
  .card.pro {
    background: var(--terracotta);
    color: var(--paper);
    border-color: var(--terracotta);
  }
  .label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .free .label { color: var(--terracotta); }
  .pro .label { color: var(--wheat); }

  h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0 0 24px;
  }
  .suffix {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-left: 8px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
  }
  ul li {
    padding: 12px 0;
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.5;
    border-top: 1px solid rgba(42, 30, 23, 0.2);
  }
  .pro ul li { border-top-color: rgba(244, 234, 217, 0.2); }
  ul li:last-child { border-bottom: 1px solid rgba(42, 30, 23, 0.2); }
  .pro ul li:last-child { border-bottom-color: rgba(244, 234, 217, 0.2); }

  .footnote {
    font-family: var(--body-ed);
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
  }
  .free .footnote { color: var(--ink-soft); }
  .pro .footnote { color: rgba(244, 234, 217, 0.75); }

  @media (max-width: 767px) {
    .pricing-section { padding: 80px 20px; }
    .inner { grid-template-columns: 1fr; }
    .card.pro { order: -1; }
    .card { padding: 32px; }
  }
</style>
