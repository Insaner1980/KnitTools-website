---
import { PRICING } from "../config/pricing";
import RegionalPrice from "./RegionalPrice.astro";
import RegionalPricingNote from "./RegionalPricingNote.astro";

const freeBullets = [
  "Saved row counter",
  "Pattern viewer (PDF or Ravelry)",
  "Four calculators (gauge, cast-on, increases, yardage)",
  "Ravelry sign-in",
  "Reference library (needles, sizes, symbols, abbreviations)",
  "One project",
  "Eleven languages",
];

const proBullets = [
  "Unlimited projects",
  "Progress photos, row-tagged",
  "Project stats, streaks, pace-over-time",
  "Home-screen counter widget",
];
---

<section class="pricing-section" aria-labelledby="pricing-heading">
  <div class="inner">
    <header class="section-head">
      <p class="section-label">
        <span class="label-text">Pricing</span>
      </p>
      <h2 id="pricing-heading" class="title">
        Pay once.<br /><em>Own it.</em>
      </h2>
    </header>

    <div class="plans">
      <article class="card free">
        <p class="label">Free</p>
        <h3>$0 <span class="suffix">forever</span></h3>
        <ol>
          {
            freeBullets.map((b) => (
              <li>
                <span class="t">{b}</span>
              </li>
            ))
          }
        </ol>
        <p class="footnote">No account. No trial expiry. No card.</p>
      </article>

      <article class="card pro">
        <span class="badge">Recommended</span>
        <p class="label">Pro</p>
        <h3>
          <RegionalPrice phase="launch" />
          <span class="suffix">one-time</span>
        </h3>
        <p class="trial">
          {PRICING.trialDays}-day free trial. No credit card required.
        </p>
        <p class="includes">Everything in Free, plus:</p>
        <ol>
          {
            proBullets.map((b) => (
              <li>
                <span class="t">{b}</span>
              </li>
            ))
          }
        </ol>
        <p class="footnote">
          Launch price <RegionalPrice phase="launch" />. Regular price <RegionalPrice
            phase="permanent"
          /> later. No subscription, ever. <RegionalPricingNote />
        </p>
      </article>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    padding: 120px 40px;
    border-top: 1px solid var(--ink);
  }
  .inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .section-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 48px;
  }
  .section-head .section-label {
    display: inline-flex;
    align-items: baseline;
    gap: 20px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 10px;
  }
  .section-head .title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: var(--landing-section-title-size);
    line-height: var(--landing-section-title-line-height);
    letter-spacing: 0;
    margin: 0;
    color: var(--ink);
  }
  .section-head .title em {
    color: var(--terracotta);
    font-style: italic;
    font-size: 1.3em;
    line-height: 1;
    display: inline-block;
    margin-top: 6px;
  }

  .plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .card {
    border: 1px solid var(--ink);
    padding: 40px;
    position: relative;
  }
  .card.free {
    background: var(--wheat);
    color: var(--ink);
    border-color: var(--ink);
  }
  .card.pro {
    background: var(--sage);
    color: var(--paper);
    border: 2px solid var(--paper);
  }

  .badge {
    position: absolute;
    top: -14px;
    right: 24px;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 14px 6px;
    border: 1px solid var(--ink);
    white-space: nowrap;
    z-index: 2;
  }

  .label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .free .label {
    color: var(--walnut);
  }
  .pro .label {
    color: var(--paper);
  }

  .includes {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper);
    margin: -8px 0 16px;
  }

  .pro .trial {
    font-family: var(--body-ed);
    font-style: italic;
    font-size: 14px;
    color: var(--paper);
    margin: 4px 0 24px;
  }

  h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1;
    letter-spacing: 0;
    margin: 0 0 24px;
  }
  .suffix {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-left: 8px;
  }

  ol {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
  }
  ol li {
    padding: 12px 0;
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.5;
    border-top: 1px solid rgb(from var(--ink) r g b / 0.2);
  }
  .pro ol li {
    border-top-color: rgb(from var(--paper) r g b / 0.25);
  }
  ol li:last-child {
    border-bottom: 1px solid rgb(from var(--ink) r g b / 0.2);
  }
  .pro ol li:last-child {
    border-bottom-color: rgb(from var(--paper) r g b / 0.25);
  }

  .footnote {
    font-family: var(--body-ed);
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
  }
  .free .footnote {
    color: var(--ink-soft);
  }
  .pro .footnote {
    color: rgb(from var(--paper) r g b / 0.85);
  }

  @media (max-width: 767px) {
    .pricing-section {
      padding: 80px 20px;
    }
    .section-head .section-label {
      gap: 12px;
    }
    .plans {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .card.pro {
      order: -1;
    }
    .card {
      padding: 32px;
    }
    .badge {
      right: 20px;
    }
  }
</style>
