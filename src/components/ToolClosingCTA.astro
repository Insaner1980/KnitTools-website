<section class="tool-closing dot-grid-dark">
  <div class="tool-closing-content">
    <h1 class="tool-closing-heading">Get the full toolkit</h1>
    <a href="#" class="btn-primary">GET THE APP</a>
    <div class="tool-closing-meta">
      <span>ANDROID</span>
      <span>LAUNCH PRICE &euro;4.99</span>
      <span>NO ADS</span>
      <span>NO TRACKING</span>
    </div>
  </div>
</section>

<style>
  .tool-closing {
    background-color: var(--dark);
    padding: 6rem 20px;
  }

  .tool-closing-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .tool-closing-heading {
    color: var(--cream);
    margin: 0;
  }

  .tool-closing-meta {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 2rem;
    font-family: var(--font-body);
    font-size: var(--bebas-ui-size);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-on-dark-muted);
  }

  @media (min-width: 769px) {
    .tool-closing {
      padding: 8rem 48px;
    }
  }
</style>
