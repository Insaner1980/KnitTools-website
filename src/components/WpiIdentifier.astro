---

<div class="wpi-tool gs-form" data-wpi-tool>
  <h2 class="wpi-heading">{copy.heading}</h2>
  <p class="wpi-intro">{copy.intro}</p>
  <div class="wpi-input-wrap">
    <input
      type="number"
      class="wpi-input"
      aria-label={copy.prompt}
      placeholder={copy.placeholder}
      min="1"
      max="40"
      step="1"
      inputmode="numeric"
      autocomplete="off"
      data-wpi-input
    />
  </div>
  <p class="wpi-result" aria-live="polite" data-wpi-result>{copy.prompt}</p>
  <noscript>
    <p class="wpi-fallback">{copy.fallback}</p>
  </noscript>
</div>

<script
  is:inline
  define:vars={{
    wpiCategories: categories,
    wpiCopy: copy,
  }}
>
  (() => {
    const tool = document.currentScript?.previousElementSibling;
    if (!tool || !tool.matches("[data-wpi-tool]")) return;

    const input = tool.querySelector("[data-wpi-input]");
    const result = tool.querySelector("[data-wpi-result]");
    if (!input || !result) return;

    const joinParts = (parts) => {
      if (parts.length === 1) return parts[0];
      if (parts.length === 2) return `${parts[0]} ${wpiCopy.or} ${parts[1]}`;
      return `${parts.slice(0, -1).join(", ")} ${wpiCopy.or} ${parts[parts.length - 1]}`;
    };

    const formatMatches = (matches) => {
      if (matches.length === 1) {
        const match = matches[0];
        return `${wpiCopy.suggests} ${match.name} (CYC ${match.cyc}), ${match.regional}`;
      }

      const parts = matches.map((match) => `${match.name} (CYC ${match.cyc})`);
      return `${wpiCopy.matches} ${joinParts(parts)}. ${wpiCopy.swatch}`;
    };

    input.addEventListener("input", () => {
      const raw = input.value.trim();
      if (raw === "") {
        result.textContent = wpiCopy.prompt;
        return;
      }

      const value = Number(raw);
      if (!Number.isFinite(value) || value < 1 || value > 40) {
        result.textContent = wpiCopy.invalid;
        return;
      }

      const matches = wpiCategories.filter(
        (category) => value >= category.min && value <= category.max,
      );
      result.textContent =
        matches.length === 0
          ? `${value} WPI ${wpiCopy.between}`
          : `${value} WPI ${formatMatches(matches)}`;
    });
  })();
</script>

<style>
  .wpi-tool {
    margin-top: 8px;
    padding-top: 32px;
    border-top: 1px solid rgba(244, 234, 217, 0.2);
  }

  .wpi-heading {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 10px;
    text-transform: none;
  }

  .wpi-intro {
    font-family: var(--body-ed);
    font-weight: 400;
    font-size: 16px;
    color: var(--ink);
    line-height: 1.55;
    margin: 0 0 18px;
    max-width: 560px;
  }

  .wpi-input-wrap {
    max-width: 220px;
  }

  .wpi-input {
    width: 100%;
    height: 52px;
    padding: 0 18px;
    font-size: 16px;
    font-family: var(--body-ed);
    background-color: var(--paper-2);
    border: 1.5px solid var(--ink);
    color: var(--ink);
    outline: none;
    border-radius: 0;
    box-sizing: border-box;
    transition:
      border-color 300ms ease,
      box-shadow 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .wpi-input::placeholder {
    color: var(--ink-soft);
  }

  .wpi-input:focus {
    border-color: var(--terracotta);
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  .wpi-input::-webkit-outer-spin-button,
  .wpi-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .wpi-input[type="number"] {
    -moz-appearance: textfield;
  }

  .wpi-result {
    font-family: var(--body-ed);
    font-style: italic;
    font-weight: 400;
    font-size: 16px;
    color: var(--ink);
    margin: 16px 0 0;
    line-height: 1.5;
    min-height: 1.5em;
  }

  .wpi-fallback {
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--terracotta);
    margin: 12px 0 0;
  }
</style>
