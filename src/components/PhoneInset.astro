---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['phone-inset', className]}>
  <slot />
</div>

<style>
  .phone-inset {
    background: var(--dark);
    border-radius: 28px;
    padding: 40px 32px 0;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 16px;
  }

  @media (max-width: 768px) {
    .phone-inset {
      width: 100%;
      padding: 28px 20px 0;
      border-radius: 24px;
    }
  }
</style>
