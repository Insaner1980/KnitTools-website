---
---

<section class="feature-reference">
  <div class="feature-inner reveal">
    <span class="section-tag">REFERENCE</span>
    <h2>Reference</h2>
    <div class="card-grid">
      <div class="ref-card">
        <h3 class="card-title accent">NEEDLE SIZES</h3>
        <p class="card-sub">Metric · US · UK · JP</p>
      </div>
      <div class="ref-card">
        <h3 class="card-title avocado">SIZE CHARTS</h3>
        <p class="card-sub">6 categories</p>
      </div>
      <div class="ref-card">
        <h3 class="card-title mustard">ABBREVIATIONS</h3>
        <p class="card-sub">76 terms</p>
      </div>
      <div class="ref-card">
        <h3 class="card-title rose">CHART SYMBOLS</h3>
        <p class="card-sub">Categorized symbols</p>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-reference {
    position: relative;
    z-index: 1;
    padding: 80px 20px;
  }

  .feature-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .feature-reference h2 {
    color: var(--text-on-light);
    margin-bottom: 3rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .ref-card {
    background: var(--dark);
    border-radius: 20px;
    padding: 36px 24px;
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .card-title {
    font-family: var(--font-label);
    font-size: var(--bebas-ui-size);
    font-weight: 400;
    letter-spacing: var(--bebas-ui-tracking);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .card-title.accent { color: var(--accent); }
  .card-title.avocado { color: var(--avocado); }
  .card-title.mustard { color: var(--mustard); }
  .card-title.rose { color: var(--dusty-rose); }

  .card-sub {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--text-on-dark-muted);
  }

  @media (min-width: 769px) {
    .feature-reference {
      padding: 120px 48px;
    }
    .feature-inner {
      padding-right: var(--safe-pr-desktop);
    }
  }

  @media (max-width: 768px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
