---
const items = [
  'Projects',
  'Row counter',
  'AI pattern help',
  'Pattern viewer',
  'Voice counter',
  'Yarn scanner',
  'AI journaling',
  'Live voice chat',
  'Ravelry',
  'Progress photos',
  'Row reminders',
  'Home screen widget',
  'Four calculators',
  'Reference library',
  'No tracking',
  'One-time price',
];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {[...items, ...items].map((item) => (
      <>
        <span class="marquee-item">{item}</span>
        <span class="marquee-sep"></span>
      </>
    ))}
  </div>
</div>

<style>
  .marquee {
    position: relative;
    z-index: 0;
    background: var(--accent);
    padding: 18px 0;
    overflow: hidden;
    width: 100%;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: marquee 60s linear infinite;
    width: max-content;
  }

  .marquee-item {
    font-family: var(--font-label);
    font-size: clamp(1rem, 1.75vw, 1.4rem);
    font-weight: 400;
    color: var(--cream);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1.2;
  }

  .marquee-sep {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--cream);
    border-radius: 9999px;
    margin: 0 2.5rem;
    opacity: 0.55;
    flex-shrink: 0;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
