---
const tools = [
  { href: '/tools/cast-on-calculator', label: 'Cast On', fill: 'terracotta' },
  { href: '/tools/yarn-estimator', label: 'Yarn Estimator', fill: 'amber' },
  { href: '/tools/yarn-weight-chart', label: 'Yarn Weights', fill: 'wheat' },
  { href: '/tools/needle-size-chart', label: 'Needle Sizes', fill: 'sage' },
  { href: '/tools/knitting-size-charts', label: 'Size Charts', fill: 'walnut' },
  { href: '/tools/knitting-abbreviations', label: 'Abbreviations', fill: 'ink' },
];
---

<section class="free-tools-callout" aria-labelledby="free-tools-heading">
  <div class="inner">
    <p class="eyebrow">Free tools</p>
    <h2 id="free-tools-heading">Use them right here, no install.</h2>

    <ul class="pills">
      {
        tools.map((t) => (
          <li>
            <a class:list={['pill', `fill-${t.fill}`]} href={t.href}>
              {t.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a class="see-all" href="/tools/">See all tools →</a>
  </div>
</section>

<style>
  .free-tools-callout {
    background: var(--paper);
    padding: 120px 40px;
  }
  .inner {
    max-width: 1120px;
    margin: 0 auto;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 18px;
  }
  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 40px;
    color: var(--ink);
  }
  h2 em { color: var(--terracotta); font-style: italic; }

  .pills {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding: 0;
    margin: 0 0 24px;
  }
  .pill {
    display: inline-block;
    padding: 9px 16px;
    border-radius: 0;
    border: 1.5px solid #2A1E17;
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F4EAD9;
    text-decoration: none;
    transition: filter 0.15s ease;
  }
  .pill:hover { filter: brightness(0.88); }
  .fill-terracotta { background: #A05038; }
  .fill-amber { background: var(--amber); }
  .fill-wheat { background: var(--wheat); color: #2A1E17; }
  .fill-sage { background: var(--sage); }
  .fill-walnut { background: var(--walnut); }
  .fill-ink { background: #F4EAD9; color: #2A1E17; }

  .see-all {
    display: inline-block;
    font-family: var(--body-ed);
    font-style: italic;
    font-size: 15px;
    color: var(--ink-soft);
    text-decoration: none;
    margin-top: 8px;
  }
  .see-all:hover { color: var(--terracotta); }

  @media (max-width: 640px) {
    .free-tools-callout { padding: 80px 20px; }
    .pill { padding: 8px 16px; font-size: 11px; }
  }
</style>
