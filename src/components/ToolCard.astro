---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="tool-card">
  <h3>{title}</h3>
  <slot />
  <p class="tool-nudge">
    For a more precise estimate, try <a href="#"
      ><strong>KnitTools for Android</strong></a
    >
  </p>
</div>

<style>
  .tool-card {
    background: white;
    border: 1px solid var(--cream-muted);
    border-radius: 12px;
    padding: 32px 24px;
  }

  .tool-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--text-on-light);
    text-align: left;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--cream-muted);
  }

  .tool-nudge {
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--cream-muted);
    font-size: 0.85rem;
    color: var(--text-on-light-muted);
  }

  .tool-nudge a {
    color: var(--accent);
  }
</style>
