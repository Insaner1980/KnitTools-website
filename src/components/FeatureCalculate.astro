---
import PhoneMockup from './PhoneMockup.astro';
import counterLight from '../assets/images/counter-light.png';
---

<section class="feature-calculate">
  <div class="feature-inner">
    <div class="feature-row">
      <div class="feature-phones reveal reveal-left reveal-delay-2">
        <div class="phone-main">
          <PhoneMockup screenshot={counterLight} alt="Cast On Calculator" theme="light" class="phone-lg" />
        </div>
      </div>
      <div class="feature-text reveal reveal-right">
        <span class="section-tag tag-mustard">CALCULATORS</span>
        <h2>Four calculators<br>for every<br><span class="accent-italic">knitting math</span></h2>
        <div class="sub-features">
          <div class="sub-feature">
            <h3 class="sub-title">Gauge Perfection</h3>
            <p>Convert between gauge measurements and resize patterns to your exact tension.</p>
          </div>
          <div class="sub-feature">
            <h3 class="sub-title">Inc/Dec Spacing</h3>
            <p>Calculate evenly spaced increases and decreases for shaping.</p>
          </div>
          <div class="sub-feature">
            <h3 class="sub-title">Cast-On Master</h3>
            <p>Find the right cast-on count for any width and gauge combination.</p>
          </div>
          <div class="sub-feature">
            <h3 class="sub-title">Yarn Estimation</h3>
            <p>Estimate how much yarn you need for any project before you start.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-calculate {
    position: relative;
    z-index: 1;
    padding: 120px 20px;
  }

  /* Diagonal background — from left, teal */
  .feature-calculate::before {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 45%;
    left: 0;
    right: 0;
    background-color: var(--stripe-teal);
    clip-path: polygon(0% 0%, 40% 0%, 47% 100%, 0% 100%);
    z-index: 0;
  }

  .feature-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .feature-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .tag-mustard { color: var(--mustard); }

  .feature-text {
    position: relative;
    z-index: 2;
  }

  .feature-text h2 {
    color: var(--text-on-light);
    margin-bottom: 2rem;
  }


  .sub-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .sub-title {
    color: var(--accent);
    font-family: var(--font-label);
    font-size: var(--bebas-ui-size);
    letter-spacing: var(--bebas-ui-tracking);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .sub-feature p {
    color: var(--text-on-light-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .feature-phones {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .phone-main {
    position: relative;
    z-index: 2;
  }

  .phone-main :global(.phone-lg) { width: 300px; }

  @media (min-width: 769px) {
    .feature-calculate { padding: 140px 0 140px 20px; }

    .feature-row {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }

    /* Phones LEFT, text RIGHT (flipped from default) */
    .feature-phones {
      flex: 1;
      order: 0;
    }

    .feature-text {
      flex: 1.3;
      order: 1;
    }

    .phone-main :global(.phone-lg) { width: 320px; }
  }

  @media (max-width: 768px) {
    .feature-calculate { padding: 80px 20px; }

    .feature-calculate::before {
      height: 40%;
      clip-path: polygon(0% 0%, 100% 5%, 100% 95%, 0% 100%);
    }

    .feature-text { text-align: center; }

    .sub-features {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .phone-main :global(.phone-lg) { width: 240px; }
  }
</style>
