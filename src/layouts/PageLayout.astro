---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  showStripe?: boolean;
  bodyClass?: string;
}

const { title, description, canonicalPath, bodyClass } = Astro.props;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} bodyClass={bodyClass}>
  <Navbar />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</BaseLayout>
