---
import BaseLayout from "./BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../i18n/config";

interface Props {
  title: string;
  description: string;
  browserTitle?: string;
  canonicalPath?: string;
  bodyClass?: string;
  lang?: Lang;
  alternates?: Partial<Record<Lang, string>>;
  ogType?: "website" | "article";
  ogImageAlt?: string;
  articlePublishedTime?: Date | string;
  articleModifiedTime?: Date | string;
  articleAuthorUrl?: string;
  articleSection?: string;
  articleTags?: string[];
  enableRevealAnimations?: boolean;
}

const {
  title,
  description,
  browserTitle,
  canonicalPath,
  bodyClass,
  lang = "en",
  alternates,
  ogType,
  ogImageAlt,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthorUrl,
  articleSection,
  articleTags,
  enableRevealAnimations = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  browserTitle={browserTitle}
  canonicalPath={canonicalPath}
  bodyClass={bodyClass}
  lang={lang}
  alternates={alternates}
  ogType={ogType}
  ogImageAlt={ogImageAlt}
  articlePublishedTime={articlePublishedTime}
  articleModifiedTime={articleModifiedTime}
  articleAuthorUrl={articleAuthorUrl}
  articleSection={articleSection}
  articleTags={articleTags}
  enableRevealAnimations={enableRevealAnimations}
>
  <Navbar lang={lang} />
  <main id="main-content">
    <slot />
  </main>
  <Footer lang={lang} />
</BaseLayout>
