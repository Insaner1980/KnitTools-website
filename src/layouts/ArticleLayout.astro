---
import PageLayout from './PageLayout.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { CATEGORY_LABELS, type CategorySlug } from '../lib/categories';

interface Props {
  title: string;
  description: string;
  category: CategorySlug;
  publishDate: Date;
  updatedDate?: Date;
  tags: string[];
}

const { title, description, category, publishDate, updatedDate } = Astro.props;
const categoryLabel = CATEGORY_LABELS[category];
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
const formattedPublished = publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
const dateLabel = formattedUpdated ? `Updated ${formattedUpdated}` : `Published ${formattedPublished}`;
---

<PageLayout title={title} description={description} canonicalPath={`/articles/${Astro.params.slug}`} bodyClass="article">
  <article class="article">
    <header class="article-header">
      <div class="article-header-inner">
        <p class="eyebrow">
          <a href="/articles" class="eyebrow-back">← All articles</a>
        </p>
        <p class="article-category">{categoryLabel}</p>
        <h1>{title}</h1>
        <p class="article-meta">
          <span>By KnitTools</span>
          <span>{dateLabel}</span>
        </p>
      </div>
    </header>

    <div class="article-body">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <ClosingCTA variant="page" />
</PageLayout>

<style>
  .article {
    color: var(--ink);
  }

  .article-header {
    padding: 80px 40px 32px;
  }

  .article-header-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }
  .eyebrow-back {
    color: var(--terracotta);
    text-decoration: none;
  }
  .eyebrow-back:hover { color: var(--ink); }
  .eyebrow-sep { opacity: 0.5; }
  .eyebrow-cat { color: var(--ink-soft); }

  .article-header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 24px;
  }

  .article-meta {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .meta-sep { opacity: 0.5; }

  .article-body {
    padding: 32px 40px 96px;
    border-top: 1px solid var(--ink);
  }

  .prose {
    max-width: 720px;
    margin: 48px auto 0;
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.4vw, 18px);
    line-height: 1.7;
    color: var(--ink);
  }

  .prose :global(p) {
    margin: 0 0 1.4em;
  }

  .prose :global(h2) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 2.6vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 2.5em 0 0.7em;
  }

  .prose :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.2;
    color: var(--ink);
    margin: 2em 0 0.6em;
  }

  .prose :global(a) {
    color: var(--terracotta);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) {
    color: var(--ink);
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.4em;
    padding-left: 1.4em;
  }
  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(li) {
    margin: 0 0 0.4em;
    padding-left: 0.4em;
  }
  .prose :global(li::marker) {
    color: var(--terracotta);
  }

  .prose :global(blockquote) {
    margin: 2em 0;
    padding: 0.2em 0 0.2em 1.5em;
    border-left: 3px solid var(--terracotta);
    font-style: italic;
    font-size: 1.08em;
    color: var(--ink-soft);
  }
  .prose :global(blockquote p) {
    margin: 0 0 0.8em;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    padding: 1px 6px;
    background: var(--paper-2);
    border-radius: 0;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--ink);
    opacity: 0.4;
    margin: 3em 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2em 0;
  }

  @media (max-width: 768px) {
    .article-header { padding: 60px 20px 28px; }
    .article-body { padding: 28px 20px 72px; }
    .prose { margin-top: 32px; }
  }
</style>
