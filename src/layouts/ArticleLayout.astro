---
import PageLayout from "./PageLayout.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import {
  SITE_URL,
  FINNVEK_URL,
  ORGANIZATION_ID,
  SOCIAL_PROFILE_URLS,
} from "../config/brand";
import { getCategoryLabel, type CategorySlug } from "../lib/categories";
import { getArticlesIndexPath } from "../i18n/articles";
import { useTranslations } from "../i18n/ui";
import { getHtmlLang, type Lang } from "../i18n/config";

interface Props {
  title: string;
  browserTitle?: string;
  description: string;
  category: CategorySlug;
  publishDate: Date;
  updatedDate?: Date;
  tags: string[];
  lang?: Lang;
  canonicalPath?: string;
  alternates?: Partial<Record<Lang, string>>;
}

const {
  title,
  browserTitle,
  description,
  category,
  publishDate,
  updatedDate,
  tags,
  lang = "en",
  canonicalPath,
  alternates,
} = Astro.props;
const t = useTranslations(lang);
const categoryLabel = getCategoryLabel(category, lang);
const articleCanonicalPath = canonicalPath ?? `/articles/${Astro.params.slug}/`;
const canonicalUrl = `${SITE_URL}${articleCanonicalPath}`;
const modifiedDate = updatedDate ?? publishDate;
const articleAuthorUrl = `${SITE_URL}/about/`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${canonicalUrl}#article`,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  headline: title,
  description,
  image: `${SITE_URL}/images/og-image.png`,
  datePublished: publishDate.toISOString(),
  dateModified: modifiedDate.toISOString(),
  author: {
    "@type": "Organization",
    name: "KnitTools",
    url: articleAuthorUrl,
  },
  publisher: {
    "@type": "Organization",
    "@id": ORGANIZATION_ID,
    name: "Finnvek",
    url: FINNVEK_URL,
    sameAs: SOCIAL_PROFILE_URLS,
  },
  articleSection: categoryLabel,
  keywords: tags,
  inLanguage: getHtmlLang(lang),
  url: canonicalUrl,
};
const dateLocale =
  lang === "fi"
    ? "fi-FI"
    : lang === "de"
      ? "de-DE"
      : lang === "sv"
        ? "sv-SE"
        : lang === "no"
          ? "nb-NO"
          : lang === "fr"
            ? "fr-FR"
            : lang === "nl"
              ? "nl-NL"
              : lang === "da"
                ? "da-DK"
                : "en-US";
const formattedUpdated = updatedDate?.toLocaleDateString(dateLocale, {
  year: "numeric",
  month: "long",
});
const formattedPublished = publishDate.toLocaleDateString(dateLocale, {
  year: "numeric",
  month: "long",
});
const dateLabel = formattedUpdated
  ? `${t("updated")} ${formattedUpdated}`
  : `${t("published")} ${formattedPublished}`;
const articlesPath = getArticlesIndexPath(lang);
---

<PageLayout
  title={title}
  browserTitle={browserTitle}
  description={description}
  canonicalPath={articleCanonicalPath}
  bodyClass="article"
  lang={lang}
  alternates={alternates}
  ogType="article"
  articlePublishedTime={publishDate}
  articleModifiedTime={modifiedDate}
  articleAuthorUrl={articleAuthorUrl}
  articleSection={categoryLabel}
  articleTags={tags}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />

  <article class="article">
    <header class="article-header">
      <div class="article-header-inner">
        <p class="eyebrow">
          <a href={articlesPath} class="eyebrow-back">← {t("allArticles")}</a>
        </p>
        <p class="article-category">{categoryLabel}</p>
        <h1>{title}</h1>
        <p class="article-meta">
          <span>{t("byline")}</span>
          <span>{dateLabel}</span>
        </p>
      </div>
    </header>

    <div class="article-body">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <ClosingCTA variant="page" lang={lang} />
</PageLayout>

<style>
  .article {
    color: var(--ink);
  }

  .article-header {
    padding: 80px 40px 32px;
  }

  .article-header-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .eyebrow {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
  }
  .eyebrow-back {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .eyebrow-back:hover {
    color: var(--terracotta);
  }
  .eyebrow-sep {
    opacity: 0.5;
  }
  .eyebrow-cat {
    color: var(--ink-soft);
  }

  .article-header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 24px;
  }

  .article-meta {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .meta-sep {
    opacity: 0.5;
  }

  .article-body {
    padding: 32px 40px 96px;
    border-top: 1px solid var(--ink);
  }

  .prose {
    max-width: 720px;
    margin: 48px auto 0;
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.4vw, 18px);
    line-height: 1.7;
    color: var(--ink);
  }

  .prose :global(p) {
    margin: 0 0 1.4em;
  }

  .prose :global(h2) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 2.6vw, 2.25rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 2.5em 0 0.7em;
  }

  .prose :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.2;
    color: var(--ink);
    margin: 2em 0 0.6em;
  }

  .prose :global(a) {
    color: var(--terracotta);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose :global(a:hover) {
    color: var(--ink);
  }

  .prose :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.4em;
    padding-left: 1.4em;
  }
  .prose :global(ul) {
    list-style: disc;
  }
  .prose :global(ol) {
    list-style: decimal;
  }
  .prose :global(li) {
    margin: 0 0 0.4em;
    padding-left: 0.4em;
  }
  .prose :global(li::marker) {
    color: var(--terracotta);
  }

  .prose :global(blockquote) {
    margin: 2em 0;
    padding: 0.2em 0 0.2em 1.5em;
    border-left: 3px solid var(--terracotta);
    font-style: italic;
    font-size: 1.08em;
    color: var(--ink-soft);
  }
  .prose :global(blockquote p) {
    margin: 0 0 0.8em;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    padding: 1px 6px;
    background: var(--paper-2);
    border-radius: 0;
  }

  .prose :global(pre) {
    margin: 1.8em 0;
    padding: 18px 20px;
    overflow-x: auto;
    background-color: var(--paper-2) !important;
    color: var(--ink) !important;
  }

  .prose :global(pre code) {
    display: block;
    padding: 0;
    background: transparent;
    color: inherit;
    line-height: 1.6;
  }

  .prose :global(table) {
    width: 100%;
    margin: 1.8em 0;
    border-collapse: collapse;
    font-size: var(--ts-table-cell-size);
    line-height: 1.45;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.55em 1.1em 0.55em 0;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
    text-align: left;
    vertical-align: top;
  }

  .prose :global(th) {
    font-size: var(--ts-table-header-size);
    font-weight: 600;
    color: var(--ink);
  }

  .prose :global(th:last-child),
  .prose :global(td:last-child) {
    padding-right: 0;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--ink);
    opacity: 0.4;
    margin: 3em 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2em 0;
  }

  @media (max-width: 768px) {
    .article-header {
      padding: 60px 20px 28px;
    }
    .article-body {
      padding: 28px 20px 72px;
    }
    .prose {
      margin-top: 32px;
    }
  }
</style>
