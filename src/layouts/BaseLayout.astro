---
import "../styles/global.css";
import { COUNTRY_TO_TIER, FALLBACK_PRICING_TIER } from "../config/pricing";
import { SITE_URL, SOCIAL_PROFILE_URLS } from "../config/brand";
import { getHtmlLang, getLocale, type Lang } from "../i18n/config";
import { useTranslations } from "../i18n/ui";

const GOOGLE_ANALYTICS_MEASUREMENT_ID = "G-BT2BNJWV11";

interface Props {
  title: string;
  description: string;
  browserTitle?: string;
  canonicalPath?: string;
  bodyClass?: string;
  lang?: Lang;
  alternates?: Partial<Record<Lang, string>>;
  ogType?: "website" | "article";
  ogImageAlt?: string;
  articlePublishedTime?: Date | string;
  articleModifiedTime?: Date | string;
  articleAuthorUrl?: string;
  articleSection?: string;
  articleTags?: string[];
  enableRevealAnimations?: boolean;
  preloadDisplayFont?: boolean;
}

const {
  title,
  description,
  browserTitle,
  canonicalPath = "",
  bodyClass = "",
  lang = "en",
  alternates,
  ogType = "website",
  ogImageAlt = "KnitTools knitting app and tools",
  articlePublishedTime,
  articleModifiedTime,
  articleAuthorUrl,
  articleSection,
  articleTags = [],
  enableRevealAnimations = false,
  preloadDisplayFont = true,
} = Astro.props;
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const fullTitle = `${title} | KnitTools`;
const pageTitle = browserTitle ?? fullTitle;
const ogLocale = getLocale(lang);
const htmlLang = getHtmlLang(lang);
const t = useTranslations(lang);
const enableGoogleAnalytics = import.meta.env.PROD;
const googleAnalyticsSnippet = `
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', ${JSON.stringify(GOOGLE_ANALYTICS_MEASUREMENT_ID)});
`;

const toIsoDateTime = (value?: Date | string): string | undefined => {
  if (!value) return undefined;
  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.valueOf()) ? String(value) : date.toISOString();
};

const articlePublishedIso = toIsoDateTime(articlePublishedTime);
const articleModifiedIso = toIsoDateTime(articleModifiedTime);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    {
      enableGoogleAnalytics && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GOOGLE_ANALYTICS_MEASUREMENT_ID}`}
          />
          <script is:inline set:html={googleAnalyticsSnippet} />
        </>
      )
    }
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#F4EAD9" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {
      alternates &&
        Object.entries(alternates).map(([alternateLang, path]) => (
          <link
            rel="alternate"
            hreflang={getHtmlLang(alternateLang as Lang)}
            href={`${SITE_URL}${path}`}
          />
        ))
    }
    {
      alternates && alternates.en && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={`${SITE_URL}${alternates.en}`}
        />
      )
    }

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE_URL}/images/og-image.png`} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="KnitTools" />
    <meta property="og:locale" content={ogLocale} />
    {
      alternates &&
        Object.keys(alternates)
          .filter((alternateLang) => alternateLang !== lang)
          .map((alternateLang) => (
            <meta
              property="og:locale:alternate"
              content={getLocale(alternateLang as Lang)}
            />
          ))
    }
    {
      ogType === "article" && articlePublishedIso && (
        <meta property="article:published_time" content={articlePublishedIso} />
      )
    }
    {
      ogType === "article" && articleModifiedIso && (
        <meta property="article:modified_time" content={articleModifiedIso} />
      )
    }
    {
      ogType === "article" && articleAuthorUrl && (
        <meta property="article:author" content={articleAuthorUrl} />
      )
    }
    {
      ogType === "article" && articleSection && (
        <meta property="article:section" content={articleSection} />
      )
    }
    {
      ogType === "article" &&
        articleTags.map((tag) => <meta property="article:tag" content={tag} />)
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/images/og-image.png`} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {SOCIAL_PROFILE_URLS.map((href) => <link rel="me" href={href} />)}

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href="/fonts/teko-500-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preloadDisplayFont && (
        <link
          rel="preload"
          href="/fonts/lalezar.woff2"
          as="font"
          type="font/woff2"
          crossorigin
        />
      )
    }
    <link
      rel="preload"
      href="/fonts/general-sans-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/general-sans-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Global styles imported via frontmatter -->
    {
      enableRevealAnimations && (
        <script is:inline>
          document.documentElement.classList.add("reveal-animations");
        </script>
      )
    }
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">{t("skipToContent")}</a>
    <div class="page-wrapper">
      <slot />
    </div>
    <script>
      import { initWaitlistSignups } from "../scripts/waitlistSignup";

      initWaitlistSignups();
    </script>
    {
      enableRevealAnimations && (
        <script>
          import {initRevealAnimations} from "../scripts/revealAnimations";
          initRevealAnimations();
        </script>
      )
    }
    <script
      define:vars={{
        countryToTier: COUNTRY_TO_TIER,
        fallbackPricingTier: FALLBACK_PRICING_TIER,
      }}
    >
      (() => {
        const countryStorageKey = "knittools-pricing-country";

        const getTier = (country) => {
          if (!country) return "";
          return (
            countryToTier[String(country).toUpperCase()] || fallbackPricingTier
          );
        };

        const readCachedCountry = () => {
          try {
            return sessionStorage.getItem(countryStorageKey) || "";
          } catch {
            return "";
          }
        };

        const writeCachedCountry = (country) => {
          if (!country) return;
          try {
            sessionStorage.setItem(countryStorageKey, country);
          } catch {
            // sessionStorage can be unavailable in strict privacy modes.
          }
        };

        const getCloudflareCountry = async () => {
          const cachedCountry = readCachedCountry();
          if (cachedCountry) return cachedCountry;

          try {
            const controller = new AbortController();
            const timeout = window.setTimeout(() => controller.abort(), 1200);
            const response = await fetch("/cdn-cgi/trace", {
              cache: "no-store",
              signal: controller.signal,
            });
            window.clearTimeout(timeout);
            if (!response.ok) return "";
            const trace = await response.text();
            const country = trace.match(/^loc=([A-Z]{2})$/m)?.[1] || "";
            writeCachedCountry(country);
            return country;
          } catch {
            return "";
          }
        };

        const applyPricingTier = (tier) => {
          if (!tier) return;
          document.querySelectorAll("[data-regional-price]").forEach((el) => {
            const value = el.getAttribute(`data-${tier.toLowerCase()}`);
            if (value) el.textContent = value;
          });
          document
            .querySelectorAll("[data-regional-pricing-note]")
            .forEach((el) => {
              el.hidden = tier !== fallbackPricingTier;
            });
        };

        getCloudflareCountry().then((country) => {
          const tier = getTier(country);
          applyPricingTier(tier);
        });
      })();
    </script>
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "90537a60e26f433485a8fdaf6b076843"}'
    ></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
