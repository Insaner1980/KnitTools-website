---
import DutchToolsIndex from "../../../components/dutch-tools/DutchToolsIndex.astro";
import DutchCastOnPage from "../../../components/dutch-tools/DutchCastOnPage.astro";
import DutchYarnEstimatorPage from "../../../components/dutch-tools/DutchYarnEstimatorPage.astro";
import DutchNeedleSizeChartPage from "../../../components/dutch-tools/DutchNeedleSizeChartPage.astro";
import DutchYarnWeightChartPage from "../../../components/dutch-tools/DutchYarnWeightChartPage.astro";
import DutchKnittingAbbreviationsPage from "../../../components/dutch-tools/DutchKnittingAbbreviationsPage.astro";
import DutchKnittingSizeChartsPage from "../../../components/dutch-tools/DutchKnittingSizeChartsPage.astro";
import { dutchToolRoutes } from "../../../i18n/dutchTools";
import { toolRouteToRestSlug } from "../../../i18n/tools";

const pageComponents = {
  index: DutchToolsIndex,
  castOn: DutchCastOnPage,
  yarnEstimator: DutchYarnEstimatorPage,
  needleSizeChart: DutchNeedleSizeChartPage,
  yarnWeightChart: DutchYarnWeightChartPage,
  knittingAbbreviations: DutchKnittingAbbreviationsPage,
  knittingSizeCharts: DutchKnittingSizeChartsPage,
};

export function getStaticPaths() {
  const pageRoutes = [
    { href: dutchToolRoutes.index, page: "index" },
    { href: dutchToolRoutes.castOnCalculator, page: "castOn" },
    { href: dutchToolRoutes.yarnEstimator, page: "yarnEstimator" },
    { href: dutchToolRoutes.needleSizeChart, page: "needleSizeChart" },
    { href: dutchToolRoutes.yarnWeightChart, page: "yarnWeightChart" },
    {
      href: dutchToolRoutes.knittingAbbreviations,
      page: "knittingAbbreviations",
    },
    { href: dutchToolRoutes.knittingSizeCharts, page: "knittingSizeCharts" },
  ] as const;

  return pageRoutes.map(({ href, page }) => ({
    params: { slug: toolRouteToRestSlug(dutchToolRoutes.index, href) },
    props: { page },
  }));
}

const Page = pageComponents[Astro.props.page as keyof typeof pageComponents];
---

<Page />
