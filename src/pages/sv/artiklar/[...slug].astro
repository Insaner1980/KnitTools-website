---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
import {
  getArticleAlternates,
  getArticlePath,
  getArticleSlug,
  getSwedishArticleRouteSlug,
  isArticleVisibleForLang,
  isArticleVisibleInCurrentBuild,
} from "../../../i18n/articles";

export async function getStaticPaths() {
  const visibleArticles = (await getCollection("articles")).filter(
    isArticleVisibleInCurrentBuild,
  );
  const articles = visibleArticles.filter((article) =>
    isArticleVisibleForLang(article, "sv"),
  );
  return articles.map((article) => ({
    params: {
      slug: getSwedishArticleRouteSlug(
        article.data.translationKey ?? getArticleSlug(article.id),
        getArticleSlug(article.id),
      ),
    },
    props: { article, visibleArticles },
  }));
}

const { article, visibleArticles } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  tags={article.data.tags}
  lang="sv"
  canonicalPath={getArticlePath(article, "sv")}
  alternates={getArticleAlternates(article, visibleArticles)}
>
  <Content />
</ArticleLayout>
