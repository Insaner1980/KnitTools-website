const faqs = [
  {
    q: "Är stickförkortningar samma i amerikanska och brittiska mönster?",
    a: 'De flesta är identiska. k, p, yo och k2tog betyder samma sak på båda sidor av Atlanten. Skillnaderna samlas kring några termer: amerikanskt "bind off" är brittiskt "cast off", amerikanskt "gauge" är brittiskt "tension", och amerikanskt "stockinette" är brittiskt "stocking stitch". Dessutom kan "seed stitch" och "moss stitch" byta betydelse beroende på källan, så lita på maskdefinitionen mer än namnet. När ett mönster inte anger vilket system det använder är designerns plats oftast bästa ledtråden.',
  },
  {
    q: "Vad betyder asterisken i ett stickmönster?",
    a: 'Den markerar en upprepning. Allt mellan asterisken och nästa matchande instruktion, oftast "rep from *", stickas om och om igen över varvet. Hakparenteser och parenteser gör samma jobb: de grupperar en serie moment som upprepas ett visst antal gånger. Att missa en upprepningsmarkör är ett av de snabbaste sätten att få fel maskantal.',
  },
  {
    q: "Vad gör jag om jag inte hittar en förkortning i en standardlista?",
    a: "Det är nästan säkert en mönsterspecifik förkortning som designern har definierat. Gå upp till början av mönstret och leta efter en förkortningslista eller avsnitt med maskdefinitioner. Flät- och spetsmönster är den största källan till egna kortformer, eftersom designers ofta hittar på kompakt notation för tekniker som bara gäller just den designen. Om den inte finns där är mönsteranteckningar eller diagramnyckel nästa ställe att kontrollera.",
  },
  {
    q: "Vad är skillnaden mellan ssk och skp?",
    a: "Båda är vänsterlutande minskningar och ger nästan samma resultat i den färdiga stickningen. ssk är modern standard och syns i de flesta nya mönster. skp förekommer oftare i äldre mönster. Utförandet skiljer sig lite, så följ den förkortning som mönstret anger i stället för att byta fritt.",
  },
];
---

<LocalizedToolPage
  title="Stickförkortningar: sökbar ordlista"
  description="Slå upp stickförkortningar eller sök efter tekniknamn. Praktisk ordlista över mönstertermer från k2tog till psso, ordnad efter kategori."
  canonicalPath={routes.tool.knittingAbbreviations.sv}
  lang="sv"
  alternates={routes.tool.knittingAbbreviations}
  intro="Sök en förkortning för att se vad den betyder, eller sök en teknik för att hitta dess förkortningar."
  schemaName="Stickförkortningar"
  schemaDescription="Sökbar ordlista över stickförkortningar och tekniknamn."
  faqs={faqs}
  variant="brown"
>
  <div slot="tool">
    <div class="abbr-wrapper">
      <input
        type="text"
        id="abbr-search"
        class="search-input"
        placeholder='Sök förkortning eller teknik, t.ex. "ssk" eller "minskning"'
        autocomplete="off"
      />

      <div
        class="category-filters"
        role="group"
        aria-label="Filtrera efter kategori"
      >
        {
          filterOrder.map((cat, index) => (
            <button
              type="button"
              class={`cat-btn${index === 0 ? " is-active" : ""}`}
              data-cat={cat}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {cat === "all" ? "Alla" : categoryLabels[cat as Category]}
            </button>
          ))
        }
      </div>

      <ul class="abbr-list" id="abbr-list" aria-label="Stickförkortningar">
        {
          abbreviations.map((item) => (
            <li
              class="abbr-row"
              data-abbr={item.abbr.toLowerCase()}
              data-def={item.def.toLowerCase()}
              data-search={item.search.toLowerCase()}
              data-cats={item.categories.join(" ")}
              data-catlabels={item.categories
                .map((cat) => categoryLabels[cat].toLowerCase())
                .join(" ")}
            >
              <span class="abbr-term">{item.abbr}</span>
              <span class="abbr-def">{item.def}</span>
            </li>
          ))
        }
      </ul>

      <p class="no-results" id="no-results" hidden>
        Inga matchande förkortningar hittades.
      </p>
    </div>
  </div>

  <div slot="content">
    <h2>Så läses förkortningar i sitt sammanhang</h2>
    <p>
      De flesta förkortningar sorterar sig i några grupper, och att känna igen
      gruppen hjälper mer än att memorera varje enskild term.
    </p>
    <p>
      <strong>Grundmaskor</strong> är enstaka bokstäver. <code>k</code> är knit, räta
      maskor, och <code>p</code> är purl, aviga maskor. En siffra efter bokstaven
      säger hur många: <code>k5</code> betyder sticka fem räta maskor. Det är hela
      systemet för de enklaste.
    </p>
    <p>
      <strong>Kombinerade moment</strong> staplar bokstäver och siffror. <code
        >k2tog</code
      > betyder sticka två maskor tillsammans. <code>p2tog</code> är samma idé men
      avigt. Mycket stickförkortning fungerar så. Sakta ner och läs det bokstavligt.
    </p>
    <p>
      <strong>Sidmarkörer</strong> berättar vilken sida av arbetet du är på. <code
        >RS</code
      > är rätsida, <code>WS</code> är avigsida. Det spelar roll eftersom samma handrörelse
      ger olika resultat beroende på om du arbetar på den synliga sidan eller baksidan.
    </p>
    <p>
      <strong>Formningsförkortningar</strong> styr hur tyget växer eller smalnar av.
      <code>M1</code>, <code>M1L</code>, <code>M1R</code> och <code>kfb</code> lägger
      till maskor. <code>k2tog</code> och <code>ssk</code> tar bort dem. När du vet
      vilka som lutar åt vänster, vilka som lutar åt höger och vilka som bara lägger
      till eller tar bort blir mönster lättare att läsa snabbt.
    </p>
    <p>
      <strong>Strukturtermer</strong> håller instruktionerna kompakta. <code
        >rep</code
      >, <code>st(s)</code>, <code>beg</code>, <code>rem</code>, <code
        >cont</code
      >. Stomme, inte maskor.
    </p>
    <p>
      Interpunktion spelar också roll. Asterisker och semikolon är inte
      dekoration. <code>*k2, p2; rep from *</code> betyder att allt mellan asterisken
      och semikolonet upprepas. Hakparenteser och parenteser fungerar på liknande
      sätt och grupperar moment som upprepas ett visst antal gånger. Att missa en
      upprepningsmarkör är ett av de snabbaste sätten att få fel maskantal.
    </p>

    <h2>Skillnader mellan US och UK</h2>
    <p>Några termer skiftar över Atlanten. De stora är:</p>
    <p>
      Amerikanskt "bind off" är brittiskt "cast off". Amerikanskt "gauge" är
      brittiskt "tension". Amerikanskt "stockinette" är brittiskt "stocking
      stitch". Och den klassiska fällan: "seed stitch" och "moss stitch" kan
      byta betydelse beroende på källan, så en skriven maskdefinition slår
      alltid namnet.
    </p>
    <p>
      De flesta vanliga förkortningar, som <code>k</code>, <code>p</code>, <code
        >yo</code
      > och <code>k2tog</code>, är samma i båda systemen. Om ett mönster inte
      anger amerikanska eller brittiska konventioner brukar avsnittet med
      maskdefinitioner reda ut det. Om det inte finns någon sådan del alls är
      designerns plats bästa ledtråden.
    </p>

    <h2>Mönsterspecifika förkortningar</h2>
    <p>
      Det är här det blir intressant, för många förkortningar finns inte i någon
      standardlista. Det är normalt. De är egna kortformer som designern har
      hittat på för just det mönstret, och de ska definieras nära början av
      instruktionerna.
    </p>
    <p>
      Flätmönster är den största källan till sådana. En diagramnyckel kan
      definiera <code>C4F</code>, <code>C6B</code> eller något mer specifikt för designen.
      Siffran anger oftast hur många maskor som korsas. Bokstaven i slutet, F eller
      B, anger riktning: front eller back, alltså var du håller flätstickan när du
      korsar. Men designers är inte alltid konsekventa med den konventionen. Vissa
      använder L och R i stället. Vissa räknar alla maskor som ingår, andra bara maskorna
      som flyttas. Mönstrets egen definition är det som gäller.
    </p>
    <p>
      Spetsmönster bygger också sammansatta kortformer. Ett mönster skriver <code
        >CDD</code
      > för en centrerad dubbel minskning. Ett annat skriver ut samma sak som <code
        >sl2-k1-p2sso</code
      >. Ett tredje använder <code>s2kp</code>. Alla tre pekar på samma
      grundidé, men exakt utförande kan skilja mellan designers, och vissa
      förkortningar används för lite olika minskningar beroende på källa. Om en
      förkortning ser obekant ut, kontrollera mönsternyckeln innan du antar att
      den är den vanligaste versionen. Mönsternycklar finns just därför.
    </p>
    <p>
      Flerfärgsstickning förkortar ibland färgnamn eller färgtilldelning. Du kan
      se MC, main color, och CC, contrast color, eller CC1 och CC2 när flera
      kontrastfärger används. Vissa designers använder A, B, C i stället.
      Förkortningarna är enkla, men om du blandar ihop vilken färg som ska vara
      var syns det i det färdiga arbetet.
    </p>
    <p>
      Vissa designers skapar också kortformer för upprepade masksekvenser som
      bara finns i deras design. Ett mönster kan definiera något som "MB" för en
      viss bobble-metod, eller "cluster" för en särskild kombination av omslag
      och genomdragningar som bara gäller det projektet. De sparar designern
      från att skriva ut ett flerstegsmoment varje gång det dyker upp. De är
      bara begripliga inuti det mönstret.
    </p>
    <p>
      Grundregeln: om du inte hittar en förkortning i en standardreferens är den
      nästan säkert definierad i mönsterhuvudet. Bläddra upp innan du söker
      vidare.
    </p>

    <h2>Vad symbolerna i stickdiagram betyder</h2>
    <p>
      Diagram använder symboler i stället för utskrivna varv. Varje ruta är en
      maska, och symbolen i rutan säger vad du ska göra.
    </p>
    <p>
      Det finns ingen universell standard för diagramsymboler, men många
      designers ligger nära Craft Yarn Councils konventioner. En tom ruta
      betyder oftast rät maska på RS och avig maska på WS. Ett streck betyder
      avig maska på RS. En cirkel är <code>yo</code>. Ett högerlutande
      snedstreck markerar <code>k2tog</code>, ett vänsterlutande markerar <code
        >ssk</code
      >.
    </p>
    <p>
      Diagram läses nedifrån och upp, eftersom stickningen växer uppåt. På plana
      diagram går RS-varv från höger till vänster och WS-varv från vänster till
      höger, i samma riktning som stickorna rör sig. Diagram för rundstickning
      läses från höger till vänster på varje varv, eftersom du alltid arbetar
      från rätsidan.
    </p>
    <p>
      Om ett mönster har både skrivna instruktioner och diagram ska de stämma
      överens. När de inte gör det, och det händer oftare än man vill, bör
      mönsteranteckningarna säga vilket som gäller. Om de inte säger det, sticka
      en rapport som prov innan du litar på någon av versionerna.
    </p>

    <h2>Några förkortningar att kunna tidigt</h2>
    <p>
      Du behöver inte memorera allt innan du lägger upp. En första halsduk
      kanske bara använder <code>k</code> och <code>p</code>. En enkel mössa
      lägger till någon minskning. Resten kommer naturligt med mönstren du
      väljer, och samma dussin förkortningar täcker det mesta du stickar.
    </p>
    <p>
      Ett par som ofta ställer till det: <code>ssk</code> och <code>skp</code> är
      båda vänsterlutande minskningar. <code>ssk</code> är modern standard. <code
        >skp</code
      > syns mer i äldre mönster. De blir lika i resultatet men skiljer sig lite i
      utförande, så följ mönstret som det står om det inte ger tillåtelse att byta.
    </p>
    <p>
      En annan värd att flagga: <code>psso</code>, pass slipped stitch over,
      dyker upp både ensam och som del av sammansatta förkortningar som <code
        >sl1-k2tog-psso</code
      >. När du ser den ensam följer den oftast på en lyft maska från föregående
      steg.
    </p>
    <p>
      Craft Yarn Council publicerar en allmänt använd standardlista över
      förkortningar, och många designers följer den för vanliga termer. Utöver
      grunderna tar regionala vanor och mönsterspecifika kortformer över.
      "Kontrollera mönsternyckeln" är bättre råd än "memorera en huvudlista".
    </p>
    <p>
      Ha den här referensen öppen medan du stickar. Den sökbara ordlistan är
      snabbare än att växla mellan flikar när du är mitt i ett varv. Om du också
      reder ut stickstorlekar eller <a
        href="/sv/artiklar/sa-mater-du-stickfasthet/">stickfasthet</a
      > passar de referenserna bra ihop med ordlistan. Och om du är ny på att <a
        href="/sv/artiklar/lasa-stickmonster-nyborjarguide/"
        >läsa stickmönster</a
      > är förkortningsnyckeln i mönstret den första delen att skanna innan du lägger
      upp.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const searchInput = document.getElementById(
    "abbr-search",
  ) as HTMLInputElement | null;
  const list = document.getElementById("abbr-list");
  const noResults = document.getElementById("no-results");
  const catButtons = document.querySelectorAll<HTMLButtonElement>(".cat-btn");

  let activeCategory = "all";

  function applyFilters() {
    if (!list || !noResults) return;
    const rows = list.querySelectorAll<HTMLElement>(".abbr-row");
    const query = (searchInput?.value || "").trim().toLowerCase();
    let visibleCount = 0;

    rows.forEach((row) => {
      const cats = (row.dataset.cats || "").split(" ");
      const haystack = [
        row.dataset.abbr,
        row.dataset.def,
        row.dataset.search,
        row.dataset.catlabels,
      ].join(" ");

      const matchesCategory =
        activeCategory === "all" || cats.includes(activeCategory);
      const matchesSearch = !query || haystack.includes(query);
      const visible = matchesCategory && matchesSearch;

      row.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    noResults.hidden = visibleCount > 0;
  }

  searchInput?.addEventListener("input", applyFilters);

  catButtons.forEach((button) => {
    button.addEventListener("click", () => {
      catButtons.forEach((item) => {
        item.classList.remove("is-active");
        item.setAttribute("aria-pressed", "false");
      });

      button.classList.add("is-active");
      button.setAttribute("aria-pressed", "true");
      activeCategory = button.dataset.cat || "all";
      applyFilters();
    });
  });
</script>
