---
import LocalizedToolPage from "../../../components/LocalizedToolPage.astro";
import { routes } from "../../../i18n/routes";

type Category =
  | "cast-on-bind-off"
  | "increases"
  | "decreases"
  | "cables"
  | "lace"
  | "general"
  | "stitch-patterns";

interface Abbreviation {
  abbr: string;
  def: string;
  search: string;
  categories: Category[];
}

