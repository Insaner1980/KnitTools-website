  },
  {
    q: "Vad gör jag om mina mått inte passar snyggt i en storlek?",
    a: "Det är normalt. De flesta är inte en enda storlek över alla mått. Prioritera det mått som är viktigast för plagget: bröstvidd för en tröja, höft för en kjol, huvudomkrets för en mössa. Många mönster har instruktioner för att förlänga eller korta vissa delar.",
  },
];
---

<LocalizedToolPage
  title="Storlekstabeller för stickning"
  description="Standardiserade kroppsmått för stickning. Storlekar från baby till vuxen med bröst, midja, höft, ärmlängd och mer, i cm och tum."
  canonicalPath={routes.tool.knittingSizeCharts.sv}
  lang="sv"
  alternates={routes.tool.knittingSizeCharts}
  intro="Referensmått för stickprojekt. Välj kategori och måttenhet för att se tabellen."
  schemaName="Storlekstabeller för stickning"
  schemaDescription="Referenstabeller med standardiserade kroppsmått för stickning, från baby till vuxenstorlekar."
  faqs={faqs}
  variant="terracotta"
>
  <div slot="tool">
    <p class="panel-intro">
      Det här är kroppsmått, inte färdiga plaggmått. Lägg till rörelsevidd för
      den passform du vill ha.
    </p>
    <div class="chart-controls">
      <div class="tab-scroller">
        <div class="tabs" role="tablist" aria-label="Storlekskategori">
          {
            panels.map((panel) => (
              <button
                type="button"
                role="tab"
                class={`tab-btn${panel.id === defaultPanel ? " is-active" : ""}`}
                data-tab={panel.id}
                aria-selected={panel.id === defaultPanel ? "true" : "false"}
                aria-controls={`panel-${panel.id}`}
                id={`tab-${panel.id}`}
              >
                {panel.label}
              </button>
            ))
          }
        </div>
      </div>

      <div class="unit-toggle" role="radiogroup" aria-label="Måttenhet">
        <button
          type="button"
          role="radio"
          class="unit-btn is-active"
          data-unit="cm"
          aria-checked="true">CM</button
        >
        <button
          type="button"
          role="radio"
          class="unit-btn"
          data-unit="inch"
          aria-checked="false">Tum</button
        >
      </div>
    </div>

    <div class="chart-wrap show-cm" id="sv-size-chart-wrap">
      {
        panels.map((panel) => (
          <div
            class={`panel${panel.id === defaultPanel ? " is-active" : ""}`}
            data-panel={panel.id}
            role="tabpanel"
            id={`panel-${panel.id}`}
            aria-labelledby={`tab-${panel.id}`}
            hidden={panel.id !== defaultPanel}
          >
            {panel.intro && <p class="panel-intro">{panel.intro}</p>}
            {panel.tables.map((table) => (
              <div class="table-block">
                {table.caption && (
                  <h3 class="table-caption">{table.caption}</h3>
                )}
                <div class="table-scroll">
                  <table class="size-table">
                    <thead>
                      <tr>
                        <th class="sticky-col">{table.sizeHeader ?? "Mått"}</th>
                        {table.sizes.map((size) => (
                          <th>{size}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {table.rows.map((row) => (
                        <tr>
                          <th scope="row" class="sticky-col row-label">
                            {row.label}
                          </th>
                          {row.cells.map((cell) => (
                            <td>
                              <span class="unit-cm">{formatCm(cell.cm)}</span>
                              <span class="unit-inch">{cell.inch}</span>
                            </td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>

  <div slot="content">
    <h2>Så tar du kroppsmått</h2>
    <p>
      Måtten i de här tabellerna motsvarar specifika punkter på kroppen. För att
      få ett korrekt mått behöver du mäta på rätt ställe.
    </p>
    <p>
      <strong>Bröst / byst:</strong> Mät runt den fylligaste delen av bröstet, med
      måttbandet vågrätt och intill kroppen men inte hårt. För kvinnor är det vid
      bystens fylligaste punkt. Det här är huvudmåttet för att välja plaggstorlek.
    </p>
    <p>
      <strong>Midja:</strong> Mät vid den naturliga midjan, den smalaste punkten på
      bålen, oftast strax ovanför naveln. Böj dig åt sidan om du är osäker; vecket
      visar var midjan sitter.
    </p>
    <p>
      <strong>Höft:</strong> Mät runt höftens fylligaste del, oftast 18-23 cm under
      midjan. Håll måttbandet vågrätt.
    </p>
    <p>
      <strong>Ryggbredd (axel till axel):</strong> Mät rakt över ryggen från spetsen
      av ena axeln till den andra. Det avgör plaggets axelbredd.
    </p>
    <p>
      <strong>Rygglängd till midja:</strong> Mät från den tydliga knölen i nacken
      rakt ner till den naturliga midjan. Det avgör hur lång båldelen av plagget behöver
      vara.
    </p>
    <p>
      <strong>Ärmlängd till underarm:</strong> Mät från armhålan till handledsknölen.
      Det är din guide för ärmlängd.
    </p>
    <p>
      <strong>Överarmsvidd:</strong> Mät omkretsen vid överarmens fylligaste del,
      med armen avslappnad vid sidan.
    </p>
    <p>
      <strong>Ärmhålsdjup:</strong> Mät från axelns ovansida rakt ner till underarmen.
      Det avgör hur djup ärmhålsformningen behöver vara.
    </p>
    <p>
      <strong>Nacke till handled mitt bak:</strong> Mät från mitten bak i nacken,
      över axeln och ner längs armen till handledsknölen. Det här samlade måttet används
      för raglan- och okkonstruktioner där kropp och ärm stickas ihop.
    </p>

    <h2>Kroppsmått kontra färdiga plaggmått</h2>
    <p>
      Det här är den vanligaste källan till storleksförvirring i stickning.
      Tabellerna visar kroppsmått, alltså personens faktiska mått. Ett färdigt
      plagg kan vara mindre, lika stort eller större beroende på vilken
      rörelsevidd mönstret använder.
    </p>
    <p>
      <strong>Negativ rörelsevidd (-2,5 till -5 cm):</strong> Plagget är mindre än
      kroppen. Används för mössor, sockor och mycket kroppsnära resårplagg som ska
      sitta åt.
    </p>
    <p>
      <strong>Noll rörelsevidd:</strong> Plagget matchar kroppsmåtten exakt. Det ger
      en kroppsnära passform och är mindre vanligt än positiv rörelsevidd i tröjor.
    </p>
    <p>
      <strong>Positiv rörelsevidd (5-10 cm):</strong> Plagget är lite större än kroppen.
      Det är standardpassform för de flesta tröjor, koftor och toppar.
    </p>
    <p>
      <strong>Generös rörelsevidd (10-15 cm):</strong> Plagget är tydligt större än
      kroppen. Slappa tröjor, cocoon-koftor och plagg med avslappnad passform.
    </p>
    <p>
      <strong>Oversized rörelsevidd (15+ cm):</strong> Plagget är mycket löst och
      betydligt större än kroppen.
    </p>
    <p>
      När ett mönster säger att en storlek passar bröstvidd 91,5 cm och anger
      färdig bystvidd 101,5 cm är skillnaden på 10 cm rörelsevidden. Din uppgift
      är att välja storleken där passformsmåttet matchar kroppen, inte bara det
      färdiga måttet.
    </p>
    <p>
      När du vet målstorleken kan <a href={routes.tool.yarnEstimator.sv}
        >garnåtgångskalkylatorn</a
      > rimlighetskontrollera garnåtgången, och <a
        href="/sv/artiklar/hur-mycket-garn-till-troja/"
        >guiden till garn för tröjor</a
      > går igenom storleksberäkningar mer ingående.
    </p>

    <h2>Att välja mellan storlekar</h2>
    <p>
      Om bröstvidden hamnar mellan två storlekar beror rätt val på plaggets
      tänkta passform. För ett kroppsnära plagg, välj den mindre storleken. För
      en ledig eller oversized passform, välj den större.
    </p>
    <p>
      Jämför också andra mått, särskilt höft för längre plagg och överarm för
      åtsittande ärmar. Om bröstet säger M men höften säger L, kontrollera
      mönstrets måttskiss för att se om höftskillnaden spelar roll för plaggets
      längd och silhuett.
    </p>
    <p>
      Oavsett vilken storlek du väljer avgör <a
        href="/sv/artiklar/sticka-provlapp-steg-for-steg/">stickprovet</a
      > om det färdiga arbetet faktiskt matchar mönstrets siffror. Guiden <a
        href="/sv/artiklar/sa-mater-du-stickfasthet/"
        >så mäter du stickfasthet</a
      > går igenom stickprovet i detalj.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const tabButtons = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const panels = document.querySelectorAll<HTMLElement>(".panel");

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const target = button.dataset.tab;

      tabButtons.forEach((tab) => {
        const isActive = tab.dataset.tab === target;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === target;
        panel.classList.toggle("is-active", isActive);
        if (isActive) {
          panel.removeAttribute("hidden");
        } else {
          panel.setAttribute("hidden", "");
        }
      });
    });
  });

  const unitButtons = document.querySelectorAll<HTMLButtonElement>(".unit-btn");
  const chartWrap = document.getElementById("sv-size-chart-wrap");

  unitButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const unit = button.dataset.unit;
      if (!unit || !chartWrap) return;

      unitButtons.forEach((unitButton) => {
        const isActive = unitButton.dataset.unit === unit;
        unitButton.classList.toggle("is-active", isActive);
        unitButton.setAttribute("aria-checked", isActive ? "true" : "false");
      });

      chartWrap.classList.toggle("show-cm", unit === "cm");
      chartWrap.classList.toggle("show-inch", unit === "inch");
    });
  });
</script>
