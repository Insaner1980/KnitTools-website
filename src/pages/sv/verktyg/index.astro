---
import ToolsIndexPage from "../../../components/ToolsIndexPage.astro";
import { routes } from "../../../i18n/routes";

const tools = [
  {
    tag: "Maskor",
    title: "Uppläggningskalkylator",
    description:
      "Räkna ut hur många maskor du ska lägga upp för valfri bredd och stickfasthet.",
    href: routes.tool.castOnCalculator.sv,
    className: "card-terracotta card-top-left",
  },
  {
    tag: "Garnåtgång",
    title: "Garnåtgångskalkylator",
    description:
      "Uppskatta garnåtgång efter typ av projekt, storlek och garntjocklek.",
    href: routes.tool.yarnEstimator.sv,
    className: "card-rust card-top-right",
  },
  {
    tag: "Tjocklekar",
    title: "Garntjocklekar",
    description: "CYC:s garntjocklekar med stickfasthet, stickor och WPI.",
    href: routes.tool.yarnWeightChart.sv,
    className: "card-sand card-bl1",
  },
  {
    tag: "Stickor",
    title: "Stickstorlekar",
    description:
      "Översätt mellan US-, UK-, metriska och japanska stickstorlekar.",
    href: routes.tool.needleSizeChart.sv,
    className: "card-teal card-br1",
  },
  {
    tag: "Storlekar",
    title: "Storlekstabeller",
    description: "Kroppsmått från baby till vuxen, i cm och tum.",
    href: routes.tool.knittingSizeCharts.sv,
    className: "card-terracotta card-bl2",
  },
  {
    tag: "Ordlista",
    title: "Stickförkortningar",
    description: "Sök en förkortning eller hitta termer efter teknik.",
    href: routes.tool.knittingAbbreviations.sv,
    className: "card-brown card-br2",
  },
];
---

<ToolsIndexPage
  title="Gratis stickverktyg: kalkylatorer och tabeller"
  description="Gratis stickkalkylatorer och referenstabeller online: uppläggning, garnåtgång, stickstorlekar, garntjocklekar, förkortningar och kroppsmått."
  canonicalPath={routes.toolsIndex.sv}
  lang="sv"
  alternates={routes.toolsIndex}
  collectionName="Gratis stickverktyg"
  collectionDescription="Gratis stickkalkylatorer och referenstabeller online."
  eyebrow="Gratis verktyg"
  heading="Stickverktyg online."
  intro="Kalkylatorer och referenstabeller för dina stickprojekt. Ingen inloggning, ingen app behövs."
  tools={tools}
/>
