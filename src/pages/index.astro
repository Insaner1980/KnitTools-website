  <script is:inline>
    (() => {
      const rowEl = document.getElementById('rowNum');
      if (rowEl) {
        let row = 84;
        const flash = () => {
          rowEl.animate(
            [{ transform: 'scale(1)' }, { transform: 'scale(1.08)' }, { transform: 'scale(1)' }],
            { duration: 220 }
          );
        };
        document.querySelector('[data-inc]')?.addEventListener('click', () => {
          row++;
          rowEl.textContent = row;
          flash();
        });
        document.querySelector('[data-dec]')?.addEventListener('click', () => {
          row = Math.max(0, row - 1);
          rowEl.textContent = row;
        });
      }

      const heroForm = document.getElementById('hero-signup-form');
      const heroContent = document.getElementById('hero-content-layer');
      const heroSuccess = document.getElementById('hero-success');
      if (heroForm && heroContent && heroSuccess) {
        heroForm.addEventListener('submit', (e) => {
          e.preventDefault();
          heroContent.style.display = 'none';
          heroSuccess.style.display = 'flex';
          heroSuccess.setAttribute('aria-hidden', 'false');
        });
      }

      const closingForm = document.getElementById('closing-signup-form');
      const closingContent = document.getElementById('closing-content');
      const closingSuccess = document.getElementById('closing-success');
      if (closingForm && closingContent && closingSuccess) {
        closingForm.addEventListener('submit', (e) => {
          e.preventDefault();
          closingContent.style.display = 'none';
          closingSuccess.style.display = 'block';
          closingSuccess.setAttribute('aria-hidden', 'false');
        });
      }
    })();
  </script>

