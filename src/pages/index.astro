---
import EditorialLayout from '../layouts/EditorialLayout.astro';

const languages = [
  'English',
  'Suomi',
  'Svenska',
  'Dansk',
  'Norsk',
  'Nederlands',
  'Deutsch',
  'Français',
  'Italiano',
  'Português',
  'Español',
];

const features = [
  {
    section: '§ Counter',
    tier: 'free',
    title: 'Tap without looking.',
    body:
      'A big round button where your thumb already is. Miscount? Undo. Session history accrues quietly in the background.',
    yarnBall: true,
  },
  {
    section: '§ Ravelry',
    tier: 'free',
    dark: true,
    title: 'Signed in. Nothing else shared.',
    body:
      'Search, save, start a project in one tap. Log in through Ravelry itself — your password never touches this app.',
  },
  {
    section: '§ Calculators',
    tier: 'free',
    title: "The math you'd rather avoid.",
    body: 'Cast on, gauge, increases, yardage. Four calculators, quietly working the numbers your knitting already asked you to do.',
  },
  {
    section: '§ Reference',
    tier: 'free',
    title: 'One tap away, every time.',
    body:
      'Needles, sizes, chart symbols, abbreviations. Right there in your library, before you remember you needed it.',
  },
  {
    section: '§ Widget',
    tier: 'free',
    title: 'A widget on your home screen.',
    body:
      'Tap to count. No app launch, no loading. The exact amount of friction a row counter should have, which is zero.',
  },
  {
    section: '§ Pattern',
    tier: 'pro',
    sage: true,
    title: 'Patterns that follow along.',
    body:
      "PDF or Ravelry pull-in. The row you're on highlights itself. Tap sl1, k2tog, psso — the AI explains step by step.",
  },
  {
    section: '§ Yarn Stash',
    tier: 'pro',
    title: 'A cabinet of yarn cards.',
    body:
      'Point the camera at the ball band. Fiber, weight, meters, needle size, gauge, dye lot — one card per skein, searchable.',
  },
  {
    section: '§ Insights',
    tier: 'pro',
    title: 'Your numbers, quietly kept.',
    body:
      'Hours at the needles. Rows per hour. Streaks. No leaderboards, no nudges, no comparing yourself to anyone else. The stats are yours.',
  },
  {
    section: '§ Progress',
    tier: 'pro',
    title: 'Progress photos, just for you.',
    body:
      'One folder per project. Full resolution, on your device, nothing uploaded anywhere.',
  },
];

const counterChecklist = [
  { n: 'i', t: 'Undo and redo every count', d: 'Tap & hold' },
  { n: 'ii', t: 'Stitch, shape and repeat side by side', d: 'Three counters' },
  { n: 'iii', t: 'Row reminders with messages', d: '"Join sleeve"' },
  { n: 'iv', t: 'Automatic shaping increases', d: 'Every N rows' },
  { n: 'v', t: 'Session history, row-timestamped', d: 'Auto-saved' },
  { n: 'vi', t: 'Home-screen widget, one tap to count', d: 'No app launch' },
];

const scannerChecklist = [
  { n: 'i', t: 'Point your camera at the ball band', d: 'On-device OCR' },
  { n: 'ii', t: 'AI reads fiber, weight, yardage, gauge', d: 'Auto-filed' },
  { n: 'iii', t: 'Mystery skeins finally get a name', d: 'Cross-referenced' },
  { n: 'iv', t: 'Full band photo saved alongside', d: 'Never lost again' },
];

const voiceBullets = [
  {
    n: 'i',
    t: 'Voice commands, English & Finnish',
    d: 'Add three, next row, set row, undo. Works with no signal needed.',
  },
  {
    n: 'ii',
    t: 'The AI knows where you are',
    d: "Which project, which row, how far you've gone today — no need to tell it twice.",
  },
  {
    n: 'iii',
    t: 'Explains the stitches when you ask',
    d: 'Tap sl1, k2tog, psso — or ask aloud. The AI walks you through it.',
  },
  {
    n: 'iv',
    t: 'On-device where possible',
    d: 'No cloud round-trip for the basics. AI requests only when you invoke them.',
  },
];

const freeBrowserTools = [
  { n: '01', t: 'Cast On Calculator', href: '/tools/cast-on-calculator' },
  { n: '02', t: 'Yarn Estimator', href: '/tools/yarn-estimator' },
  { n: '03', t: 'Needle Size Chart', href: '/tools/needle-size-chart' },
  { n: '04', t: 'Yarn Weight Chart', href: '/tools/yarn-weight-chart' },
  { n: '05', t: 'Abbreviations', href: '/tools/knitting-abbreviations' },
  { n: '06', t: 'Size Charts', href: '/tools/knitting-size-charts' },
];

const heatmapSeed = [
  2, 0, 1, 3, 4, 2, 1, 0, 1, 2, 2, 3, 4, 3, 1, 0, 1, 2, 4, 4, 3, 0, 0, 1, 1, 2, 3, 2, 2, 2, 3, 4, 4, 3, 2, 1, 1, 2, 3,
  3, 2, 1, 0, 1, 2, 2, 3, 4, 3, 2, 3, 3, 4, 4, 4, 3, 1, 2, 2, 3, 3, 2, 1, 0, 0, 1, 2, 3, 3, 2, 2, 2, 3, 4, 4, 3, 2, 1,
  0, 1, 2, 3, 4, 3, 0, 1, 2, 3, 3, 2, 1, 2, 3, 3, 4, 4, 3, 2, 1, 1, 2, 2, 3, 3, 2, 0, 0, 1, 2, 3, 4, 3, 2, 2, 3, 3, 4,
  4, 3, 1, 2, 3, 4, 4, 3, 2, 0, 1, 2, 3, 3, 2, 1, 1, 2, 2, 3, 4, 4, 3,
];
const heatmapLevels = ['', 'l1', 'l2', 'l3', 'l4'];
const heatmapCells = 20 * 7;
---

<EditorialLayout
  title="KnitTools — Every Tool a Knitter Needs. One App."
  description="A private, on-device knitting studio for Android. Free row counter, calculators, Ravelry sign-in. Pro unlocks voice commands, AI, yarn scanner, unlimited projects. No subscription."
  canonicalPath="/"
>
  <div class="page">
    <!-- Masthead -->
    <header>
      <div class="sub-mast">
        <div class="bit mono">Vol. 01 · Pre-launch</div>
        <div class="bit center mono">"Pick up where you left off."</div>
        <div class="bit center mono">A private, on-device toolkit</div>
        <div class="bit right mono">For Android</div>
        <div class="bit right mono">Waitlist open</div>
      </div>
      <hr class="thin" style="margin:10px 0 0" />
      <div class="masthead">
        <div class="left mono"><span>EST.</span><span class="dot"></span><span>2026</span></div>
        <div class="wordmark">Kni<span class="accent">t</span>Tools</div>
        <div class="right mono"><span>ELEVEN LANGUAGES</span><span class="dot"></span><span>€8.99</span></div>
      </div>
      <div class="double"></div>
      <nav class="top">
        <a href="#features">The Features</a>
        <span class="sep">◆</span>
        <a href="#counter">Counter</a>
        <span class="sep">◆</span>
        <a href="#scanner">Yarn Scanner</a>
        <span class="sep">◆</span>
        <a href="#voice">Voice &amp; AI</a>
        <span class="sep">◆</span>
        <a href="#insights">Insights</a>
        <span class="sep">◆</span>
        <a href="#pricing">Pricing</a>
        <span class="sep">◆</span>
        <a href="#privacy">Privacy</a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div>
        <div class="issue-tag"><span class="square"></span> A knitting toolkit for Android · Launching soon</div>
        <h1 class="display">
          Pick up<br />where you<br /><em>left</em> <span class="knot"></span> <em>off.</em>
        </h1>
        <p class="dek">
          The row you were on, the yarn you forgot, the pattern that made no sense at midnight. KnitTools remembers it
          all — so the only thing you need to do is keep knitting.
        </p>

        <form class="hero-signup" id="hero-signup-form" action="#" method="post">
          <div class="signup-content" id="hero-content-layer">
            <div class="signup-row">
              <input
                type="email"
                placeholder="your@email.com"
                required
                class="signup-input"
                aria-label="Email address"
              />
              <button type="submit" class="btn">Join the list →</button>
            </div>
            <p class="signup-meta">
              Free forever with limits. <strong>Pro €8.99</strong> → €11.99 two months after launch.
            </p>
          </div>
          <div class="signup-success" id="hero-success" aria-hidden="true">
            <span class="success-label">You're in.</span>
            <span class="success-sub">We'll email you at launch.</span>
          </div>
        </form>
      </div>
      <div class="hero-right">
        <div class="sun"></div>
        <div class="sun-core"></div>

        <div class="phone">
          <div class="notch"></div>
          <div class="screen">
            <div class="ps-top"><span>9:41 AM</span><span>◐ 82%</span></div>
            <div class="ps-head">
              <h3>Harvest Cardigan</h3>
              <span class="tag">ACTIVE</span>
            </div>
            <div class="ps-counter">
              <div style="display:flex;justify-content:space-between">
                <span class="lbl">ROW</span>
                <span class="lbl">INCREASE · +1</span>
              </div>
              <div class="num" id="rowNum">84</div>
              <div class="of">of 142 · sleeve increases</div>
              <div class="controls">
                <button class="ps-btn" data-dec aria-label="Decrement row">−</button>
                <button class="ps-btn plus" data-inc aria-label="Increment row">+1</button>
              </div>
            </div>
            <div class="ps-side">
              <div class="ps-chip"><span class="k">STITCHES</span><span class="v">126</span></div>
              <div class="ps-chip"><span class="k">REPEAT</span><span class="v">3 / 8</span></div>
            </div>
            <div class="ps-foot">
              <div style="display:flex;align-items:center;gap:8px">
                <span class="dot"></span><span class="t">Session · 42 min</span>
              </div>
              <span class="t">🎙 Listening…</span>
            </div>
            <div class="ps-tabs">
              <span class="on">COUNTER</span><span>PATTERN</span><span>NOTES</span><span>PHOTOS</span>
            </div>
          </div>
        </div>

        <div class="stamp">
          Private<br />by<br />Design<small>No Cloud · No Ads</small>
        </div>
      </div>
    </section>

    <!-- Ticker -->
    <div class="ticker">
      <div class="ticker-track">
        <span>Row counter <span class="dot"></span></span>
        <span>Pattern viewer <span class="dot"></span></span>
        <span>Yarn OCR scanner <span class="dot"></span></span>
        <span>Four calculators <span class="dot"></span></span>
        <span>Ravelry sign-in <span class="dot"></span></span>
        <span>Eleven languages <span class="dot"></span></span>
        <span>Voice commands <span class="dot"></span></span>
        <span>No subscription <span class="dot"></span></span>
        <span>All data on device <span class="dot"></span></span>
        <span>Home-screen widget <span class="dot"></span></span>
        <span>Row counter <span class="dot"></span></span>
        <span>Pattern viewer <span class="dot"></span></span>
        <span>Yarn OCR scanner <span class="dot"></span></span>
        <span>Four calculators <span class="dot"></span></span>
        <span>Ravelry sign-in <span class="dot"></span></span>
        <span>Eleven languages <span class="dot"></span></span>
        <span>Voice commands <span class="dot"></span></span>
        <span>No subscription <span class="dot"></span></span>
      </div>
    </div>

    <!-- Features -->
    <section class="section" id="features">
      <div class="section-head">
        <div class="section-num">Nº 01</div>
        <div class="section-title">Every tool, <em>talking to each other.</em></div>
        <div class="section-kicker">Nine tools · One app</div>
      </div>

      <div class="features">
        {
          features.map((f) => (
            <div class:list={['cell', f.dark && 'dark', f.sage && 'sage']}>
              <div class="k">
                <span>{f.section}</span>
                <span class:list={['pill', f.tier]}>{f.tier === 'pro' ? 'PRO' : 'FREE'}</span>
              </div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
              {f.yarnBall && <div class="yarn-ball" />}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Free browser tools strip -->
    <section class="section" style="padding-top:24px;padding-bottom:0">
      <div class="free-strip">
        <div class="intro">
          <div class="k">§ In your browser</div>
          <h3>Six free tools, no install.</h3>
          <p>Not ready for the app? The calculators and reference charts run right in your browser, free forever.</p>
        </div>
        <div class="links">
          {
            freeBrowserTools.map((t) => (
              <a href={t.href}>
                <span class="n">{t.n} →</span>
                <span class="t">{t.t}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Spread 1: Counter -->
    <section class="spread" id="counter">
      <div class="fig">
        <div
          style="position:absolute;inset:40px;border:1.5px solid var(--ink);display:flex;flex-direction:column;justify-content:space-between;padding:28px;background:var(--paper)"
        >
          <div style="display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.16em">
            <span>ROW</span><span>REPEAT 3/8</span><span>INCREASE +1</span>
          </div>
          <div
            style="font-family:var(--serif);font-size:200px;text-align:center;color:var(--terracotta);line-height:.9;letter-spacing:-.02em"
          >
            84
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">STITCH</div>
              <div style="font-family:var(--serif);font-size:28px">126</div>
            </div>
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center;background:var(--wheat)">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">SHAPE</div>
              <div style="font-family:var(--serif);font-size:28px">12/20</div>
            </div>
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">REPEAT</div>
              <div style="font-family:var(--serif);font-size:28px">3/8</div>
            </div>
          </div>
        </div>
        <div class="cap">FIG. I · THE ROW COUNTER</div>
      </div>
      <div>
        <div class="mono" style="color:var(--terracotta);margin-bottom:12px">§ 02 — The Counter</div>
        <h2>Tap without <em>looking.</em></h2>
        <p class="lead">
          A big round button where your thumb already is. Miscount? Undo. Stitch, shape, and repeat counters run side
          by side. Mark a row with a reminder, and it waits politely until you get there.
        </p>
        <ul class="checklist">
          {
            counterChecklist.map((item) => (
              <li>
                <span class="n">{item.n}</span>
                <span class="t">{item.t}</span>
                <span class="d">{item.d}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Spread 2: Yarn scanner -->
    <section class="spread alt" id="scanner">
      <div>
        <div class="mono" style="color:var(--terracotta);margin-bottom:12px">§ 03 — The Yarn Scanner · Pro</div>
        <h2>Point. Scan. <em>Filed.</em></h2>
        <p class="lead">
          The label graveyard, organised at last. Point the camera at the ball band; the AI reads fiber, weight,
          meters, needle size, gauge, and dye lot. Filed in your stash with a photo of the band itself. That mystery
          skein finally has a name.
        </p>
        <ul class="checklist">
          {
            scannerChecklist.map((item) => (
              <li>
                <span class="n">{item.n}</span>
                <span class="t">{item.t}</span>
                <span class="d">{item.d}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="fig">
        <div
          style="position:absolute;inset:40px;background:var(--paper);border:1.5px solid var(--ink);padding:26px;overflow:hidden"
        >
          <div style="font-family:var(--serif);font-size:28px;font-style:italic;margin-bottom:6px">Drops Karisma</div>
          <div
            style="font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--walnut);margin-bottom:16px"
          >
            — BALL BAND · SCANNED —
          </div>
          <div style="font-family:var(--body);font-size:13px;line-height:1.9;color:var(--ink)">
            <div>Fiber · 100% pure new wool</div>
            <div>Weight · DK · 50 g</div>
            <div>Yardage · 100 m / 110 yd</div>
            <div style="background:linear-gradient(transparent 60%, #C4A66180 60%);padding:2px 0">
              Needles · 4.0 mm (US 6)
            </div>
            <div>Gauge · 21 sts × 28 rows = 10 cm</div>
            <div>Dye lot · 5813</div>
            <div>Care · Machine wash 40°C</div>
          </div>
          <div
            style="position:absolute;right:24px;top:90px;background:var(--wheat);border:1.5px solid var(--ink);padding:6px 10px;font-family:var(--mono);font-size:10px;letter-spacing:.14em;transform:rotate(3deg)"
          >
            SCANNED · FILED
          </div>
        </div>
        <div class="cap">FIG. II · ONE CARD PER SKEIN</div>
      </div>
    </section>

    <!-- Voice & AI -->
    <section class="section" id="voice">
      <div class="section-head">
        <div class="section-num">Nº 04</div>
        <div class="section-title">Hands full? <em>Just talk to it.</em></div>
        <div class="section-kicker">Voice · On-Device · Pro</div>
      </div>

      <div class="voice">
        <h2>Say "<em>next row</em>" and<br />your needles keep moving.</h2>
        <div class="grid">
          <div class="voice-card">
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"Next row."</div>
              <div class="wave"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Row 85. Two more before your sleeve increase.</div>
            </div>
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"What's sl1 k2tog psso?"</div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Slip one, knit two together, pass the slipped stitch over. A left-leaning double decrease.</div>
            </div>
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"Add three. How many rows until the neckline?"</div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Row 88. Forty-two rows until the neckline. <em>Carry on.</em></div>
            </div>
          </div>
          <div class="bullets">
            {
              voiceBullets.map((b) => (
                <div class="b">
                  <div class="n">{b.n}</div>
                  <div class="t">{b.t}</div>
                  <div class="d">{b.d}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Insights -->
    <section class="section" id="insights">
      <div class="section-head">
        <div class="section-num">Nº 05</div>
        <div class="section-title">Your numbers, <em>without the pressure.</em></div>
        <div class="section-kicker">Insights · Pro</div>
      </div>

      <div class="insights">
        <div class="col" style="display:grid;gap:16px">
          <div class="row">
            <div class="stat-card">
              <span class="k">Total Time</span>
              <span class="v">128<span style="font-size:28px;color:var(--walnut)">h</span></span>
              <span class="u">Since January</span>
            </div>
            <div class="stat-card">
              <span class="k">Pace</span>
              <span class="v">42<span style="font-size:28px;color:var(--walnut)">/hr</span></span>
              <span class="u">Rows per hour</span>
            </div>
          </div>
          <div class="row">
            <div class="stat-card">
              <span class="k">Streak</span>
              <span class="v">14<span style="font-size:28px;color:var(--walnut)">d</span></span>
              <span class="u">Daily knit</span>
            </div>
            <div
              class="stat-card"
              style="background:var(--terracotta);color:var(--paper);border-color:var(--terracotta)"
            >
              <span class="k" style="color:rgba(244,234,217,.85)">Active Projects</span>
              <span class="v" style="color:var(--paper)">3</span>
              <span class="u" style="color:rgba(244,234,217,.85)">Cardigan · Socks · Hat</span>
            </div>
          </div>
        </div>
        <div class="col" style="display:grid;gap:16px">
          <div class="chart">
            <div class="title">PACE OVER TIME · ROWS / HOUR</div>
            <svg viewBox="0 0 400 160" preserveAspectRatio="none">
              <defs>
                <linearGradient id="paceGrad" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0" stop-color="#A05038" stop-opacity=".5" />
                  <stop offset="1" stop-color="#A05038" stop-opacity="0" />
                </linearGradient>
              </defs>
              <g stroke="#2A1E17" stroke-opacity=".15">
                <line x1="0" y1="40" x2="400" y2="40" />
                <line x1="0" y1="80" x2="400" y2="80" />
                <line x1="0" y1="120" x2="400" y2="120" />
              </g>
              <path
                d="M0,120 C40,110 60,90 90,80 S150,50 190,60 S250,100 290,70 S350,30 400,40 L400,160 L0,160 Z"
                fill="url(#paceGrad)"
              ></path>
              <path
                d="M0,120 C40,110 60,90 90,80 S150,50 190,60 S250,100 290,70 S350,30 400,40"
                fill="none"
                stroke="#A05038"
                stroke-width="2.5"
              ></path>
              <g fill="#5B8072">
                <circle cx="90" cy="80" r="3.5"></circle>
                <circle cx="190" cy="60" r="3.5"></circle>
                <circle cx="290" cy="70" r="3.5"></circle>
                <circle cx="400" cy="40" r="3.5"></circle>
              </g>
            </svg>
          </div>
          <div>
            <div
              style="font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--walnut);text-transform:uppercase;margin-bottom:8px"
            >
              Weekday Heatmap · Last 20 Weeks
            </div>
            <div class="heatmap">
              {
                Array.from({ length: heatmapCells }).map((_, i) => {
                  const v = heatmapSeed[i % heatmapSeed.length];
                  const cls = heatmapLevels[v];
                  return cls ? <div class={cls} /> : <div />;
                })
              }
            </div>
          </div>
        </div>
      </div>
      <p
        style="margin:28px 0 0;font-family:var(--body);font-size:15px;color:var(--ink-soft);font-style:italic;max-width:640px"
      >
        No leaderboards. No nudges. No comparing yourself to anyone else. The stats are yours, and they stay on your
        phone.
      </p>
    </section>

    <!-- Pricing -->
    <section class="section" id="pricing">
      <div class="section-head">
        <div class="section-num">Nº 06</div>
