---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import PullQuote from '../components/PullQuote.astro';
import NineTools from '../components/NineTools.astro';
import FreeToolsCallout from '../components/FreeToolsCallout.astro';
import TrustSection from '../components/TrustSection.astro';
import PricingCards from '../components/PricingCards.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { getPrice, getStructuredPrice } from '../config/pricing';

const structuredPrice = getStructuredPrice();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'KnitTools',
  operatingSystem: 'Android',
  applicationCategory: 'LifestyleApplication',
  description:
    'A private, on-device knitting toolkit for Android. Row counter, pattern viewer, yarn scanner, calculators, Ravelry integration.',
  offers: {
    '@type': 'Offer',
    price: structuredPrice.price,
    priceCurrency: structuredPrice.priceCurrency,
    availability: 'https://schema.org/PreOrder',
  },
  inLanguage: ['en', 'fi', 'sv', 'da', 'nb', 'nl', 'de', 'fr', 'it', 'pt', 'es'],
};
---

<PageLayout
  title="KnitTools: Every Tool a Knitter Needs. One App."
  browserTitle="KnitTools"
  description={`A private, on-device knitting toolkit for Android. Row counter, pattern viewer, yarn scanner, calculators. Pay once, ${getPrice('launch')}. No subscription, no ads, no cloud.`}
  canonicalPath="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

  <Hero />
  <Marquee />
  <NineTools />
  <FreeToolsCallout />
  <TrustSection />
  <PullQuote
    quote="One tool for every row. One price for every needle. One app for every project."
  />
  <PricingCards />
  <ClosingCTA />
</PageLayout>
