---
import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import PullQuote from "../components/PullQuote.astro";
import NineTools from "../components/NineTools.astro";
import FreeToolsCallout from "../components/FreeToolsCallout.astro";
import TrustSection from "../components/TrustSection.astro";
import PricingCards from "../components/PricingCards.astro";
import ClosingCTA from "../components/ClosingCTA.astro";
import { getStructuredPrice } from "../config/pricing";
import {
  CONTACT_MAILTO,
  FINNVEK_URL,
  ORGANIZATION_ID,
  SOCIAL_PROFILE_URLS,
  SOFTWARE_APPLICATION_ID,
  SITE_URL,
} from "../config/brand";

const structuredPrice = getStructuredPrice();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": ORGANIZATION_ID,
      name: "Finnvek",
      url: FINNVEK_URL,
      email: CONTACT_MAILTO,
      sameAs: SOCIAL_PROFILE_URLS,
    },
    {
      "@type": "SoftwareApplication",
      "@id": SOFTWARE_APPLICATION_ID,
      name: "KnitTools",
      url: `${SITE_URL}/`,
      operatingSystem: "Android",
      applicationCategory: "LifestyleApplication",
      publisher: {
        "@id": ORGANIZATION_ID,
      },
      description:
        "An all-in-one knitting toolkit for Android. Row counter, pattern viewer, four calculators, Ravelry integration, project notes, progress photos, project stats, and a home-screen counter widget. One-time purchase, no subscription.",
      offers: {
        "@type": "Offer",
        price: structuredPrice.price,
        priceCurrency: structuredPrice.priceCurrency,
      },
      inLanguage: [
        "en",
        "fi",
        "sv",
        "da",
        "nb",
        "nl",
        "de",
        "fr",
        "it",
        "pt",
        "es",
      ],
    },
  ],
};
---

<PageLayout
  title="KnitTools: Rows, Patterns, Projects in One Android App"
  browserTitle="KnitTools: Rows, Patterns, Projects in One Android App"
  description="KnitTools is an Android knitting app with row counters, pattern viewer, calculators, Ravelry, project notes, progress photos, stats, widget and 14-day trial."
  canonicalPath="/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <Hero />
  <Marquee />
  <NineTools />
  <FreeToolsCallout />
  <TrustSection />
  <PullQuote
    quote="One tool for every row. One price for every needle. One app for every project."
  />
  <PricingCards />
  <ClosingCTA />
</PageLayout>
