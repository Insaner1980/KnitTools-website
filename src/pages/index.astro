  <script is:inline>
    (() => {
      const rowEl = document.getElementById('rowNum');
      if (rowEl) {
        let row = 84;
        const flash = () => {
          rowEl.animate(
            [{ transform: 'scale(1)' }, { transform: 'scale(1.08)' }, { transform: 'scale(1)' }],
            { duration: 220 }
          );
        };
        document.querySelector('[data-inc]')?.addEventListener('click', () => {
          row++;
          rowEl.textContent = row;
          flash();
        });
        document.querySelector('[data-dec]')?.addEventListener('click', () => {
          row = Math.max(0, row - 1);
          rowEl.textContent = row;
        });
      }

      const form = document.getElementById('hero-signup-form');
      const content = document.getElementById('hero-content-layer');
      const success = document.getElementById('hero-success');
      if (form && content && success) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          content.style.display = 'none';
          success.style.display = 'flex';
          success.setAttribute('aria-hidden', 'false');
        });
      }
    })();
  </script>

