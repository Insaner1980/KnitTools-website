---
import PageLayout from "../layouts/PageLayout.astro";

const recoveryLinks = [
  {
    label: "Home",
    href: "/",
    title: "KnitTools home",
    text: "Return to the app landing page.",
  },
  {
    label: "Tools",
    href: "/tools/",
    title: "Free knitting tools",
    text: "Open calculators, size charts, abbreviations, and yarn references.",
  },
  {
    label: "Articles",
    href: "/articles/",
    title: "Knitting articles",
    text: "Browse guides for gauge, yarn, needles, techniques, and app tools.",
  },
];
---

<PageLayout
  title="Page Not Found"
  description="The page could not be found. Return to KnitTools tools, articles, and Android knitting app information from the home page."
  canonicalPath="/404"
  bodyClass="not-found-page"
>
  <section class="not-found-hero" aria-labelledby="not-found-heading">
    <div class="not-found-copy">
      <p class="eyebrow">404</p>
      <h1 id="not-found-heading">This page is off the needles.</h1>
      <p class="lede">
        The page you were looking for is not available at this address. You can
        return to KnitTools, open the free knitting tools, or browse the
        knitting articles.
      </p>
      <a href="/" class="primary-link">Back to KnitTools</a>
    </div>

    <nav class="recovery-panel" aria-label="Helpful links">
      <p class="panel-label">Try one of these instead</p>
      <div class="recovery-links">
        {
          recoveryLinks.map((link) => (
            <a href={link.href} class="recovery-link">
              <span class="link-content">
                <span class="link-label">{link.label}</span>
                <span class="link-title">{link.title}</span>
                <span class="link-text">{link.text}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
    </nav>
  </section>
</PageLayout>

<style>
  :global(body.not-found-page) {
    background-color: var(--paper);
  }

  .not-found-hero {
    position: relative;
    min-height: calc(100vh - 80px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 560px);
    align-items: center;
    gap: clamp(48px, 7vw, 120px);
    padding: 116px 48px 96px;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
  }

  .not-found-copy,
  .recovery-panel {
    position: relative;
    z-index: 1;
  }

  .not-found-copy {
    max-width: 820px;
  }

  .eyebrow {
    margin-bottom: 18px;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
  }

  h1 {
    max-width: 760px;
    font-family: var(--serif);
    font-size: clamp(3.25rem, 8vw, 7.5rem);
    font-weight: 400;
    line-height: 0.9;
    color: var(--ink);
    text-transform: none;
  }

  .lede {
    max-width: 560px;
    margin-top: 26px;
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .primary-link {
    display: inline-flex;
    align-items: center;
    min-height: 48px;
    margin-top: 34px;
    border: 1.5px solid var(--ink);
    padding: 12px 22px;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .primary-link:hover,
  .primary-link:focus-visible {
    background-color: var(--ink);
    color: var(--paper);
  }

  .recovery-panel {
    align-self: stretch;
    display: grid;
    align-content: center;
    gap: 26px;
    border: 2px solid var(--ink);
    padding: clamp(30px, 4vw, 48px);
    background-color: transparent;
  }

  .panel-label {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .recovery-links {
    display: grid;
    border-top: 1.5px solid var(--ink);
  }

  .recovery-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 104px;
    padding: 20px 0;
    border-bottom: 1.5px solid var(--ink);
    color: var(--ink);
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .link-content {
    display: grid;
    gap: 8px;
  }

  .recovery-link:hover,
  .recovery-link:focus-visible {
    background-color: var(--ink);
    color: var(--paper);
    padding-inline: 16px;
  }

  .link-label {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--terracotta);
  }

  .link-title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 0.95;
    color: inherit;
  }

  .link-arrow {
    flex: 0 0 auto;
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1;
  }

  .link-text {
    max-width: 300px;
    font-family: var(--body-ed);
    font-size: 15px;
    line-height: 1.45;
    color: inherit;
  }

  @media (max-width: 980px) {
    .not-found-hero {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 72px 24px 80px;
    }

    .recovery-panel {
      max-width: 680px;
    }
  }

  @media (max-width: 640px) {
    .not-found-hero {
      min-height: auto;
      padding: 56px 20px 72px;
    }

    h1 {
      font-size: clamp(2.8rem, 16vw, 5rem);
    }

    .recovery-link {
      min-height: 108px;
    }

    .link-arrow {
      display: none;
    }
  }
</style>
