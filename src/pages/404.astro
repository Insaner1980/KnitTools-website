---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Page Not Found"
  description="This KnitTools page could not be found."
  canonicalPath="/404"
>
  <section class="not-found" aria-labelledby="not-found-heading">
    <p class="eyebrow">404</p>
    <h1 id="not-found-heading">Page not found.</h1>
    <p>The page may have moved, or the link may be out of date.</p>
    <a href="/" class="home-link">Back to KnitTools</a>
  </section>
</PageLayout>

<style>
  .not-found {
    min-height: 56vh;
    display: grid;
    align-content: center;
    gap: 18px;
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 24px;
    color: var(--ink);
  }

  .eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    line-height: 0.95;
  }

  p {
    max-width: 480px;
    font-family: var(--body-ed);
    font-size: 18px;
    color: var(--ink-soft);
  }

  .home-link {
    justify-self: start;
    margin-top: 14px;
    border: 1.5px solid var(--ink);
    padding: 12px 18px;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-link:hover {
    background: var(--ink);
    color: var(--paper);
  }
</style>
