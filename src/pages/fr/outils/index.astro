---
import ToolsIndexPage from "../../../components/ToolsIndexPage.astro";
import { routes } from "../../../i18n/routes";

const tools = [
  {
    tag: "Mailles",
    title: "Calculateur de mailles à monter",
    description:
      "Calcule combien de mailles monter pour une largeur et un échantillon donnés.",
    href: routes.tool.castOnCalculator.fr,
    className: "card-terracotta card-top-left",
  },
  {
    tag: "Métrage",
    title: "Estimateur de quantité de laine",
    description:
      "Estime la quantité de fil selon le type de projet, la taille et l'épaisseur du fil.",
    href: routes.tool.yarnEstimator.fr,
    className: "card-rust card-top-right",
  },
  {
    tag: "Épaisseurs",
    title: "Épaisseurs de fil",
    description: "Les catégories de fil, avec échantillon, aiguilles et WPI.",
    href: routes.tool.yarnWeightChart.fr,
    className: "card-sand card-bl1",
  },
  {
    tag: "Aiguilles",
    title: "Tailles d'aiguilles",
    description:
      "Convertis les tailles d'aiguilles US, UK, métriques et japonaises.",
    href: routes.tool.needleSizeChart.fr,
    className: "card-teal card-br1",
  },
  {
    tag: "Tailles",
    title: "Tableaux de tailles tricot",
    description:
      "Mensurations bébé, enfant et adulte en cm, avec équivalences en pouces dans le tableau.",
    href: routes.tool.knittingSizeCharts.fr,
    className: "card-terracotta card-bl2",
  },
  {
    tag: "Glossaire",
    title: "Abréviations tricot",
    description:
      "Cherche une abréviation ou retrouve les termes par technique.",
    href: routes.tool.knittingAbbreviations.fr,
    className: "card-brown card-br2",
  },
];
---

<ToolsIndexPage
  title="Outils tricot gratuits : calculateurs et tableaux"
  description="Calculateurs et tableaux tricot gratuits en ligne : mailles à monter, quantité de laine, tailles d'aiguilles, épaisseurs de fil, abréviations et mensurations."
  canonicalPath={routes.toolsIndex.fr}
  lang="fr"
  alternates={routes.toolsIndex}
  collectionName="Outils tricot gratuits"
  collectionDescription="Calculateurs et tableaux tricot gratuits en ligne."
  eyebrow="Outils gratuits"
  heading="Outils tricot en ligne."
  intro="Calculateurs et tableaux de référence pour tes projets tricot. Pas de compte, pas d'application à installer."
  tools={tools}
/>
