---
import EditorialLayout from '../layouts/EditorialLayout.astro';

const features = [
  {
    tall: true,
    section: '§ Counter',
    badge: 'FREE',
    title: 'A row counter sized for the couch.',
    body:
      'One hundred and ten scaled pixels of count, readable from across the room. A stitch counter sits alongside. Session history quietly accrues in the background.',
    yarnBall: true,
  },
  {
    section: '§ Library',
    badge: 'FREE',
    title: 'Patterns, in a pocket.',
    body:
      'Save Ravelry patterns, import PDFs, and keep a gallery of project photos that spans all your works-in-progress.',
  },
  {
    sage: true,
    section: '§ Yarn Stash',
    badge: 'FREE',
    title: 'A cabinet of yarn cards.',
    body:
      'Brand, colour, fiber, weight and yardage — one card for every skein you own, searchable and cross-referenced.',
  },
  {
    section: '§ Tools',
    badge: 'FREE',
    title: "Gauge, cast-on, and the math you'd rather avoid.",
    body:
      'Gauge, increases and decreases (flat or in the round), cast-on helpers, yarn estimators, and a reference drawer of symbols and sizes.',
  },
  {
    dark: true,
    section: '§ Ravelry',
    badge: 'FREE',
    title: 'Signed in. Nothing else shared.',
    body:
      'Search, browse, save, and link a Ravelry pattern to your project. Open in the built-in PDF viewer, or kick it out to your browser.',
  },
  {
    section: '§ Themes',
    badge: 'FREE',
    title: '"70s Craft Revival."',
    body:
      'Light and dark palettes drawn from terracotta, sage, and wheat. Or follow the system — whichever suits the evening.',
  },
];

const counterChecklist = [
  { n: 'i', t: 'Multiple counters per project', d: 'Stitch · Shape · Repeat' },
  { n: 'ii', t: 'Automatic shaping increases', d: 'Every N rows' },
  { n: 'iii', t: 'Repeat section tracker', d: '3 / 8' },
  { n: 'iv', t: 'Row reminders with messages', d: '"Join sleeve"' },
  { n: 'v', t: 'Progress photos, row-tagged', d: 'Timestamped' },
  { n: 'vi', t: 'Project notes, full-screen', d: 'Markdown' },
];

const patternChecklist = [
  { n: 'i', t: 'Camera-scan to PDF', d: 'OCR + Deskew' },
  { n: 'ii', t: 'Row-by-row annotations', d: 'Persistent' },
  { n: 'iii', t: 'Gemini Nano row mapping', d: 'On-device · ML Kit' },
  { n: 'iv', t: 'Full project history', d: 'Every session logged' },
];

const voiceBullets = [
  {
    n: 'i',
    t: 'Voice commands, English & Finnish',
    d: 'Increment, decrement, set row, undo. Number recognition up to 100. No wake word beyond the mic tap.',
  },
  {
    n: 'ii',
    t: 'Live voice conversation',
    d: "The AI knows which project you're in, where you are in the pattern, and how far you've gone today.",
  },
  {
    n: 'iii',
    t: 'AI journal entries',
    d: 'Mumble into the mic; it tidies a timestamped, row-tagged entry. Speech rings out in locale-aware TTS.',
  },
  {
    n: 'iv',
    t: 'On-device pattern parsing',
    d: "Row mapping assisted by Gemini Nano via ML Kit's GenAI Prompt API. The page never leaves your phone.",
  },
];

const languages = [
  'English',
  'Suomi',
  'Svenska',
  'Deutsch',
  'Français',
  'Español',
  'Português',
  'Italiano',
  'Norsk',
  'Dansk',
  'Nederlands',
];

const patternLines = [
  'Row 82 · Knit across, place marker, k to end of round. (126 sts)',
  'Row 83 · K1, m1r, knit to last st, m1l, k1. (128 sts)',
  'Row 84 · Knit even. — shaping increase every 6th row',
  'Row 85 · K1, m1r, k to 1 st before marker, m1l, sm, knit.',
  'Row 86–88 · Knit even. Check gauge: 22 sts × 28 rows = 4".',
  'Row 89 · Rep increase row. (132 sts)',
  'Row 90 · Pm for sleeve cap, knit even.',
];

const heatmapSeed = [
  2, 0, 1, 3, 4, 2, 1, 0, 1, 2, 2, 3, 4, 3, 1, 0, 1, 2, 4, 4, 3, 0, 0, 1, 1, 2, 3, 2, 2, 2, 3, 4, 4, 3, 2, 1, 1, 2, 3,
  3, 2, 1, 0, 1, 2, 2, 3, 4, 3, 2, 3, 3, 4, 4, 4, 3, 1, 2, 2, 3, 3, 2, 1, 0, 0, 1, 2, 3, 3, 2, 2, 2, 3, 4, 4, 3, 2, 1,
  0, 1, 2, 3, 4, 3, 0, 1, 2, 3, 3, 2, 1, 2, 3, 3, 4, 4, 3, 2, 1, 1, 2, 2, 3, 3, 2, 0, 0, 1, 2, 3, 4, 3, 2, 2, 3, 3, 4,
  4, 3, 1, 2, 3, 4, 4, 3, 2, 0, 1, 2, 3, 3, 2, 1, 1, 2, 2, 3, 4, 4, 3,
];
const heatmapLevels = ['', 'l1', 'l2', 'l3', 'l4'];
const heatmapCells = 20 * 7;
---

<EditorialLayout>
  <div class="page">
    <!-- Masthead -->
    <header>
      <div class="sub-mast">
        <div class="bit mono">Vol. 01 · Issue 07</div>
        <div class="bit center mono">Spring Edition · MMXXVI</div>
        <div class="bit center mono">"Knit one, purl two."</div>
        <div class="bit right mono">€8.99 · Android</div>
        <div class="bit right mono">Trial — 14 days</div>
      </div>
      <hr class="thin" style="margin:10px 0 0" />
      <div class="masthead">
        <div class="left mono"><span>EST.</span><span class="dot"></span><span>2026</span></div>
        <div class="wordmark">Knit<em class="amp">&amp;</em><span class="small">Tools</span></div>
        <div class="right mono"><span>NO. 07</span><span class="dot"></span><span>€8.99</span></div>
      </div>
      <div class="double"></div>
      <nav class="top">
        <a href="#features">The Features</a>
        <span class="sep">◆</span>
        <a href="#pro">Pro, Unlocked</a>
        <span class="sep">◆</span>
        <a href="#voice">Voice &amp; AI</a>
        <span class="sep">◆</span>
        <a href="#insights">Your Numbers</a>
        <span class="sep">◆</span>
        <a href="#pricing">Pricing</a>
        <span class="sep">◆</span>
        <a href="#privacy">Privacy</a>
      </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div>
        <div class="issue-tag"><span class="square"></span> Feature · On the cover · Issue Seven</div>
        <h1 class="display">
          A quiet<br />companion<br /><em>for the</em> <span class="knot"></span> <em>long</em><br />row ahead.
        </h1>
        <p class="dek">
          KnitTools is a private, on-device knitting studio for Android — a row counter that listens, a pattern viewer
          that reads, a yarn stash that remembers. No subscriptions. No accounts. Nothing leaves your phone unless you
          ask it to.
        </p>
        <div class="hero-meta">
          <a class="btn" href="#pricing">Get it on Google Play →</a>
          <a class="btn ghost" href="#voice">Watch the Walkthrough</a>
          <div class="price-chip">
            <span class="n">€8.99</span>
            <span class="l">Introductory · One-time</span>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="sun"></div>
        <div class="sun-core"></div>

        <div class="phone">
          <div class="notch"></div>
          <div class="screen">
            <div class="ps-top"><span>9:41 AM</span><span>◐ 82%</span></div>
            <div class="ps-head">
              <h3>Harvest Cardigan</h3>
              <span class="tag">ACTIVE</span>
            </div>
            <div class="ps-counter">
              <div style="display:flex;justify-content:space-between">
                <span class="lbl">ROW</span>
                <span class="lbl">SHAPING · +1</span>
              </div>
              <div class="num" id="rowNum">84</div>
              <div class="of">of 142 · sleeve increases</div>
              <div class="controls">
                <button class="ps-btn" data-dec aria-label="Decrement row">−</button>
                <button class="ps-btn plus" data-inc aria-label="Increment row">+1</button>
              </div>
            </div>
            <div class="ps-side">
              <div class="ps-chip"><span class="k">STITCHES</span><span class="v">126</span></div>
              <div class="ps-chip"><span class="k">REPEAT</span><span class="v">3 / 8</span></div>
            </div>
            <div class="ps-foot">
              <div style="display:flex;align-items:center;gap:8px">
                <span class="dot"></span><span class="t">Session · 42 min</span>
              </div>
              <span class="t">🎙 Listening…</span>
            </div>
            <div class="ps-tabs">
              <span class="on">COUNTER</span><span>PATTERN</span><span>NOTES</span><span>PHOTOS</span>
            </div>
          </div>
        </div>

        <div class="stamp">
          Private<br />by<br />Design<small>No Cloud · No Ads</small>
        </div>
      </div>
    </section>

    <!-- Ticker -->
    <div class="ticker">
      <div class="ticker-track">
        <span>Eleven languages <span class="dot"></span></span>
        <span>Shaping counter <span class="dot"></span></span>
        <span>Voice commands <span class="dot"></span></span>
        <span>Yarn OCR scanning <span class="dot"></span></span>
        <span>Ravelry sign-in <span class="dot"></span></span>
        <span>No subscriptions <span class="dot"></span></span>
        <span>All data on device <span class="dot"></span></span>
        <span>Home-screen glance widget <span class="dot"></span></span>
        <span>Eleven languages <span class="dot"></span></span>
        <span>Shaping counter <span class="dot"></span></span>
        <span>Voice commands <span class="dot"></span></span>
        <span>Yarn OCR scanning <span class="dot"></span></span>
        <span>Ravelry sign-in <span class="dot"></span></span>
        <span>No subscriptions <span class="dot"></span></span>
        <span>All data on device <span class="dot"></span></span>
        <span>Home-screen glance widget <span class="dot"></span></span>
      </div>
    </div>

    <!-- Features -->
    <section class="section" id="features">
      <div class="section-head">
        <div class="section-num">Nº 01</div>
        <div class="section-title">The Features, <em>briefly</em>.</div>
        <div class="section-kicker">Free Core · Every Install</div>
      </div>

      <div class="features">
        {
          features.map((f) => (
            <div
              class:list={[
                'cell',
                f.tall && 'tall',
                f.dark && 'dark',
                f.sage && 'sage',
              ]}
            >
              <div class="k">
                <span>{f.section}</span>
                <span class="pill">{f.badge}</span>
              </div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
              {f.yarnBall && <div class="yarn-ball" />}
            </div>
          ))
        }
      </div>
    </section>

    <!-- Spread 1: Advanced counter -->
    <section class="spread" id="pro">
      <div class="fig">
        <div
          style="position:absolute;inset:40px;border:1.5px solid var(--ink);display:flex;flex-direction:column;justify-content:space-between;padding:28px;background:var(--paper)"
        >
          <div style="display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.16em">
            <span>ROW</span><span>REPEAT 3/8</span><span>SHAPING +1</span>
          </div>
          <div
            style="font-family:var(--serif);font-size:200px;text-align:center;color:var(--terracotta);line-height:.9;letter-spacing:-.02em"
          >
            84
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">STITCH</div>
              <div style="font-family:var(--serif);font-size:28px">126</div>
            </div>
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center;background:var(--wheat)">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">SHAPE</div>
              <div style="font-family:var(--serif);font-size:28px">12/20</div>
            </div>
            <div style="border:1.5px solid var(--ink);padding:10px;text-align:center">
              <div style="font-family:var(--mono);font-size:9px;letter-spacing:.14em">REPEAT</div>
              <div style="font-family:var(--serif);font-size:28px">3/8</div>
            </div>
          </div>
        </div>
        <div class="cap">FIG. I · THE ADVANCED COUNTER</div>
      </div>
      <div>
        <div class="mono" style="color:var(--terracotta);margin-bottom:12px">§ 02 — Pro, Unlocked</div>
        <h2>Three counters, <em>one row.</em></h2>
        <p class="lead">
          Keep the stitch, the shaping, and the repeat running side by side. Tell it the interval; it increments for
          you. Mark a row with a reminder, and it waits politely until you get there.
        </p>
        <ul class="checklist">
          {
            counterChecklist.map((item) => (
              <li>
                <span class="n">{item.n}</span>
                <span class="t">{item.t}</span>
                <span class="d">{item.d}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- Spread 2: Pattern viewer -->
    <section class="spread alt">
      <div>
        <div class="mono" style="color:var(--terracotta);margin-bottom:12px">§ 03 — Pattern Viewer</div>
        <h2>Point. Scan. <em>Knit.</em></h2>
        <p class="lead">
          Turn the paper pattern your grandmother photocopied in 1978 into a searchable, annotatable PDF. Row-by-row
          marks stay where you left them. The AI, running on-device, maps instructions into rows so the counter knows
          where you are.
        </p>
        <ul class="checklist">
          {
            patternChecklist.map((item) => (
              <li>
                <span class="n">{item.n}</span>
                <span class="t">{item.t}</span>
                <span class="d">{item.d}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="fig">
        <div
          style="position:absolute;inset:40px;background:var(--paper);border:1.5px solid var(--ink);padding:26px;overflow:hidden"
        >
          <div style="font-family:var(--serif);font-size:28px;font-style:italic;margin-bottom:6px">Harvest Cardigan</div>
          <div
            style="font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--walnut);margin-bottom:16px"
          >
            — SLEEVE · INCREASES —
          </div>
          <div style="font-family:var(--body);font-size:13px;line-height:1.7;color:var(--ink)">
            {
              patternLines.map((line, i) => (
                <div
                  style={i === 2
                    ? 'background:linear-gradient(transparent 60%, #C4A66180 60%);padding:2px 0'
                    : 'padding:2px 0'}
                >
                  {line}
                </div>
              ))
            }
          </div>
          <div
            style="position:absolute;right:24px;top:90px;background:var(--wheat);border:1.5px solid var(--ink);padding:6px 10px;font-family:var(--mono);font-size:10px;letter-spacing:.14em;transform:rotate(3deg)"
          >
            SCANNED · ROW 84
          </div>
        </div>
        <div class="cap">FIG. II · PATTERN, DIGITIZED</div>
      </div>
    </section>

    <!-- Voice & AI -->
    <section class="section" id="voice">
      <div class="section-head">
        <div class="section-num">Nº 04</div>
        <div class="section-title">Hands full? <em>Just talk to it.</em></div>
        <div class="section-kicker">Voice · Journal · On-Device</div>
      </div>

      <div class="voice">
        <h2>Say "<em>next row</em>" and<br />your needles keep moving.</h2>
        <div class="grid">
          <div class="voice-card">
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"Next row."</div>
              <div class="wave"><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Row 85. Two more before your sleeve increase.</div>
            </div>
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"Set row to 100, undo, how many rows until the neckline?"</div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Forty-two rows. You're 6 rows per hour today — about seven hours at this pace.</div>
            </div>
            <div class="voice-line you">
              <div class="av">YOU</div>
              <div class="msg">"Journal entry: switched to size 5 needles, gauge feels right."</div>
            </div>
            <div class="voice-line ai">
              <div class="av">AI</div>
              <div class="msg">Saved at row 84. <em>Tidied.</em></div>
            </div>
          </div>
          <div class="bullets">
            {
              voiceBullets.map((b) => (
                <div class="b">
                  <div class="n">{b.n}</div>
                  <div class="t">{b.t}</div>
                  <div class="d">{b.d}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Insights -->
    <section class="section" id="insights">
      <div class="section-head">
        <div class="section-num">Nº 05</div>
        <div class="section-title">Your numbers, <em>quietly kept.</em></div>
        <div class="section-kicker">Insights · Pro</div>
      </div>

      <div class="insights">
        <div class="col" style="display:grid;gap:16px">
          <div class="row">
            <div class="stat-card">
              <span class="k">Total Time</span>
              <span class="v">128<span style="font-size:28px;color:var(--walnut)">h</span></span>
              <span class="u">Since January</span>
            </div>
            <div class="stat-card">
              <span class="k">Pace</span>
              <span class="v">42<span style="font-size:28px;color:var(--walnut)">/hr</span></span>
              <span class="u">Rows per hour</span>
            </div>
          </div>
          <div class="row">
            <div class="stat-card">
              <span class="k">Streak</span>
              <span class="v">14<span style="font-size:28px;color:var(--walnut)">d</span></span>
              <span class="u">Daily knit</span>
            </div>
            <div
              class="stat-card"
              style="background:var(--terracotta);color:var(--paper);border-color:var(--terracotta)"
            >
              <span class="k" style="color:rgba(244,234,217,.85)">Active Projects</span>
              <span class="v" style="color:var(--paper)">3</span>
              <span class="u" style="color:rgba(244,234,217,.85)">Cardigan · Socks · Hat</span>
            </div>
          </div>
        </div>
        <div class="col" style="display:grid;gap:16px">
          <div class="chart">
            <div class="title">PACE OVER TIME · ROWS / HOUR</div>
            <svg viewBox="0 0 400 160" preserveAspectRatio="none">
              <defs>
                <linearGradient id="paceGrad" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0" stop-color="#A05038" stop-opacity=".5" />
                  <stop offset="1" stop-color="#A05038" stop-opacity="0" />
                </linearGradient>
              </defs>
              <g stroke="#2A1E17" stroke-opacity=".15">
                <line x1="0" y1="40" x2="400" y2="40" />
                <line x1="0" y1="80" x2="400" y2="80" />
                <line x1="0" y1="120" x2="400" y2="120" />
              </g>
              <path
                d="M0,120 C40,110 60,90 90,80 S150,50 190,60 S250,100 290,70 S350,30 400,40 L400,160 L0,160 Z"
                fill="url(#paceGrad)"
              ></path>
              <path
                d="M0,120 C40,110 60,90 90,80 S150,50 190,60 S250,100 290,70 S350,30 400,40"
                fill="none"
                stroke="#A05038"
                stroke-width="2.5"
              ></path>
              <g fill="#5B8072">
                <circle cx="90" cy="80" r="3.5"></circle>
                <circle cx="190" cy="60" r="3.5"></circle>
                <circle cx="290" cy="70" r="3.5"></circle>
                <circle cx="400" cy="40" r="3.5"></circle>
              </g>
            </svg>
          </div>
          <div>
            <div
              style="font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--walnut);text-transform:uppercase;margin-bottom:8px"
            >
              Weekday Heatmap · Last 20 Weeks
            </div>
            <div class="heatmap">
              {
                Array.from({ length: heatmapCells }).map((_, i) => {
                  const v = heatmapSeed[i % heatmapSeed.length];
                  const cls = heatmapLevels[v];
                  return cls ? <div class={cls} /> : <div />;
                })
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="section" id="pricing">
      <div class="section-head">
        <div class="section-num">Nº 06</div>
        <div class="section-title">One price, <em>once.</em></div>
        <div class="section-kicker">Pricing · No Subscription</div>
      </div>

      <div class="pricing">
        <div class="plan">
          <h3>Core</h3>
          <div class="price"><span class="big">Free</span></div>
          <p style="margin:0;color:var(--ink-soft)">
            Projects, counter, library, yarn stash, tools, Ravelry sign-in, and themes. Yours forever, with every
            install.
          </p>
          <ul>
            <li>Row counter + session history</li>
            <li>Unlimited projects</li>
            <li>Gauge · Cast-on · Increase calculators</li>
            <li>Ravelry pattern search &amp; linking</li>
            <li>Eleven languages</li>
          </ul>
          <a class="btn ghost cta" style="margin-top:18px" href="#">Install, Free →</a>
        </div>

        <div class="plan pro">
          <div class="tag">LAUNCH PRICE</div>
          <h3>Pro</h3>
          <div class="price">
            <span class="cur">€</span><span class="big">8</span><span class="cur">.99</span>
            <span class="strike">€11.99</span>
          </div>
          <p style="margin:0;color:rgba(244,234,217,.9)">
            A single, one-time unlock. 14 days free, full access. After launch, returns to €11.99 — permanently.
          </p>
          <ul>
            <li>Multi-counter · shaping · repeat tracker</li>
            <li>Voice commands (EN · FI) + live AI assistant</li>
            <li>Camera-scan patterns &amp; row mapping</li>
            <li>OCR yarn-label scanning · unlimited stash</li>
            <li>Insights, streaks, pace-over-time</li>
            <li>Home-screen glance widget</li>
          </ul>
          <a
            class="btn cta"
            style="background:var(--paper);color:var(--ink);border-color:var(--paper);margin-top:18px"
            href="#"
          >
            Start 14-day Trial →
          </a>
        </div>
      </div>
    </section>

    <!-- Privacy -->
    <section class="section" id="privacy" style="padding-top:40px">
      <div class="privacy">
        <div class="lead">
          <div class="k">§ Privacy</div>
          <h4>Everything stays on the phone.</h4>
          <p>
            No accounts. No cloud sync. No ads. No tracking. KnitTools reads from your device and writes to your device
            — that's the whole architecture.
          </p>
        </div>
        <div>
          <div class="k">AI Requests</div>
          <h4>Only when you ask.</h4>
