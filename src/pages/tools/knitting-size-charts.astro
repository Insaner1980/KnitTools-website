<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Tab switching ---
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.panel');

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabButtons.forEach(b => {
        const isActive = b.dataset.tab === target;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach(p => {
        const isActive = p.dataset.panel === target;
        p.classList.toggle('is-active', isActive);
        if (isActive) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
    });
  });

  // --- Unit toggle ---
  const unitButtons = document.querySelectorAll<HTMLButtonElement>('.unit-btn');
  const chartWrap = document.getElementById('chart-wrap');

  unitButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const unit = btn.dataset.unit;
      if (!unit || !chartWrap) return;
      unitButtons.forEach(b => {
        const isActive = b.dataset.unit === unit;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });
      chartWrap.classList.toggle('show-cm', unit === 'cm');
      chartWrap.classList.toggle('show-inch', unit === 'inch');
    });
  });

  if (!prefersReducedMotion) {
    // --- Hero entrance timeline ---
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    heroTl.from('.gs-hero', {
      opacity: 0,
      y: 12,
      duration: 0.5,
      stagger: 0.15,
    }, 0.2);

    const h1El = document.querySelector('.h1-chars');
    if (h1El) {
      const text = h1El.textContent || '';
      h1El.textContent = '';
      const chars: HTMLSpanElement[] = [];
      for (const c of text) {
        if (c === ' ') {
          h1El.appendChild(document.createTextNode(' '));
        } else {
          const span = document.createElement('span');
          span.className = 'h1-char';
          span.textContent = c;
          h1El.appendChild(span);
          chars.push(span);
        }
      }

      heroTl.from(chars, {
        opacity: 0,
        x: -20,
        duration: 0.4,
        stagger: 0.03,
        ease: 'power2.out',
      }, 0.1);
    }

    heroTl.from('.gs-form', {
      opacity: 0,
      y: 16,
      duration: 0.5,
      stagger: 0.1,
    }, 0.6);

    document.querySelectorAll('.gs-clip-reveal').forEach(el => {
      gsap.set(el, { clipPath: 'inset(0 100% 0 0)' });
      gsap.to(el, {
        clipPath: 'inset(0 0% 0 0)',
        duration: 0.8,
        ease: 'power3.inOut',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true,
        },
      });
    });

    document.querySelectorAll('.gs-fade-up').forEach(el => {
      gsap.from(el, {
        opacity: 0,
        y: 24,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
      });
    });

    const faqItems = document.querySelectorAll('.gs-faq-item');
    if (faqItems.length) {
      gsap.from(faqItems, {
        opacity: 0,
        y: 16,
        duration: 0.4,
        stagger: 0.08,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: faqItems[0],
          start: 'top 85%',
          once: true,
        },
      });
    }

    document.querySelectorAll('.gs-faq-item').forEach(details => {
      const summary = details.querySelector('summary');
      const content = details.querySelector('p');
      if (!summary || !content) return;

      summary.addEventListener('click', (e) => {
        e.preventDefault();
        if (details.hasAttribute('open')) {
          gsap.to(content, {
            height: 0,
            opacity: 0,
            duration: 0.3,
            ease: 'power2.inOut',
            onComplete: () => {
              details.removeAttribute('open');
              gsap.set(content, { height: 'auto', opacity: 1 });
            },
          });
        } else {
          details.setAttribute('open', '');
          const h = content.scrollHeight;
          gsap.set(content, { height: 0, opacity: 0 });
          gsap.to(content, {
            height: h,
            opacity: 1,
            duration: 0.3,
            ease: 'power2.out',
          });
        }
      });
    });

    const waitlistForm = document.getElementById('waitlist-form');
    const waitlistContentLayer = document.getElementById('waitlist-content-layer');
    const waitlistLoading = document.getElementById('waitlist-loading');
    const waitlistSuccess = document.getElementById('waitlist-success');

    if (waitlistForm && waitlistContentLayer && waitlistLoading && waitlistSuccess) {
      waitlistForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const height = waitlistForm.offsetHeight;
        waitlistForm.style.minHeight = `${height}px`;
        waitlistContentLayer.classList.add('is-hidden');
        waitlistLoading.classList.add('is-visible');
        setTimeout(() => {
          waitlistLoading.classList.remove('is-visible');
          waitlistLoading.classList.add('is-hidden');
          waitlistSuccess.classList.add('is-visible');
        }, 1500);
      });
    }
  }
</script>

