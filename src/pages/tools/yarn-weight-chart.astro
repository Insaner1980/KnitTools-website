---
import PageLayout from '../../layouts/PageLayout.astro';

interface YarnWeightCategory {
  cyc: number;
  name: string;
  regional: string;
  regionalFull: string;
  gauge: string;
  needles: string;
  wpi: string;
  uses: string;
  wpiMin: number;
  wpiMax: number;
}

const categories: YarnWeightCategory[] = [
  {
    cyc: 0,
    name: 'Lace',
    regional: 'Cobweb / Light fingering / 2-ply',
    regionalFull: 'Lace, Cobweb, Light fingering, 2-ply (UK)',
    gauge: '33–40+ sts per 4 in / 10 cm',
    needles: 'US 000–1 (1.5–2.25 mm)',
    wpi: '30–40+',
    uses: 'Lace shawls, doilies, delicate openwork',
    wpiMin: 30,
    wpiMax: 40,
  },
  {
    cyc: 1,
    name: 'Super Fine',
    regional: 'Sock / Fingering / Baby / 4-ply',
    regionalFull: 'Sock, Fingering, Baby, 4-ply (UK/AUS)',
    gauge: '27–32 sts per 4 in / 10 cm',
    needles: 'US 1–3 (2.25–3.25 mm)',
    wpi: '14–30',
    uses: 'Socks, baby items, fine shawls, lightweight garments',
    wpiMin: 14,
    wpiMax: 30,
  },
  {
    cyc: 2,
    name: 'Fine',
    regional: 'Sport / Baby / 5-ply',
    regionalFull: 'Sport, Baby, 5-ply (UK/AUS)',
    gauge: '23–26 sts per 4 in / 10 cm',
    needles: 'US 3–5 (3.25–3.75 mm)',
    wpi: '12–18',
    uses: 'Light garments, baby clothes, accessories',
    wpiMin: 12,
    wpiMax: 18,
  },
  {
    cyc: 3,
    name: 'Light',
    regional: 'DK / Light Worsted / 8-ply',
    regionalFull: 'DK (Double Knitting), Light Worsted, 8-ply (UK/AUS)',
    gauge: '21–24 sts per 4 in / 10 cm',
    needles: 'US 5–7 (3.75–4.5 mm)',
    wpi: '11–15',
    uses: 'Sweaters, hats, scarves, baby blankets, year-round garments',
    wpiMin: 11,
    wpiMax: 15,
  },
  {
    cyc: 4,
    name: 'Medium',
    regional: 'Worsted / Aran / Afghan / 10-ply',
    regionalFull: 'Worsted, Aran, Afghan, 10-ply (AUS)',
    gauge: '16–20 sts per 4 in / 10 cm',
    needles: 'US 7–9 (4.5–5.5 mm)',
    wpi: '9–12',
    uses: 'Sweaters, hats, mittens, blankets, most everyday knits',
    wpiMin: 9,
    wpiMax: 12,
  },
  {
    cyc: 5,
    name: 'Bulky',
    regional: 'Chunky / Craft / Rug / 12-ply',
    regionalFull: 'Chunky, Craft, Rug, 12-ply (AUS)',
    gauge: '12–15 sts per 4 in / 10 cm',
    needles: 'US 9–11 (5.5–8 mm)',
    wpi: '6–9',
    uses: 'Thick sweaters, scarves, blankets, quick projects',
    wpiMin: 6,
    wpiMax: 9,
  },
  {
    cyc: 6,
    name: 'Super Bulky',
    regional: 'Super Chunky / Bulky / Roving',
    regionalFull: 'Super Chunky, Bulky, Roving',
    gauge: '7–11 sts per 4 in / 10 cm',
    needles: 'US 11–17 (8–12.75 mm)',
