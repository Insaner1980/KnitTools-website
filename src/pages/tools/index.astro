---
import ToolsIndexPage from "../../components/ToolsIndexPage.astro";
import { routes } from "../../i18n/routes";

const tools = [
  {
    tag: "Stitches",
    title: "Cast On Calculator",
    description:
      "Calculate how many stitches to cast on for any width and gauge.",
    href: routes.tool.castOnCalculator.en,
    className: "card-terracotta card-top-left reveal-delay-1",
  },
  {
    tag: "Yardage",
    title: "Yarn Estimator",
    description:
      "Estimate yarn requirements by project type, size, and yarn weight.",
    href: routes.tool.yarnEstimator.en,
    className: "card-rust card-top-right reveal-delay-2",
  },
  {
    tag: "Weights",
    title: "Yarn Weight Chart",
    description:
      "CYC yarn weight categories with gauge ranges, needles, and WPI.",
    href: routes.tool.yarnWeightChart.en,
    className: "card-sand card-bl1 reveal-delay-1",
  },
  {
    tag: "Needles",
    title: "Needle Size Chart",
    description: "Convert between US, UK, metric, and Japanese needle sizes.",
    href: routes.tool.needleSizeChart.en,
    className: "card-teal card-br1 reveal-delay-2",
  },
  {
    tag: "Sizes",
    title: "Knitting Size Charts",
    description: "Body measurements for baby through adult, in cm and inches.",
    href: routes.tool.knittingSizeCharts.en,
    className: "card-terracotta card-bl2 reveal-delay-1",
  },
  {
    tag: "Glossary",
    title: "Knitting Abbreviations",
    description: "Search any abbreviation or find terms by technique.",
    href: routes.tool.knittingAbbreviations.en,
    className: "card-brown card-br2 reveal-delay-2",
  },
];
---

<ToolsIndexPage
  title="Free Knitting Tools: Calculators & Charts"
  description="Free online knitting calculators and reference charts: cast on, yarn estimator, needle sizes, yarn weights, abbreviations, and body size charts."
  canonicalPath={routes.toolsIndex.en}
  alternates={routes.toolsIndex}
  collectionName="Free Knitting Tools"
  collectionDescription="Free online knitting calculators and reference charts."
  eyebrow="Free tools"
  heading="Knitting tools, online."
  intro="Calculators and reference charts for your knitting projects. No signup, no app required."
  tools={tools}
  variant="english"
  revealCards
/>
