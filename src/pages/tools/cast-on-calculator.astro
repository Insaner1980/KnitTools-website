---
import PageLayout from "../../layouts/PageLayout.astro";
import CastOnCalculator from "../../components/CastOnCalculator.astro";
import ToolStructuredData from "../../components/ToolStructuredData.astro";
import { PRICING } from "../../config/pricing";
import RegionalPrice from "../../components/RegionalPrice.astro";
import RegionalPricingNote from "../../components/RegionalPricingNote.astro";
import { routes } from "../../i18n/routes";

const canonicalPath = "/tools/cast-on-calculator/";
const pageTitle = "Cast On Calculator for Knitting Patterns";
const pageDescription =
  "Calculate how many stitches to cast on for any width. Enter your gauge and target measurement for an instant count.";
const faqItems = [
  {
    q: "Do I really need to knit a gauge swatch?",
    a: "Yes. Skipping the swatch is one of the most common reasons knitted pieces come out the wrong size. It takes extra time up front and can save hours of rework.",
  },
  {
    q: "Should I count edge stitches in my gauge?",
    a: "No. Measure from the center of your swatch, avoiding the first and last two stitches. Edge stitches are often tighter or looser than the rest.",
  },
  {
    q: "Why does the calculator round to an even number?",
    a: "Many simple stitch patterns, including common ribbing repeats, work cleanly over an even number of stitches. Rounding to the nearest even number gives you a practical default before you adjust for any pattern-specific multiple.",
  },
  {
    q: "What if my pattern requires a specific stitch multiple?",
    a: "Add or subtract a few stitches to reach the nearest multiple your pattern needs. For example, if your pattern repeats over 4 stitches and the calculator says 46, adjust to 44 or 48.",
  },
  {
    q: "Can I use this for circular knitting?",
    a: "Yes. Enter the full circumference as your desired width. The calculator works the same way for flat and circular knitting.",
  },
] as const;
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={canonicalPath}
  alternates={routes.tool.castOnCalculator}
  enableRevealAnimations
>
  <ToolStructuredData
    name="Cast On Calculator"
    description={pageDescription}
    canonicalPath={canonicalPath}
    faqs={faqItems}
  />

  <!-- 1. Tool hero -->
  <section class="tool-hero">
    <div class="hero-inner">
      <p class="eyebrow">
        <a href="/tools/" class="eyebrow-back">← All tools</a>
      </p>
      <h1 data-reveal="heading" aria-label="Cast On Calculator">
        Cast On Calculator
      </h1>
      <p class="hero-intro" data-reveal>
        Calculate how many stitches to cast on for any width and gauge.
      </p>
      <div class="form-card variant-terracotta" data-reveal="scale">
        <CastOnCalculator />
      </div>
    </div>
  </section>

  <!-- 2. SEO content (cream) -->
  <section class="seo-content">
    <div class="content-inner">
      <h2 data-reveal="clip">What is cast on in knitting?</h2>
      <p data-reveal>
        Casting on is the first step in any knitting project: it's how you
        create the initial row of stitches on your needle. The number of
        stitches you cast on determines the width of your finished piece. Too
        few and it's too narrow. Too many and you've wasted yarn and time.
        Getting this number right from the start saves frogging later.
      </p>

      <h2 data-reveal="clip">Why gauge matters</h2>
      <p data-reveal>
        Every knitter knits differently. Even with the same yarn and needles,
        your tension produces a slightly different fabric than someone else's.
        That's why patterns list a recommended gauge, and why you need to knit a
        swatch to find yours. Measure how many stitches fit in 10 cm (or 4
        inches), and you have the number this calculator needs.
      </p>

      <h2 data-reveal="clip">How to use this calculator</h2>
      <p data-reveal>
        To calculate your cast on stitches, you need two things: your <strong
          >gauge</strong
        > (how many stitches you get in 10 cm or 4 inches of knitting) and the <strong
          >desired width</strong
        > of your piece. Knit a gauge swatch first, measure it, and enter those numbers.
        The calculator rounds to the nearest even number, which is a practical default
        for many simple stitch patterns.
      </p>
    </div>
  </section>

  <!-- 3. FAQ (cream) -->
  <section class="tool-faq">
    <div class="faq-inner">
      <h2 data-reveal="clip">Frequently asked questions</h2>
      <div class="faq">
        {
          faqItems.map((faq) => (
            <details data-reveal data-animate-details>
              <summary>
                {faq.q}{" "}
                <span class="faq-icon" aria-hidden="true">
                  +
                </span>
              </summary>
              <p data-animate-body>{faq.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Waitlist CTA (cream) -->
  <section class="waitlist-cta" id="join">
    <div class="waitlist-inner">
      <form
        class="waitlist-form"
        action="#"
        method="post"
        id="waitlist-form"
        data-waitlist-signup
        data-source="knittools"
        data-sending-text="Sending..."
        data-generic-error="Something went wrong. Please try again."
        data-network-error="Network error. Please check your connection."
      >
        <label class="visually-hidden" for="waitlist-website" aria-hidden="true"
          >Leave this field empty</label
        >
        <input
          class="visually-hidden"
          id="waitlist-website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <label class="visually-hidden" for="waitlist-email">Email address</label
        >
        <!-- Initial Form State (Including headers) -->
        <div class="waitlist-content-layer" id="waitlist-content-layer">
          <h2 class="waitlist-head">
            Where every stitch<br /><em>counts.</em>
          </h2>
          <div class="waitlist-row" id="waitlist-row" data-content>
            <input
              id="waitlist-email"
              type="email"
              name="email"
              placeholder="your@email.com"
              aria-describedby="waitlist-success waitlist-error"
              required
              class="waitlist-input"
            />
            <button type="submit" class="waitlist-btn" id="waitlist-btn"
              >Notify me at launch</button
            >
          </div>
          <p
            class="waitlist-success"
            id="waitlist-success"
            data-success
            role="status"
            aria-live="polite"
            aria-atomic="true"
            aria-hidden="true"
            hidden
          >
            You're in! We'll notify you at launch.
          </p>
          <p class="waitlist-meta">
            Coming {PRICING.launchMonthLabel} to Google Play. Launch price <strong
              ><RegionalPrice phase="launch" /></strong
            >. Regular price <strong><RegionalPrice phase="permanent" /></strong
            > later. <RegionalPricingNote />
          </p>
          <p
            class="waitlist-error"
            id="waitlist-error"
            data-error
            role="alert"
            aria-live="polite"
            aria-hidden="true"
            hidden
          >
          </p>
        </div>
      </form>
    </div>
  </section>
</PageLayout>

<style>
  /* ---- Shared section rhythm (v11 editorial) ---- */
  .tool-hero,
  .seo-content,
  .tool-faq,
  .waitlist-cta {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px;
  }

  .tool-hero {
    padding-top: 60px;
    border-bottom: 1px solid var(--ink);
  }

  .seo-content {
    border-bottom: 1px solid var(--ink);
  }

  .waitlist-cta {
    padding-bottom: 100px;
  }

  .hero-inner,
  .content-inner,
  .faq-inner,
  .waitlist-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .content-inner,
  .faq-inner {
    max-width: 720px;
  }

  .waitlist-inner {
    max-width: 640px;
  }

  /* ---- 1. Tool hero ---- */
  .eyebrow {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
  }
  .eyebrow-back {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .eyebrow-back:hover {
    color: var(--terracotta);
  }

  .tool-hero h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: none;
    margin: 0 0 20px;
    padding-bottom: 0.08em;
  }

  .hero-intro {
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink);
    max-width: 560px;
    margin: 0 0 36px;
  }

  /* ---- 2. SEO content ---- */
  .seo-content h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-top: 56px;
    margin-bottom: 16px;
    text-transform: none;
  }
  .seo-content h2:first-child {
    margin-top: 0;
  }

  .seo-content p {
    font-family: var(--body-ed);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 0;
  }
  .seo-content p strong {
    font-weight: 600;
    color: var(--terracotta);
  }

  /* ---- 3. FAQ ---- */
  .tool-faq h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    text-transform: none;
  }

  .faq {
    display: flex;
    flex-direction: column;
  }

  .faq details {
    border-top: 1px solid rgba(42, 30, 23, 0.2);
  }
  .faq details:last-child {
    border-bottom: 1px solid rgba(42, 30, 23, 0.2);
  }

  .faq summary {
    padding: 18px 0;
    cursor: pointer;
    color: var(--ink);
    font-family: var(--body-ed);
    font-weight: 500;
    font-size: 17px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 200ms ease;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary:hover {
    color: var(--terracotta);
  }

  .faq summary .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-left: 1rem;
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 300;
    color: var(--terracotta);
    line-height: 1;
    transition:
      transform 300ms ease,
      color 200ms ease;
  }
  .faq summary:hover .faq-icon {
    color: var(--ink);
  }
  .faq details[open] summary .faq-icon {
    transform: rotate(45deg);
  }

  .faq details p {
    max-width: 440px;
    padding-bottom: 18px;
    font-family: var(--body-ed);
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  /* ---- 4. Waitlist CTA ---- */
  .waitlist-cta h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: var(--closing-cta-heading-size);
    line-height: var(--closing-cta-heading-line-height);
    letter-spacing: var(--closing-cta-heading-letter-spacing);
    margin: var(--closing-cta-heading-margin);
    text-align: center;
    text-transform: none;
  }
  .waitlist-cta h2 em {
    color: var(--terracotta);
    font-style: italic;
    font-size: var(--closing-cta-heading-em-size);
    line-height: 1;
    display: inline-block;
    margin-top: var(--closing-cta-heading-em-margin-top);
  }

  .waitlist-meta {
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 16px 0 0;
  }
  .waitlist-error {
    margin: 16px 0 0;
    font-family: var(--font-body, var(--body-ed));
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft, var(--ink));
    text-align: center;
  }
  .waitlist-meta strong {
    color: var(--terracotta);
    font-weight: 600;
  }

  .waitlist-form {
    position: relative;
    max-width: 100%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
  }

  .waitlist-content-layer {
    width: 100%;
  }

  .waitlist-row {
    display: flex;
    gap: 0;
    width: 100%;
  }

  .waitlist-input {
    flex: 1;
    padding: 14px 20px;
    font-size: 16px;
    font-family: var(--body-ed);
    background: var(--paper-2);
    border: 1.5px solid var(--ink);
    border-right: 0;
    color: var(--ink);
    outline: none;
    border-radius: 0;
    min-width: 0;
  }
  .waitlist-input::placeholder {
    color: var(--ink-soft);
  }
  .waitlist-input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  .waitlist-btn {
    padding: 14px 22px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 0;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
    white-space: nowrap;
  }
  .waitlist-btn:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .waitlist-btn:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }
  .waitlist-success {
    display: none;
    font-family: var(--body-ed);
    font-style: italic;
    font-size: 20px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
    text-align: center;
  }
  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .tool-hero,
    .seo-content,
    .tool-faq,
    .waitlist-cta {
      padding: 60px 20px;
    }
    .tool-hero {
      padding-top: 48px;
    }
    .waitlist-cta {
      padding-bottom: 72px;
    }

    .waitlist-row {
      flex-direction: column;
    }
    .waitlist-input {
      border-right: 1.5px solid var(--ink);
      border-bottom: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow-back,
    .calc-wrapper :global(.calc-btn),
    .waitlist-btn {
      transition: none;
    }
  }
</style>
