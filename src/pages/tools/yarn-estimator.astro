---
import PageLayout from '../../layouts/PageLayout.astro';
import YarnEstimator from '../../components/YarnEstimator.astro';
import { PRICING } from '../../config/pricing';
import RegionalPrice from '../../components/RegionalPrice.astro';
import RegionalPricingNote from '../../components/RegionalPricingNote.astro';
---

<PageLayout
  title="Yarn Estimator: How Much Yarn Do I Need?"
  description="Calculate how many skeins of yarn you need for your knitting project. Enter yardage and skein info. Free, instant, no signup."
  canonicalPath="/tools/yarn-estimator"
  showStripe={false}
>
  <!-- 1. Tool hero -->
  <section class="tool-hero">
    <div class="hero-inner">
      <p class="eyebrow">
        <a href="/tools/" class="eyebrow-back">← All tools</a>
      </p>
      <h1 class="gs-h1" aria-label="Yarn Estimator"><span class="h1-chars">Yarn Estimator</span></h1>
      <p class="hero-intro gs-hero">Calculate how many skeins of yarn you need for your knitting project.</p>
      <div class="form-card variant-rust gs-form">
        <YarnEstimator />
      </div>
    </div>
  </section>

  <!-- 2. SEO content -->
  <section class="seo-content">
    <div class="content-inner">
      <h2 class="gs-clip-reveal">How to use this calculator</h2>
      <p class="gs-fade-up">Enter the total amount of yarn your project needs in meters (or yards), the length per skein from your yarn label, and the weight per skein. The calculator tells you how many skeins to buy and the total weight of yarn you'll need. Always buy one extra skein. Running out mid-project with a discontinued dye lot is every knitter's nightmare.</p>

      <h2 class="gs-clip-reveal">How much yarn do I need?</h2>
      <p class="gs-fade-up">Yarn requirements depend on three things: what you're knitting, what size, and what yarn weight. A fingering-weight adult sweater uses roughly 1200–1500 meters. A bulky hat might need 100 meters. Pattern instructions always list the total yardage. That's the number you enter here.</p>

      <h2 class="gs-clip-reveal">Reading a yarn label</h2>
      <p class="gs-fade-up">Every yarn label (or ball band) tells you the weight per skein and the length per skein. These are the two numbers this calculator needs. If you've lost the label, weigh your yarn on a kitchen scale and check the manufacturer's website for the meters-per-gram ratio.</p>
    </div>
  </section>

  <!-- 3. FAQ -->
  <section class="tool-faq">
    <div class="faq-inner">
      <h2 class="gs-clip-reveal">Frequently asked questions</h2>
      <div class="faq">
        <details class="gs-faq-item">
          <summary>How do I know how much yarn my project needs? <span class="faq-icon" aria-hidden="true">+</span></summary>
          <p>Your pattern lists total yardage or meterage in the materials section. If you're designing without a pattern, search for average yarn requirements by project type and size. There are well-established ranges for most garments.</p>
        </details>
        <details class="gs-faq-item">
          <summary>Should I buy extra yarn? <span class="faq-icon" aria-hidden="true">+</span></summary>
          <p>Always. Buy at least one extra skein, especially if your yarn has a dye lot number. Dye lots vary slightly in color, and matching later may be impossible if the lot is sold out.</p>
        </details>
        <details class="gs-faq-item">
          <summary>What if my yarn label is in grams but the pattern lists yards? <span class="faq-icon" aria-hidden="true">+</span></summary>
          <p>Convert using your yarn's meters-per-gram ratio. Divide the label's length by its weight to get meters per gram, then multiply by the total grams you have. Or use KnitTools. It handles the math for you.</p>
        </details>
        <details class="gs-faq-item">
          <summary>Does yarn weight category affect how much I need? <span class="faq-icon" aria-hidden="true">+</span></summary>
          <p>Yes. Thinner yarn (fingering, sport) requires more meters for the same project than thicker yarn (worsted, bulky) because the stitches are smaller and you need more of them to cover the same area.</p>
        </details>
        <details class="gs-faq-item">
          <summary>Can I substitute a different yarn than the pattern recommends? <span class="faq-icon" aria-hidden="true">+</span></summary>
          <p>Yes, if the gauge matches. Knit a swatch with your substitute yarn, check that you get the same stitch count per 10 cm, and use this calculator to figure out how many skeins of the new yarn you need.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- 4. Waitlist CTA (cream) -->
  <section class="waitlist-cta" id="join">
    <div class="waitlist-inner">
      <form class="waitlist-form" action="#" method="post" id="waitlist-form">
        <label class="visually-hidden" for="waitlist-website">Leave this field empty</label>
        <input
          class="visually-hidden"
          id="waitlist-website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
        />
        <!-- Initial Form State (Including headers) -->
        <div class="waitlist-content-layer" id="waitlist-content-layer">
          <h2 class="gs-clip-reveal waitlist-head">Every tool. <em>One app.</em></h2>
          <p class="gs-fade-up waitlist-desc">Row counter, project management, yarn scanner, and all four calculators.</p>
          <div class="waitlist-row gs-fade-up" id="waitlist-row">
            <input type="email" name="email" placeholder="your@email.com" required class="waitlist-input" />
            <button type="submit" class="waitlist-btn" id="waitlist-btn">Notify me at launch</button>
          </div>
          <p class="gs-fade-up waitlist-meta">Coming {PRICING.launchMonthLabel} to Google Play. Launch price <strong><RegionalPrice phase="launch" /></strong>. <RegionalPricingNote /></p>
          <p class="waitlist-error" id="waitlist-error" role="alert" aria-live="polite" hidden></p>
        </div>

        <!-- Big Spinner Loading State -->
        <div class="waitlist-loading-state" id="waitlist-loading" aria-hidden="true">
          <span class="big-spinner" aria-live="polite">Sending&hellip;</span>
        </div>

        <!-- Success Message State -->
        <div class="waitlist-success" id="waitlist-success" aria-hidden="true">
          <p class="success-text">
            <span class="success-label">You're in!</span>
            <span class="success-sub">We'll notify you at launch.</span>
          </p>
        </div>
      </form>
    </div>
  </section>
</PageLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // --- Hero entrance timeline ---
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Back link + intro fade in
    heroTl.from('.gs-hero', {
      opacity: 0,
      y: 12,
      duration: 0.5,
      stagger: 0.15,
    }, 0.2);

    // H1 letter stagger — wrap each word so browsers can't break mid-word
    const h1El = document.querySelector('.h1-chars');
    if (h1El) {
      const text = h1El.textContent || '';
      h1El.textContent = '';
      const chars: HTMLSpanElement[] = [];
      const words = text.split(' ');
      words.forEach((word, wi) => {
        const wordSpan = document.createElement('span');
        wordSpan.className = 'h1-word';
        for (const c of word) {
          const span = document.createElement('span');
          span.className = 'h1-char';
          span.textContent = c;
          wordSpan.appendChild(span);
          chars.push(span);
        }
        h1El.appendChild(wordSpan);
        if (wi < words.length - 1) {
          h1El.appendChild(document.createTextNode(' '));
        }
      });

      heroTl.from(chars, {
        opacity: 0,
        x: -20,
        duration: 0.4,
        stagger: 0.03,
        ease: 'power2.out',
      }, 0.1);
    }

    // Form elements stagger
    heroTl.from('.gs-form .form-group, .gs-form .unit-toggle, .gs-form .calc-btn', {
      opacity: 0,
      y: 16,
      duration: 0.5,
      stagger: 0.1,
    }, 0.6);

    // --- Scroll-triggered: clip-reveal H2s ---
    document.querySelectorAll('.gs-clip-reveal').forEach(el => {
      gsap.set(el, { clipPath: 'inset(0 100% 0 0)' });
      gsap.to(el, {
        clipPath: 'inset(0 0% 0 0)',
        duration: 0.8,
        ease: 'power3.inOut',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true,
        },
      });
    });

    // --- Scroll-triggered: fade up paragraphs ---
    document.querySelectorAll('.gs-fade-up').forEach(el => {
      gsap.from(el, {
        opacity: 0,
        y: 24,
        duration: 0.6,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
      });
    });

    // --- FAQ items staggered on scroll ---
    const faqItems = document.querySelectorAll('.gs-faq-item');
    if (faqItems.length) {
      gsap.from(faqItems, {
        opacity: 0,
        y: 16,
        duration: 0.4,
        stagger: 0.08,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: faqItems[0],
          start: 'top 85%',
          once: true,
        },
      });
    }

    // --- FAQ accordion smooth height ---
    document.querySelectorAll('.gs-faq-item').forEach(details => {
      const summary = details.querySelector('summary');
      const content = details.querySelector('p');
      if (!summary || !content) return;

      summary.addEventListener('click', (e) => {
        e.preventDefault();
        if (details.hasAttribute('open')) {
          gsap.to(content, {
            height: 0,
            opacity: 0,
            duration: 0.3,
            ease: 'power2.inOut',
            onComplete: () => {
              details.removeAttribute('open');
              gsap.set(content, { height: 'auto', opacity: 1 });
            },
          });
        } else {
          details.setAttribute('open', '');
          const h = content.scrollHeight;
          gsap.set(content, { height: 0, opacity: 0 });
          gsap.to(content, {
            height: h,
            opacity: 1,
            duration: 0.3,
            ease: 'power2.out',
          });
        }
      });
    });

    // --- Waitlist Form Morph Animation (3-step Full Section) ---
    const waitlistForm = document.getElementById('waitlist-form');
    const waitlistContentLayer = document.getElementById('waitlist-content-layer');
    const waitlistLoading = document.getElementById('waitlist-loading');
    const waitlistSuccess = document.getElementById('waitlist-success');

    if (waitlistForm && waitlistContentLayer && waitlistLoading && waitlistSuccess) {
      waitlistForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const emailInput = waitlistForm.querySelector('input[type="email"]');
        const honeypot = waitlistForm.querySelector('input[name="website"]');
        const errorEl = document.getElementById('waitlist-error');

        // Lock height to prevent page jumping when content becomes absolute
        const height = waitlistForm.offsetHeight;
        waitlistForm.style.minHeight = `${height}px`;

        if (errorEl) {
          errorEl.hidden = true;
          errorEl.textContent = '';
        }

        // 1. Morph to Big Spinner Loading state
        waitlistContentLayer.classList.add('is-hidden');
        waitlistLoading.classList.add('is-visible');

        let success = false;
        let errorMessage = 'Something went wrong. Please try again.';

        try {
          const res = await fetch('https://api.finnvek.com/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: emailInput ? emailInput.value.trim() : '',
              source: 'knittools',
              website: honeypot ? honeypot.value : '',
            }),
          });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.success) {
            success = true;
          } else if (data.error) {
            errorMessage = data.error;
          }
        } catch {
          errorMessage = 'Network error. Please check your connection.';
        }

        // Minimum spinner visibility for perceived smoothness
        await new Promise((r) => setTimeout(r, 600));

        if (success) {
          // 2. Morph loading -> success
          waitlistLoading.classList.remove('is-visible');
          waitlistLoading.classList.add('is-hidden');
          waitlistSuccess.classList.add('is-visible');
        } else {
          // 2b. Revert loading -> content with inline error
          waitlistLoading.classList.remove('is-visible');
          waitlistLoading.classList.add('is-hidden');
          waitlistContentLayer.classList.remove('is-hidden');
          if (errorEl) {
            errorEl.textContent = errorMessage;
            errorEl.hidden = false;
          }
        }
      });
    }
  }
</script>

<style>
  /* ---- Shared section rhythm (v11 editorial) ---- */
  .tool-hero,
  .seo-content,
  .tool-faq,
  .waitlist-cta {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px;
  }

  .tool-hero {
    padding-top: 60px;
    border-bottom: 1px solid var(--ink);
  }

  .seo-content {
    border-bottom: 1px solid var(--ink);
  }

  .waitlist-cta {
    padding-bottom: 100px;
  }

  .hero-inner,
  .content-inner,
  .faq-inner,
  .waitlist-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .content-inner,
  .faq-inner {
    max-width: 720px;
  }

  .waitlist-inner {
    max-width: 640px;
  }

  /* ---- 1. Tool hero ---- */
  .eyebrow {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
  }
  .eyebrow-back {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .eyebrow-back:hover { color: var(--terracotta); }

  .tool-hero h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: none;
    margin: 0 0 20px;
    padding-bottom: 0.08em;
  }

  .tool-hero h1 :global(.h1-word) {
    display: inline-block;
    white-space: nowrap;
  }
  .tool-hero h1 :global(.h1-char) {
    display: inline-block;
  }

  .hero-intro {
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink);
    max-width: 560px;
    margin: 0 0 40px;
  }

  /* ---- 2. SEO content ---- */
  .seo-content h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-top: 56px;
    margin-bottom: 16px;
    text-transform: none;
  }
  .seo-content h2:first-child { margin-top: 0; }

  .seo-content p {
    font-family: var(--body-ed);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 0;
  }
  .seo-content p strong {
    font-weight: 600;
    color: var(--terracotta);
  }

  /* ---- 3. FAQ ---- */
  .tool-faq h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    text-transform: none;
  }

  .faq { display: flex; flex-direction: column; }

  .faq details {
    border-top: 1px solid rgba(42, 30, 23, 0.2);
  }
  .faq details:last-child {
    border-bottom: 1px solid rgba(42, 30, 23, 0.2);
  }

  .faq summary {
    padding: 18px 0;
    cursor: pointer;
    color: var(--ink);
    font-family: var(--body-ed);
    font-weight: 500;
    font-size: 17px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 200ms ease;
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary:hover { color: var(--terracotta); }

  .faq summary .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-left: 1rem;
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 300;
    color: var(--terracotta);
    line-height: 1;
    transition: transform 300ms ease, color 200ms ease;
  }
  .faq summary:hover .faq-icon {
    color: var(--ink);
  }
  .faq details[open] summary .faq-icon {
    transform: rotate(45deg);
  }

  .faq details p {
    max-width: 440px;
    padding-bottom: 18px;
    font-family: var(--body-ed);
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  /* ---- 4. Waitlist CTA ---- */
  .waitlist-cta h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.15;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    text-transform: none;
  }
  .waitlist-cta h2 em {
    color: var(--terracotta);
    font-style: italic;
  }

  .waitlist-desc {
    font-family: var(--body-ed);
    font-style: italic;
    color: var(--ink);
    font-size: 17px;
    line-height: 1.5;
    margin-bottom: 28px;
    max-width: 520px;
  }

  .waitlist-meta {
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 16px 0 0;
  }
  .waitlist-error {
    margin: 16px 0 0;
    font-family: var(--font-body, var(--body-ed));
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft, var(--ink));
    text-align: center;
  }
  .waitlist-meta strong {
    color: var(--terracotta);
    font-weight: 600;
  }

  .waitlist-form {
    position: relative;
    max-width: 100%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
  }

  .waitlist-content-layer,
  .waitlist-loading-state,
  .waitlist-success {
    transition: opacity 400ms cubic-bezier(0.4, 0, 0.2, 1), transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .waitlist-content-layer { width: 100%; }

  .waitlist-content-layer.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.96);
    position: absolute;
  }

  .waitlist-row {
    display: flex;
    gap: 0;
    width: 100%;
  }

  .waitlist-input {
    flex: 1;
    padding: 14px 20px;
    font-size: 16px;
    font-family: var(--body-ed);
    background: var(--paper-2);
    border: 1.5px solid var(--ink);
    border-right: 0;
    color: var(--ink);
    outline: none;
    border-radius: 0;
    min-width: 0;
  }
  .waitlist-input::placeholder { color: var(--ink-soft); }
  .waitlist-input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  .waitlist-btn {
    padding: 14px 22px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 0;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .waitlist-btn:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .waitlist-btn:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }

  /* Big Spinner Layer */
  .waitlist-loading-state {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.6);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .waitlist-loading-state.is-visible {
    position: relative;
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }
  .waitlist-loading-state.is-hidden {
    position: absolute;
    opacity: 0;
    transform: scale(1.2);
    pointer-events: none;
  }

  .big-spinner {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    padding: 24px 0;
    animation: waitlistPulse 1.6s ease-in-out infinite;
  }
  @keyframes waitlistPulse {
    0%, 100% { opacity: 0.45; }
    50%      { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .big-spinner { animation: none; opacity: 0.8; }
  }

  /* Success Layer */
  .waitlist-success {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px) scale(0.98);
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .waitlist-success.is-visible {
    opacity: 1;
    position: relative;
    transform: translateY(0) scale(1);
    pointer-events: auto;
    transition-delay: 100ms;
  }

  .success-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 12px 0;
    text-align: center;
  }

  .success-label {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--terracotta);
    line-height: 1;
  }

  .success-sub {
    font-family: var(--body-ed);
    font-size: 1.15rem;
    color: var(--ink);
    font-style: italic;
    margin-top: 8px;
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .tool-hero,
    .seo-content,
    .tool-faq,
    .waitlist-cta {
      padding: 60px 20px;
    }
    .tool-hero { padding-top: 48px; }
    .waitlist-cta { padding-bottom: 72px; }

    .waitlist-row { flex-direction: column; }
    .waitlist-input {
      border-right: 1.5px solid var(--ink);
      border-bottom: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow-back,
    .calc-wrapper :global(.calc-btn),
    .waitlist-btn {
      transition: none;
    }
  }
</style>
