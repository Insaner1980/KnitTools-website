---
import PageLayout from "../../layouts/PageLayout.astro";
import { PRICING } from "../../config/pricing";
import RegionalPrice from "../../components/RegionalPrice.astro";
import RegionalPricingNote from "../../components/RegionalPricingNote.astro";
import ToolStructuredData from "../../components/ToolStructuredData.astro";
import { routes } from "../../i18n/routes";
import { getNeedleSizeRows } from "../../lib/toolReferenceData";

const canonicalPath = "/tools/needle-size-chart/";
const schemaDescription =
  "Convert knitting needle sizes between US, UK, metric (mm), and Japanese systems.";
const rows = getNeedleSizeRows();
const formatReferenceCell = (value: string) => (value === "-" ? "—" : value);
const faqItems = [
  {
    q: "Can I substitute a close needle size if I don't have the exact one?",
    a: "You can, but a 0.5 mm jump often shifts gauge enough to matter. Swatch again for anything fitted.",
  },
  {
    q: "Are needle sizes the same across all brands?",
    a: "They should be. In practice there are slight differences, especially on cheaper sets or older needles. If your gauge is persistently off, measure the needle.",
  },
  {
    q: "What about circular needle sizes?",
    a: "Same sizing as straights. The size describes tip diameter, not cable length. A 4.5 mm circular is a 4.5 mm needle whether the cable is short for a hat or long for magic loop.",
  },
  {
    q: "Do I need every needle size?",
    a: "No. Most knitters live in a handful of sizes matching the yarns they use most. If you're working with Medium and Light yarns, you'll reach for 3.75 to 5.5 mm constantly.",
  },
] as const;
---

<PageLayout
  title="Needle Size Chart: US, UK, Metric & Japanese"
  description="Convert knitting needle sizes between US, UK, metric (mm), and Japanese systems. Searchable chart with recommended yarn weights per needle size."
  canonicalPath={canonicalPath}
  alternates={routes.tool.needleSizeChart}
  enableRevealAnimations
>
  <ToolStructuredData
    name="Knitting Needle Size Chart"
    description={schemaDescription}
    canonicalPath={canonicalPath}
    faqs={faqItems}
  />

  <!-- 1. Tool hero -->
  <section class="tool-hero">
    <div class="hero-inner">
      <p class="eyebrow">
        <a href="/tools/" class="eyebrow-back">← All tools</a>
      </p>
      <h1 data-reveal="heading" aria-label="Needle Size Chart">
        Needle Size Chart
      </h1>
      <p class="hero-intro" data-reveal>
        Convert between US, UK, metric, and Japanese needle sizes. Type any size
        to find its match.
      </p>

      <div class="form-card variant-teal is-wide" data-reveal="scale">
        <div class="table-wrapper">
          <input
            type="text"
            id="needle-search"
            class="search-input"
            aria-label="Search needle sizes"
            placeholder='Search any size (e.g. "4.5", "US 7", "UK 7")'
            autocomplete="off"
          />
          <div class="table-scroll">
            <table class="needle-table" id="needle-table">
              <thead>
                <tr>
                  <th>Metric (mm)</th>
                  <th>US</th>
                  <th>UK/Canadian</th>
                  <th>Japanese</th>
                  <th>Yarn Weight</th>
                </tr>
              </thead>
              <tbody>
                {
                  rows.map((row) => (
                    <tr
                      data-mm={row[0]}
                      data-us={row[1] === "-" ? "" : row[1]}
                      data-uk={row[2] === "-" ? "" : row[2]}
                      data-jp={row[3] === "-" ? "" : row[3]}
                    >
                      <td class="col-mm">{row[0]}</td>
                      {row.slice(1).map((cell) => (
                        <td>{formatReferenceCell(cell)}</td>
                      ))}
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <p class="no-results" id="no-results" hidden>
            No matching needle size found.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. SEO content -->
  <section class="seo-content">
    <div class="content-inner">
      <h2 data-reveal="clip">Why there are four different systems</h2>
      <p data-reveal>
        Metric is the only system that tells you what the needle actually
        measures. A 4.0 mm needle is 4.0 mm. Done.
      </p>
      <p data-reveal>
        US sizes are labels. A US 7 means 4.5 mm and a US 8 means 5.0 mm, but
        nothing about those numbers hints at a diameter.
      </p>
      <p data-reveal>
        Old UK and Canadian sizes run backward. A UK 14 is tiny, and the numbers
        shrink as needles grow until you hit 0, 00, and 000. Most modern UK
        patterns give metric, but the old system still shows up on vintage
        needles and secondhand pattern leaflets.
      </p>
      <p data-reveal>
        Japanese sizes track close to metric but not perfectly. Japanese size 6
        is 3.9 mm, Japanese size 8 is 4.5 mm. That offset matters most in fine
        gauges where a few tenths of a millimeter change the finished fabric.
      </p>

      <h2 data-reveal="clip">When metric is the safe bet</h2>
      <p data-reveal>
        Trust the millimeter size first. It's the actual measurement, and it
        sidesteps conversion mistakes entirely.
      </p>
      <p data-reveal>
        When a pattern calls for "US 7," what you need in your hand is 4.5 mm.
        Some brands print both numbers on the needle. Some don't. Old markings
        wear off. A needle gauge tool is worth keeping nearby for exactly this
        reason.
      </p>

      <h2 data-reveal="clip">Common conversion pitfalls</h2>
      <p data-reveal>A few sizes trip people up consistently.</p>
      <p data-reveal>
        <strong>The UK reversal.</strong> US sizes go up as needles get bigger. Old
        UK sizes go down. A US 6 is 4.0 mm. A UK 6 is 5.0 mm. Swap those and your
        swatch is off by a full millimeter before you've knit a single row. That trips
        up more people than you'd expect.
      </p>
      <p data-reveal>
        <strong>The missing one-to-one matches.</strong> Not every metric size has
        a clean equivalent in every other system. A 3.0 mm needle is sometimes labeled
        US 2.5 by some brands, while other charts place it between US 2 and US 3.
        A 3.5 mm needle usually has no old UK equivalent at all. When that happens,
        go back to the mm size and ignore the rest.
      </p>
      <p data-reveal>
        <strong>Japanese near-misses.</strong> Japanese sizes don't line up cleanly
        with US numbers. Japanese size 8 is 4.5 mm (matching US 7), but Japanese size
        5 is 3.6 mm and doesn't sit neatly in the US system at all. If you're working
        from a Japanese pattern, match the mm value. Not the printed number. Always
        the mm value.
      </p>
      <p data-reveal>
        <strong>Half sizes and odd sizes are real.</strong> 2.5 mm, 3.0 mm, and 6.5
        mm needles are standard production sizes even if your interchangeable set
        skipped them. This is why "go up half a size" sometimes turns into a rummage
        through the whole project bag.
      </p>
      <p data-reveal>
        <strong>Old pattern leaflets give no system label.</strong> A pattern from
        the 1970s that says "size 6 needles" could mean US 6 (4.0 mm) or UK 6 (5.0
        mm) depending on which country published it. Check the publisher, then check
        the chart.
      </p>

      <h2 data-reveal="clip">Needle size and yarn weight pairing</h2>
      <p data-reveal>
        The chart can get you into the right neighborhood. Your swatch decides
        the exact address.
      </p>
      <p data-reveal>
        The current Craft Yarn Council weight system pairs lace with 1.5 to 2.25
        mm, Super Fine with 2.25 to 3.25 mm, Fine with 3.25 to 3.75 mm, Light
        with 3.75 to 4.5 mm, Medium with 4.5 to 5.5 mm, Bulky with 5.5 to 8 mm,
        Super Bulky with 8 to 12.75 mm, and Jumbo at 12.75 mm and up.
      </p>
      <p data-reveal>
        Those ranges overlap on purpose. DK can make a firm hat fabric on a
        smaller needle or an airy shawl fabric on a larger one. The pattern
        gauge tells you which direction the designer intended. If you're not
        sure which yarn category you're holding, the <a
          href="/tools/yarn-weight-chart/">yarn weight chart</a
        > is the better place to start.
      </p>

      <h2 data-reveal="clip">How to measure unmarked needles</h2>
      <p data-reveal>
        Vintage needles, hand-turned wooden needles, and well-used
        interchangeables all end up with missing markings sooner or later. A
        needle gauge (sometimes called a needle sizer) fixes that. Slide the
        shaft into the holes until you find the one that fits cleanly without
        forcing.
      </p>
      <p data-reveal>
        Measure on the shaft, not the tip. The tapered point reads smaller than
        the working part of the needle. Wrong answer every time.
      </p>
      <p data-reveal>
        Most needle gauges show metric and US sizes, some include Japanese
        sizing too. If yours doesn't, use this needle size guide to find the mm
        equivalent and then knit a quick <a
          href="/articles/how-to-measure-knitting-gauge/">gauge swatch</a
        > to confirm before you commit to the full project. If you're also choosing
        a <a href="/articles/knitting-needle-materials/">needle material</a>,
        that's a separate decision from size.
      </p>
    </div>
  </section>

  <!-- 3. FAQ -->
  <section class="tool-faq">
    <div class="faq-inner">
      <h2 data-reveal="clip">Frequently asked questions</h2>
      <div class="faq">
        {
          faqItems.map((f) => (
            <details data-reveal data-animate-details>
              <summary>
                {f.q}{" "}
                <span class="faq-icon" aria-hidden="true">
                  +
                </span>
              </summary>
              <p data-animate-body>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Waitlist CTA -->
  <section class="waitlist-cta" id="join">
    <div class="waitlist-inner">
      <form
        class="waitlist-form"
        action="#"
        method="post"
        id="waitlist-form"
        data-waitlist-signup
        data-source="knittools"
        data-sending-text="Sending..."
        data-generic-error="Something went wrong. Please try again."
        data-network-error="Network error. Please check your connection."
      >
        <label class="visually-hidden" for="waitlist-website" aria-hidden="true"
          >Leave this field empty</label
        >
        <input
          class="visually-hidden"
          id="waitlist-website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <label class="visually-hidden" for="waitlist-email">Email address</label
        >
        <div class="waitlist-content-layer" id="waitlist-content-layer">
          <h2 class="waitlist-head">
            Where every stitch<br /><em>counts.</em>
          </h2>
          <div class="waitlist-row" id="waitlist-row" data-content>
            <input
              id="waitlist-email"
              type="email"
              name="email"
              placeholder="your@email.com"
              aria-describedby="waitlist-success waitlist-error"
              required
              class="waitlist-input"
            />
            <button type="submit" class="waitlist-btn" id="waitlist-btn"
              >Notify me at launch</button
            >
          </div>
          <p
            class="waitlist-success"
            id="waitlist-success"
            data-success
            role="status"
            aria-live="polite"
            aria-atomic="true"
            aria-hidden="true"
            hidden
          >
            You're in! We'll notify you at launch.
          </p>
          <p class="waitlist-meta">
            Coming {PRICING.launchMonthLabel} to Google Play. Launch price <strong
              ><RegionalPrice phase="launch" /></strong
            >. Regular price <strong><RegionalPrice phase="permanent" /></strong
            > later. <RegionalPricingNote />
          </p>
          <p
            class="waitlist-error"
            id="waitlist-error"
            data-error
            role="alert"
            aria-live="polite"
            aria-hidden="true"
            hidden
          >
          </p>
        </div>
      </form>
    </div>
  </section>
</PageLayout>

<style>
  /* ---- Shared section rhythm (v11 editorial) ---- */
  .tool-hero,
  .seo-content,
  .tool-faq,
  .waitlist-cta {
    background: var(--paper);
    color: var(--ink);
    padding: 80px 40px;
  }

  .tool-hero {
    padding-top: 60px;
    border-bottom: 1px solid var(--ink);
  }

  .seo-content {
    border-bottom: 1px solid var(--ink);
  }

  .waitlist-cta {
    padding-bottom: 100px;
  }

  .hero-inner,
  .content-inner,
  .faq-inner,
  .waitlist-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .content-inner,
  .faq-inner {
    max-width: 720px;
  }

  .waitlist-inner {
    max-width: 640px;
  }

  /* ---- 1. Tool hero ---- */
  .eyebrow {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 24px;
  }
  .eyebrow-back {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .eyebrow-back:hover {
    color: var(--terracotta);
  }

  .tool-hero h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: none;
    margin: 0 0 20px;
    padding-bottom: 0.08em;
  }

  .hero-intro {
    font-family: var(--body-ed);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink);
    max-width: 560px;
    margin: 0 0 40px;
  }

  /* ---- Search input ---- */
  .table-wrapper {
    max-width: 760px;
    margin: 0 auto;
  }

  .search-input {
    width: 100%;
    padding: 14px 20px;
    font-size: 16px;
    font-family: var(--body-ed);
    background: var(--paper-2);
    border: 1.5px solid var(--ink);
    color: var(--ink);
    outline: none;
    border-radius: 0;
    margin-bottom: 24px;
    box-sizing: border-box;
    transition: outline-color 0.15s ease;
  }
  .search-input::placeholder {
    color: var(--ink-soft);
  }
  .search-input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  /* ---- Table ---- */
  .table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .needle-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: transparent;
  }

  .needle-table thead th {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    padding: 16px 12px;
    text-align: left;
    white-space: nowrap;
    border-bottom: 1.5px solid var(--ink);
    font-weight: 500;
    background: var(--paper);
  }

  .needle-table tbody td {
    font-family: var(--body-ed);
    font-weight: 400;
    font-size: 16px;
    color: var(--ink);
    padding: 14px 12px;
    border-bottom: 1px solid rgba(244, 234, 217, 0.15);
    background: var(--paper);
  }

  .needle-table tbody tr:hover td {
    background-color: color-mix(
      in srgb,
      var(--paper) 92%,
      var(--terracotta) 8%
    );
  }

  /* Sticky first column (mm size) stays visible when scrolling horizontally */
  .needle-table thead th:first-child,
  .needle-table tbody td:first-child {
    position: sticky;
    left: 0;
    z-index: 1;
  }

  .needle-table .col-mm {
    font-weight: 600;
    color: var(--terracotta);
  }

  .no-results {
    font-family: var(--body-ed);
    font-style: italic;
    color: var(--terracotta);
    font-size: 16px;
    padding: 16px 0;
    margin: 0;
  }

  /* ---- 2. SEO content ---- */
  .seo-content h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-top: 56px;
    margin-bottom: 16px;
    text-transform: none;
  }
  .seo-content h2:first-child {
    margin-top: 0;
  }

  .seo-content p {
    font-family: var(--body-ed);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
    margin-bottom: 0;
  }
  .seo-content p + p {
    margin-top: 1rem;
  }
  .seo-content p strong {
    font-weight: 600;
    color: var(--terracotta);
  }
  .seo-content a {
    color: var(--terracotta);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .seo-content a:hover {
    opacity: 0.8;
  }

  /* ---- 3. FAQ ---- */
  .tool-faq h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    padding-bottom: 0.08em;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
    text-transform: none;
  }

  .faq {
    display: flex;
    flex-direction: column;
  }

  .faq details {
    border-top: 1px solid rgba(42, 30, 23, 0.2);
  }
  .faq details:last-child {
    border-bottom: 1px solid rgba(42, 30, 23, 0.2);
  }

  .faq summary {
    padding: 18px 0;
    cursor: pointer;
    color: var(--ink);
    font-family: var(--body-ed);
    font-weight: 500;
    font-size: 17px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 200ms ease;
  }
  .faq summary::-webkit-details-marker {
    display: none;
  }
  .faq summary:hover {
    color: var(--terracotta);
  }

  .faq summary .faq-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-left: 1rem;
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 300;
    color: var(--terracotta);
    line-height: 1;
    transition:
      transform 300ms ease,
      color 200ms ease;
  }
  .faq summary:hover .faq-icon {
    color: var(--ink);
  }
  .faq details[open] summary .faq-icon {
    transform: rotate(45deg);
  }

  .faq details p {
    max-width: 440px;
    padding-bottom: 18px;
    font-family: var(--body-ed);
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.65;
  }

  /* ---- 4. Waitlist CTA ---- */
  .waitlist-cta h2 {
    font-family: var(--serif);
    font-weight: 400;
    color: var(--ink);
    font-size: var(--closing-cta-heading-size);
    line-height: var(--closing-cta-heading-line-height);
    letter-spacing: var(--closing-cta-heading-letter-spacing);
    margin: var(--closing-cta-heading-margin);
    text-align: center;
    text-transform: none;
  }
  .waitlist-cta h2 em {
    color: var(--terracotta);
    font-style: italic;
    font-size: var(--closing-cta-heading-em-size);
    line-height: 1;
    display: inline-block;
    margin-top: var(--closing-cta-heading-em-margin-top);
  }

  .waitlist-meta {
    font-family: var(--body-ed);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 16px 0 0;
  }
  .waitlist-error {
    margin: 16px 0 0;
    font-family: var(--font-body, var(--body-ed));
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft, var(--ink));
    text-align: center;
  }
  .waitlist-meta strong {
    color: var(--terracotta);
    font-weight: 600;
  }

  .waitlist-form {
    position: relative;
    max-width: 100%;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
  }

  .waitlist-content-layer {
    width: 100%;
  }

  .waitlist-row {
    display: flex;
    gap: 0;
    width: 100%;
  }

  .waitlist-input {
    flex: 1;
    padding: 14px 20px;
    font-size: 16px;
    font-family: var(--body-ed);
    background: var(--paper-2);
    border: 1.5px solid var(--ink);
    border-right: 0;
    color: var(--ink);
    outline: none;
    border-radius: 0;
    min-width: 0;
  }
  .waitlist-input::placeholder {
    color: var(--ink-soft);
  }
  .waitlist-input:focus {
    outline: 2px solid var(--terracotta);
    outline-offset: 2px;
  }

  .waitlist-btn {
    padding: 14px 22px;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    border-radius: 0;
    cursor: pointer;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
    white-space: nowrap;
  }
  .waitlist-btn:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }
  .waitlist-btn:focus-visible {
    outline: 2px solid var(--terracotta);
    outline-offset: 3px;
  }
  .waitlist-success {
    display: none;
    font-family: var(--body-ed);
    font-style: italic;
    font-size: 20px;
    color: var(--terracotta);
    margin: 0;
    padding: 8px 0;
    text-align: center;
  }
  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .tool-hero,
    .seo-content,
    .tool-faq,
    .waitlist-cta {
      padding: 60px 20px;
    }
    .tool-hero {
      padding-top: 48px;
    }
    .waitlist-cta {
      padding-bottom: 72px;
    }

    .waitlist-row {
      flex-direction: column;
    }
    .waitlist-input {
      border-right: 1.5px solid var(--ink);
      border-bottom: 0;
    }

    .needle-table thead th,
    .needle-table tbody td {
      padding: 12px 10px;
      font-size: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eyebrow-back,
    .waitlist-btn,
    .search-input {
      transition: none;
    }
  }
</style>
