const faqs = [
  {
    q: "Sind Strickabkürzungen in US- und UK-Anleitungen gleich?",
    a: 'Die meisten sind identisch. k, p, yo und k2tog bedeuten auf beiden Seiten des Atlantiks dasselbe. Unterschiede gibt es bei einzelnen Begriffen: US "bind off" ist UK "cast off", US "gauge" ist UK "tension" und US "stockinette" ist UK "stocking stitch". Außerdem können "seed stitch" und "moss stitch" je nach Quelle vertauscht werden. Vertraue deshalb der Maschendefinition mehr als dem Namen.',
  },
  {
    q: "Was bedeutet ein Stern in einer Strickanleitung?",
    a: 'Er markiert eine Wiederholung. Alles zwischen dem Stern und der passenden Wiederholungsanweisung, zum Beispiel "rep from *", wird erneut gearbeitet. Klammern und eckige Klammern machen dasselbe: Sie gruppieren Schritte, die eine bestimmte Anzahl wiederholt werden. Ein übersehener Rapportmarker ist einer der schnellsten Wege zur falschen Maschenzahl.',
  },
  {
    q: "Was mache ich bei einer unbekannten Abkürzung?",
    a: "Sehr wahrscheinlich ist es eine anleitungsspezifische Kurzform. Suche zuerst am Anfang der Anleitung nach Abkürzungen oder Technikdefinitionen. Zopf- und Lochmuster verwenden besonders oft eigene Kürzel, weil kompakte Notation für dieses eine Design nötig ist. Wenn du dort nichts findest, prüfe Notizen und Strickschriftlegende.",
  },
  {
    q: "Was ist der Unterschied zwischen ssk und skp?",
    a: "Beides sind links geneigte Abnahmen, und sie sehen im fertigen Gestrick fast gleich aus. ssk ist der moderne Standard und erscheint in vielen aktuellen englischen Anleitungen. skp taucht häufiger in älteren Anleitungen auf. Die Ausführung unterscheidet sich leicht, deshalb solltest du die Abnahme arbeiten, die die Anleitung nennt.",
  },
];
---

<LocalizedToolPage
  title="Strickabkürzungen: suchbares Glossar"
  description="Suche englische und internationale Strickabkürzungen und lies die deutsche Bedeutung. Mit Kategorien für Zunahmen, Abnahmen, Zöpfe und Muster."
  canonicalPath={routes.tool.knittingAbbreviations.de}
  lang="de"
  alternates={routes.tool.knittingAbbreviations}
  intro="Suche eine Abkürzung oder Technik. Das Glossar hilft dir, englische Strickanleitungen auf Deutsch zu lesen."
  schemaName="Strickabkürzungen"
  schemaDescription="Durchsuchbares Glossar für Strickabkürzungen und Stricktechniken."
  faqs={faqs}
  variant="brown"
>
  <div slot="tool">
    <div class="abbr-wrapper">
      <input
        type="text"
        id="abbr-search"
        class="search-input"
        aria-label="Strickabkürzungen und Techniken suchen"
        placeholder='Abkürzung oder Technik suchen, z. B. "ssk" oder "Abnahme"'
        autocomplete="off"
      />

      <div
        class="category-filters"
        role="group"
        aria-label="Nach Kategorie filtern"
      >
        {
          filterOrder.map((cat, index) => (
            <button
              type="button"
              class={`cat-btn${index === 0 ? " is-active" : ""}`}
              data-cat={cat}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {cat === "all" ? "Alle" : categoryLabels[cat as Category]}
            </button>
          ))
        }
      </div>

      <ul class="abbr-list" id="abbr-list" aria-label="Strickabkürzungen">
        {
          abbreviations.map((item) => (
            <li
              class="abbr-row"
              data-abbr={item.abbr.toLowerCase()}
              data-def={item.def.toLowerCase()}
              data-search={item.search.toLowerCase()}
              data-cats={item.categories.join(" ")}
              data-catlabels={item.categories
                .map((cat) => categoryLabels[cat].toLowerCase())
                .join(" ")}
            >
              <span class="abbr-term">{item.abbr}</span>
              <span class="abbr-def">{item.def}</span>
            </li>
          ))
        }
      </ul>

      <p class="no-results" id="no-results" hidden>
        Keine passenden Abkürzungen gefunden.
      </p>
    </div>
  </div>

  <div slot="content">
    <h2>Abkürzungen im Zusammenhang lesen</h2>
    <p>
      Die meisten Abkürzungen fallen in einige Gruppen. Wenn du die Gruppe
      erkennst, musst du weniger Einzelbegriffe auswendig lernen.
    </p>
    <p>
      <strong>Grundmaschen</strong> sind einzelne Buchstaben. <code>k</code> ist knit,
      also eine rechte Masche, <code>p</code> ist purl, also eine linke Masche. Eine
      Zahl danach sagt, wie viele Maschen gemeint sind: <code>k5</code> heißt fünf
      Maschen rechts stricken.
    </p>
    <p>
      <strong>Kombinierte Aktionen</strong> stapeln Buchstaben und Zahlen. <code
        >k2tog</code
      > heißt zwei Maschen rechts zusammenstricken. <code>p2tog</code> ist die gleiche
      Idee links gestrickt. Viel Strickkurzschrift funktioniert so: langsam lesen
      und wörtlich zerlegen.
    </p>
    <p>
      <strong>Richtungsmarker</strong> sagen, auf welcher Seite der Arbeit du bist.
      <code>RS</code> ist die rechte Seite, <code>WS</code> die linke Seite. Das ist
      wichtig, weil dieselbe Handbewegung je nach Vorder- oder Rückseite eine andere
      Wirkung haben kann.
    </p>
    <p>
      <strong>Formgebungsabkürzungen</strong> steuern, wie das Gestrick wächst oder
      schmaler wird. <code>M1</code>, <code>M1L</code>, <code>M1R</code>
      und <code>kfb</code> fügen Maschen hinzu. <code>k2tog</code> und <code
        >ssk</code
      > nehmen Maschen ab. Wenn du weißt, welche Abnahmen nach links oder rechts geneigt
      sind, liest du Formgebung schneller.
    </p>
    <p>
      <strong>Strukturbegriffe</strong> halten Anleitungen kurz: <code>rep</code
      >, <code>st(s)</code>, <code>beg</code>, <code>rem</code>, <code
        >cont</code
      >. Das sind Gerüstwörter, keine neuen Maschen.
    </p>
    <p>
      Satzzeichen zählen ebenfalls. Sterne und Semikolons sind keine Deko. <code
        >*k2, p2; rep from *</code
      > bedeutet, dass alles zwischen Stern und Semikolon wiederholt wird. Klammern
      und eckige Klammern gruppieren ähnlich einen Satz von Schritten, der eine bestimmte
      Anzahl gearbeitet wird. Ein fehlender Rapportmarker bringt die Maschenzahl sehr
      schnell durcheinander.
    </p>

    <h2>US- und UK-Unterschiede</h2>
    <p>
      Einige Begriffe verschieben sich zwischen den USA und dem UK. Die
      wichtigsten:
    </p>
    <p>
      US <code>bind off</code> ist UK <code>cast off</code>. US <code
        >gauge</code
      > ist UK <code>tension</code>. US <code>stockinette</code> ist UK <code
        >stocking stitch</code
      >. Die klassische Falle: <code>seed stitch</code> und <code
        >moss stitch</code
      >
      können je nach Quelle die Bedeutung tauschen. Die ausgeschriebene Maschendefinition
      ist verlässlicher als der Name allein.
    </p>
    <p>
      Die meisten häufigen Kürzel wie <code>k</code>, <code>p</code>, <code
        >yo</code
      > und <code>k2tog</code> sind in beiden Systemen gleich. Wenn eine Anleitung
      das System nicht nennt, klärt die Technikdefinition es meist. Gibt es gar keine
      Definition, ist der Herkunftsort der Anleitung der beste Hinweis.
    </p>

    <h2>Anleitungsspezifische Abkürzungen</h2>
    <p>
      Jetzt wird es spannend, weil viele Abkürzungen in keiner Standardliste
      stehen. Das ist normal. Es sind Kurzformen, die für genau diese Anleitung
      erfunden wurden und am Anfang der Anleitung definiert sein sollten.
    </p>
    <p>
      Zopfmuster sind eine der größten Quellen. Eine Strickschrift kann <code
        >C4F</code
      >, <code>C6B</code> oder etwas noch Spezifischeres definieren. Die Zahl sagt
      meist, wie viele Maschen verkreuzt werden. Der Buchstabe am Ende nennt die Richtung:
      F für front, B für back, also wo die Zopfnadel beim Kreuzen gehalten wird. Diese
      Konvention ist aber nicht überall gleich. Manche verwenden L und R, manche zählen
      alle beteiligten Maschen, andere nur die bewegten Maschen. Die Definition der
      Anleitung zählt.
    </p>
    <p>
      Lochmuster bauen ebenfalls zusammengesetzte Kürzel. Eine Anleitung
      schreibt <code>CDD</code> für eine zentrierte doppelte Abnahme. Eine andere
      schreibt dieselbe Grundidee als <code>sl2-k1-p2sso</code> aus, eine dritte nutzt
      <code>s2kp</code>. Alle zeigen in dieselbe Richtung, aber die genaue
      Ausführung kann sich unterscheiden. Prüfe die Musterlegende, bevor du eine
      unbekannte Abkürzung mit der häufigsten Version gleichsetzt.
    </p>
    <p>
      Mehrfarbige Muster kürzen manchmal Farbnamen oder Farbzuweisungen ab. Du
      siehst dann MC für main color und CC für contrast color, oder CC1 und CC2
      bei mehreren Kontrastfarben. Manche Anleitungen verwenden A, B und C. Die
      Kürzel sind einfach, aber eine verwechselte Farbe sieht man im fertigen
      Stück sofort.
    </p>
    <p>
      Manche Anleitungen definieren auch Kurzformen für wiederkehrende
      Maschenfolgen, die nur in diesem Design vorkommen. Ein Beispiel wäre
      <code>MB</code> für eine bestimmte Noppe oder ein eigener Begriff für eine Kombination
      aus Wicklungen und Durchziehen. Solche Kürzel sparen Platz, gelten aber nur
      innerhalb dieser Anleitung.
    </p>
    <p>
      Die Grundregel: Wenn du eine Abkürzung nicht in einer Standardreferenz
      findest, steht sie sehr wahrscheinlich im Kopfteil der Anleitung. Scrolle
      zuerst nach oben.
    </p>

    <h2>Was Symbole in Strickschriften bedeuten</h2>
    <p>
      Strickschriften verwenden Symbole statt ausgeschriebener Reihen. Jedes
      Kästchen ist eine Masche, und das Symbol im Kästchen sagt, was du
      arbeitest.
    </p>
    <p>
      Es gibt keine vollständig universelle Symbolsprache, aber viele
      Anleitungen bleiben nah an den Craft-Yarn-Council-Konventionen. Ein leeres
      Kästchen bedeutet oft rechts auf der rechten Seite und links auf der
      linken Seite. Ein Strich bedeutet links auf der rechten Seite. Ein Kreis
      ist <code>yo</code>. Ein nach rechts geneigter Schrägstrich markiert
      <code>k2tog</code>, ein nach links geneigter <code>ssk</code>.
    </p>
    <p>
      Strickschriften liest du von unten nach oben. Bei flach gestrickten
      Stücken laufen Reihen auf der rechten Seite von rechts nach links und
      Rückreihen von links nach rechts. Beim Rundstricken liest du jede Runde
      von rechts nach links, weil du immer auf der rechten Seite arbeitest.
    </p>
    <p>
      Wenn eine Anleitung sowohl geschriebene als auch gezeichnete Anweisungen
      hat, sollten sie übereinstimmen. Wenn nicht, sollten die Notizen sagen,
      welche Version Vorrang hat. Falls das fehlt, stricke einen Rapport als
      Probe, bevor du blind einer Version vertraust.
    </p>

    <h2>Diese Kürzel lohnen sich früh</h2>
    <p>
      Du musst nicht alles vor dem Anschlagen auswendig lernen. Ein erster Schal
      nutzt vielleicht nur <code>k</code> und <code>p</code>. Eine einfache
      Mütze bringt ein oder zwei Abnahmen dazu. Der Rest kommt mit den
      Anleitungen, die du strickst.
    </p>
    <p>
      Ein Paar sorgt oft für Verwirrung: <code>ssk</code> und <code>skp</code>
      sind beide links geneigte Abnahmen. <code>ssk</code> ist der moderne Standard,
      <code>skp</code> taucht häufiger in älteren Anleitungen auf. Das Ergebnis ist
      ähnlich, die Ausführung leicht anders. Arbeite die Version, die die Anleitung
      nennt.
    </p>
    <p>
      Ebenfalls wichtig: <code>psso</code> (pass slipped stitch over) erscheint allein
      oder als Teil zusammengesetzter Kürzel wie <code>sl1-k2tog-psso</code>.
      Wenn es allein auftaucht, bezieht es sich meistens auf eine zuvor
      abgehobene Masche.
    </p>
    <p>
      Das Craft Yarn Council veröffentlicht eine weit verbreitete Standardliste,
      und viele Anleitungen folgen ihr für häufige Begriffe. Danach übernehmen
      regionale Gewohnheiten und anleitungsspezifische Kurzformen. "Prüfe die
      Legende" ist besserer Rat als "lerne eine Masterliste auswendig".
    </p>
    <p>
      Lass beim Stricken eine Referenz offen. Diese Seite ist durchsuchbar, was
      schneller ist als Tab-Wechsel mitten in der Reihe. Wenn du gleichzeitig
      <a href="/de/artikel/maschenprobe-messen/">Maschenproben misst</a> oder eine
      <a href="/de/artikel/strickanleitung-lesen/">Strickanleitung lesen</a> lernst,
      passen diese Referenzen gut zusammen. In deiner eigentlichen Anleitung bleibt
      die Abkürzungsliste trotzdem die erste Stelle, die du vor dem Anschlagen prüfst.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const searchInput = document.getElementById(
    "abbr-search",
  ) as HTMLInputElement | null;
  const list = document.getElementById("abbr-list");
  const noResults = document.getElementById("no-results");
  const catButtons = document.querySelectorAll<HTMLButtonElement>(".cat-btn");

  let activeCategory = "all";

  function applyFilters() {
    if (!list || !noResults) return;
    const rows = list.querySelectorAll<HTMLElement>(".abbr-row");
    const query = (searchInput?.value || "").trim().toLowerCase();
    let visibleCount = 0;

    rows.forEach((row) => {
      const cats = (row.dataset.cats || "").split(" ");
      const haystack = [
        row.dataset.abbr,
        row.dataset.def,
        row.dataset.search,
        row.dataset.catlabels,
      ].join(" ");

      const matchesCategory =
        activeCategory === "all" || cats.includes(activeCategory);
      const matchesSearch = !query || haystack.includes(query);
      const visible = matchesCategory && matchesSearch;

      row.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    noResults.hidden = visibleCount > 0;
  }

  searchInput?.addEventListener("input", applyFilters);

  catButtons.forEach((button) => {
    button.addEventListener("click", () => {
      catButtons.forEach((item) => {
        item.classList.remove("is-active");
        item.setAttribute("aria-pressed", "false");
      });

      button.classList.add("is-active");
      button.setAttribute("aria-pressed", "true");
      activeCategory = button.dataset.cat || "all";
      applyFilters();
    });
  });
</script>
