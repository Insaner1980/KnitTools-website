  | "cast-on-bind-off"
  | "increases"
  | "decreases"
  | "cables"
  | "lace"
  | "general"
  | "stitch-patterns";

interface Abbreviation {
  abbr: string;
  def: string;
  search: string;
  categories: Category[];
}

const categoryLabels: Record<Category, string> = {
  "cast-on-bind-off": "Anschlag / Abketten",
  increases: "Zunahmen",
  decreases: "Abnahmen",
  cables: "Zöpfe",
  lace: "Lochmuster",
  general: "Allgemein",
  "stitch-patterns": "Muster",
};

