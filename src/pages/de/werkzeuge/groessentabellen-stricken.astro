const faqs = [
  {
    q: 'Wähle ich die Größe nach Körpermaß oder Fertigmaß?',
    a: 'Meistens startest du mit dem Körpermaß und vergleichst es dann mit der gewünschten Mehrweite. Das Fertigmaß des Strickstücks ist nicht dasselbe wie dein Körpermaß.',
  },
