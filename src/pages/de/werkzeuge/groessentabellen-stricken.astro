  },
];
---

<LocalizedToolPage
  title="Größentabellen fürs Stricken"
  description="Körpermaße für Strickanleitungen von Baby bis Erwachsene. Tabellen mit Brustumfang, Taille, Hüfte, Ärmellänge und mehr in cm und Zoll."
  canonicalPath={routes.tool.knittingSizeCharts.de}
  lang="de"
  alternates={routes.tool.knittingSizeCharts}
  intro="Nutze die Maße als Ausgangspunkt, wenn du eine Größe in einer Strickanleitung auswählst oder die Mehrweite prüfst. Wähle zuerst Gruppe und Einheit."
  schemaName="Größentabellen fürs Stricken"
  schemaDescription="Körpermaßtabellen zur Größenwahl in Strickanleitungen."
  faqs={faqs}
  variant="terracotta"
>
  <div slot="tool">
    <div class="chart-controls">
      <div class="tab-scroller">
        <div class="tabs" role="tablist" aria-label="Größengruppe">
          {panels.map((panel) => (
            <button
              type="button"
              role="tab"
              class={`tab-btn${panel.id === defaultPanel ? ' is-active' : ''}`}
              data-tab={panel.id}
              aria-selected={panel.id === defaultPanel ? 'true' : 'false'}
              aria-controls={`panel-${panel.id}`}
              id={`tab-${panel.id}`}
            >
              {panel.label}
            </button>
          ))}
        </div>
      </div>

      <div class="unit-toggle" role="radiogroup" aria-label="Einheit">
        <button
          type="button"
          role="radio"
          class="unit-btn is-active"
          data-unit="cm"
          aria-checked="true"
        >CM</button>
        <button
          type="button"
          role="radio"
          class="unit-btn"
          data-unit="inch"
          aria-checked="false"
        >Zoll</button>
      </div>
    </div>

    <div class="chart-wrap show-cm" id="de-size-chart-wrap">
      {panels.map((panel) => (
        <div
          class={`panel${panel.id === defaultPanel ? ' is-active' : ''}`}
          data-panel={panel.id}
          role="tabpanel"
          id={`panel-${panel.id}`}
          aria-labelledby={`tab-${panel.id}`}
          hidden={panel.id !== defaultPanel}
        >
          {panel.intro && <p class="panel-intro">{panel.intro}</p>}
          {panel.tables.map((table) => (
            <div class="table-block">
              {table.caption && <h3 class="table-caption">{table.caption}</h3>}
              <div class="table-scroll">
                <table class="size-table">
                  <thead>
                    <tr>
                      <th class="sticky-col">{table.sizeHeader ?? 'Maß'}</th>
                      {table.sizes.map((size) => <th>{size}</th>)}
                    </tr>
                  </thead>
                  <tbody>
                    {table.rows.map((row) => (
                      <tr>
                        <th scope="row" class="sticky-col row-label">{row.label}</th>
                        {row.cells.map((cell) => (
                          <td>
                            <span class="unit-cm">{cell.cm}</span>
                            <span class="unit-inch">{cell.inch}</span>
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <div slot="content">
    <h2>Körper messen, nicht nur ein altes Kleidungsstück</h2>
    <p>Die Größe einer Strickanleitung wählst du meistens aus Körpermaßen und geplanter Mehrweite. Ein Lieblingspullover kann helfen, das Gefühl einzuschätzen, ersetzt aber nicht Brustumfang, Hüfte und Ärmellänge.</p>

    <h2>Körpermaß und Fertigmaß sind verschieden</h2>
    <p>Wenn dein Brustumfang 96 cm ist und das fertige Strickstück 106 cm misst, hat es 10 cm Mehrweite. Das kann für einen lockeren Pullover genau richtig und für einen körpernahen Cardigan zu viel sein. Die Schemazeichnung der Anleitung zeigt, wo die Designerin Platz eingeplant hat.</p>

    <h2>Wähle die Größe nach dem Modell</h2>
    <p>Der Brustumfang entscheidet nicht alles. Bei langen Stücken kann die Hüfte wichtiger sein. Bei einem schmalen Ärmel kann der Oberarm ausschlaggebend sein, selbst wenn der Brustumfang passt. Prüfe ein paar Schlüsselmaße, bevor du dich festlegst.</p>
  </div>
</LocalizedToolPage>

<script>
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.panel');

  tabButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.dataset.tab;

      tabButtons.forEach((tab) => {
        const isActive = tab.dataset.tab === target;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.panel === target;
        panel.classList.toggle('is-active', isActive);
        if (isActive) {
          panel.removeAttribute('hidden');
        } else {
          panel.setAttribute('hidden', '');
        }
      });
    });
  });

  const unitButtons = document.querySelectorAll<HTMLButtonElement>('.unit-btn');
  const chartWrap = document.getElementById('de-size-chart-wrap');

  unitButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const unit = button.dataset.unit;
      if (!unit || !chartWrap) return;

      unitButtons.forEach((unitButton) => {
        const isActive = unitButton.dataset.unit === unit;
        unitButton.classList.toggle('is-active', isActive);
        unitButton.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });

      chartWrap.classList.toggle('show-cm', unit === 'cm');
      chartWrap.classList.toggle('show-inch', unit === 'inch');
    });
  });
</script>
