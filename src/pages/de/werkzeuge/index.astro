---
import ToolsIndexPage from "../../../components/ToolsIndexPage.astro";
import { routes } from "../../../i18n/routes";

const tools = [
  {
    tag: "Maschen",
    title: "Maschenanschlag-Rechner",
    description:
      "Berechne, wie viele Maschen du für eine gewünschte Breite und Maschenprobe anschlagen solltest.",
    href: routes.tool.castOnCalculator.de,
    className: "card-terracotta card-top-left",
  },
  {
    tag: "Garnbedarf",
    title: "Garnbedarfsrechner",
    description:
      "Schätze den Garnbedarf nach Projektart, Größe und Garnstärke.",
    href: routes.tool.yarnEstimator.de,
    className: "card-rust card-top-right",
  },
  {
    tag: "Garnstärken",
    title: "Garnstärken-Tabelle",
    description:
      "Garnstärken, Maschenproben, Nadelstärken und WPI an einem Ort.",
    href: routes.tool.yarnWeightChart.de,
    className: "card-sand card-bl1",
  },
  {
    tag: "Nadeln",
    title: "Nadelstärken-Tabelle",
    description: "Vergleiche metrische, US-, UK- und japanische Nadelstärken.",
    href: routes.tool.needleSizeChart.de,
    className: "card-teal card-br1",
  },
  {
    tag: "Größen",
    title: "Größentabellen fürs Stricken",
    description: "Körpermaße von Baby bis Erwachsene in Zentimetern und Zoll.",
    href: routes.tool.knittingSizeCharts.de,
    className: "card-terracotta card-bl2",
  },
  {
    tag: "Glossar",
    title: "Strickabkürzungen",
    description:
      "Suche Abkürzungen aus Strickanleitungen oder finde Begriffe nach Technik.",
    href: routes.tool.knittingAbbreviations.de,
    className: "card-brown card-br2",
  },
];
---

<ToolsIndexPage
  title="Kostenlose Stricktools: Rechner und Tabellen"
  description="Kostenlose Strickrechner und Tabellen für Maschenanschlag, Garnbedarf, Nadelstärken, Garnstärken, Abkürzungen und Größen."
  canonicalPath={routes.toolsIndex.de}
  lang="de"
  alternates={routes.toolsIndex}
  collectionName="Kostenlose Stricktools"
  collectionDescription="Kostenlose Strickrechner und Referenztabellen."
  eyebrow="Kostenlose Tools"
  heading="Stricktools online."
  intro="Rechner und Tabellen für deine Strickprojekte. Ohne Anmeldung, ohne App-Installation."
  tools={tools}
/>
