---
import LocalizedToolPage from "../../../components/LocalizedToolPage.astro";
import { routes } from "../../../i18n/routes";

const rows = [
  ["1,5", "000", "-", "-", "Lace"],
  ["1,75", "00", "-", "-", "Lace"],
  ["2,0", "0", "14", "0", "Lace"],
  ["2,25", "1", "13", "-", "Lace / Fingering / Sockengarn"],
  ["2,4", "-", "-", "1", "Fingering / Sockengarn"],
  ["2,5", "1,5", "-", "-", "Fingering / Sockengarn"],
  ["2,7", "-", "-", "2", "Fingering / Sockengarn"],
  ["2,75", "2", "12", "-", "Fingering / Sockengarn"],
  ["3,0", "2,5", "11", "3", "Fingering / Sockengarn"],
  ["3,25", "3", "10", "-", "Fingering / Sockengarn / Sport"],
  ["3,3", "-", "-", "4", "Sport"],
  ["3,5", "4", "-", "-", "Sport"],
  ["3,6", "-", "-", "5", "Sport"],
  ["3,75", "5", "9", "-", "Sport / DK / Light"],
  ["3,9", "-", "-", "6", "DK / Light"],
  ["4,0", "6", "8", "6", "DK / Light"],
  ["4,2", "-", "-", "7", "DK / Light"],
  ["4,5", "7", "7", "8", "DK / Light / Worsted"],
  ["4,8", "-", "-", "9", "Worsted / Aran / Medium"],
  ["5,0", "8", "6", "-", "Worsted / Aran / Medium"],
  ["5,1", "-", "-", "10", "Worsted / Aran / Medium"],
  ["5,4", "-", "-", "11", "Worsted / Aran / Medium"],
  ["5,5", "9", "5", "-", "Worsted / Aran / Medium / Bulky"],
  ["5,7", "-", "-", "12", "Bulky / Chunky"],
  ["6,0", "10", "4", "13", "Bulky / Chunky"],
  ["6,3", "-", "-", "14", "Bulky / Chunky"],
  ["6,5", "10,5", "3", "-", "Bulky / Chunky"],
  ["6,6", "-", "-", "15", "Bulky / Chunky"],
  ["7,0", "-", "2", "-", "Bulky / Chunky"],
  ["8,0", "11", "0", "-", "Bulky / Super Bulky"],
  ["9,0", "13", "00", "-", "Super Bulky / Super Chunky"],
  ["10,0", "15", "000", "-", "Super Bulky / Super Chunky"],
  ["12,0", "17", "-", "-", "Super Bulky / Super Chunky"],
  ["12,75", "-", "-", "-", "Super Bulky / Jumbo"],
  ["15,0", "19", "-", "-", "Jumbo"],
  ["16,0", "19", "-", "-", "Jumbo"],
  ["19,0", "35", "-", "-", "Jumbo"],
  ["25,0", "50", "-", "-", "Jumbo"],
];

const faqs = [
  {
    q: "Kann ich eine ähnliche Nadelstärke nehmen, wenn ich die genaue nicht habe?",
    a: "Du kannst es probieren, aber schon 0,5 mm können die Maschenprobe sichtbar verändern. Für passgenaue Kleidung solltest du neu probestricken.",
  },
  {
    q: "Sind Nadelstärken bei allen Marken gleich?",
    a: "Eigentlich sollten sie gleich sein. In der Praxis gibt es kleine Abweichungen, besonders bei alten Nadeln oder sehr günstigen Sets. Wenn die Maschenprobe dauerhaft nicht passt, miss die Nadel nach.",
  },
  {
    q: "Gilt die Nadelstärke auch für Rundstricknadeln?",
    a: "Ja. Die Nadelstärke beschreibt den Durchmesser der Spitze, nicht die Kabellänge. Eine Rundstricknadel mit 4,5 mm hat dieselbe Stärke wie eine gerade Nadel mit 4,5 mm.",
  },
  {
    q: "Brauche ich jede Nadelstärke?",
    a: "Nein. Die meisten nutzen immer wieder einige wenige Stärken, die zu ihren häufigsten Garnen passen. Wenn du viel DK und Worsted strickst, brauchst du 3,75-5,5 mm besonders oft.",
  },
];
---

<LocalizedToolPage
  title="Nadelstärken-Tabelle: US, UK, metrisch, Japan"
  description="Vergleiche Stricknadelgrößen zwischen metrischen, US-, UK- und japanischen Angaben. Mit Garnstärken-Empfehlungen pro Nadelstärke."
  canonicalPath={routes.tool.needleSizeChart.de}
  lang="de"
  alternates={routes.tool.needleSizeChart}
  intro="Prüfe die Nadelstärke in Millimetern und vergleiche sie mit US-, UK- und japanischen Größen. Suche nach Millimetern oder zum Beispiel US 7."
  schemaName="Nadelstärken-Tabelle"
  schemaDescription="Vergleicht Stricknadelgrößen zwischen metrischen, US-, UK- und japanischen Systemen."
  faqs={faqs}
  variant="teal"
>
  <div slot="tool">
    <div class="table-wrapper">
      <input
        type="text"
        id="needle-search"
        class="search-input"
        placeholder='Größe suchen, z. B. "4,5", "US 7" oder "UK 7"'
        autocomplete="off"
      />
      <div class="table-scroll">
        <table class="needle-table" id="needle-table">
          <thead>
            <tr>
              <th>Millimeter</th>
              <th>US</th>
              <th>UK/Kanada</th>
              <th>Japan</th>
              <th>Garnstärke</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row) => (
                <tr
                  data-mm={row[0]}
                  data-us={row[1] === "-" ? "" : row[1]}
                  data-uk={row[2] === "-" ? "" : row[2]}
                  data-jp={row[3] === "-" ? "" : row[3]}
                >
                  <td class="col-mm">{row[0]}</td>
                  {row.slice(1).map((cell) => (
                    <td>{cell === "-" ? "—" : cell}</td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="no-results" id="no-results" hidden>
        Keine passende Nadelstärke gefunden.
      </p>
    </div>
  </div>

  <div slot="content">
    <h2>Warum es mehrere Größensysteme gibt</h2>
    <p>
      Metrische Größen sind das einzige System, das direkt sagt, was die Nadel
      misst. Eine 4,0-mm-Nadel hat 4,0 mm Durchmesser. Fertig.
    </p>
    <p>
      US-Größen sind Etiketten. US 7 bedeutet 4,5 mm und US 8 bedeutet 5,0 mm,
      aber die Zahl selbst verrät nichts über den Durchmesser.
    </p>
    <p>
      Alte UK- und kanadische Größen laufen rückwärts. UK 14 ist sehr fein, und
      die Zahlen werden kleiner, je dicker die Nadeln werden, bis 0, 00 und 000
      auftauchen. Moderne UK-Anleitungen nennen meist Millimeter, aber alte
      Größen findest du noch auf Vintage-Nadeln und in gebrauchten
      Anleitungsheften.
    </p>
    <p>
      Japanische Größen liegen nah an metrischen Werten, aber nicht perfekt.
      Japanische Größe 6 ist 3,9 mm, japanische Größe 8 ist 4,5 mm. Dieser
      Versatz fällt vor allem bei feinen Maschenproben auf, wo schon wenige
      Zehntelmillimeter die fertige Strickfläche verändern.
    </p>

    <h2>Millimeter sind die sichere Wahl</h2>
    <p>
      Vertraue zuerst der Millimeterangabe. Sie ist der tatsächliche Messwert
      und vermeidet Umrechnungsfehler vollständig.
    </p>
    <p>
      Wenn eine Anleitung "US 7" verlangt, brauchst du 4,5 mm in der Hand.
      Manche Hersteller drucken beide Angaben auf die Nadel, manche nicht. Alte
      Markierungen reiben sich ab. Genau dafür lohnt sich ein Nadelmaß in der
      Projekttasche.
    </p>

    <h2>Häufige Umrechnungsfehler</h2>
    <p>Ein paar Größen sorgen immer wieder für Verwechslungen.</p>
    <p>
      <strong>Die UK-Umkehrung.</strong> US-Größen werden größer, wenn Nadeln dicker
      werden. Alte UK-Größen werden kleiner. US 6 ist 4,0 mm. UK 6 ist 5,0 mm. Wenn
      du das vertauschst, ist deine Maschenprobe schon vor der ersten Reihe um einen
      ganzen Millimeter verschoben.
    </p>
    <p>
      <strong>Fehlende Eins-zu-eins-Treffer.</strong> Nicht jede metrische Größe hat
      in jedem anderen System eine saubere Entsprechung. Eine 3,0-mm-Nadel wird von
      manchen Marken als US 2,5 beschriftet, während andere Tabellen sie zwischen
      US 2 und US 3 einordnen. Eine 3,5-mm-Nadel hat oft gar keine alte UK-Entsprechung.
      Dann zählt wieder der Millimeterwert.
    </p>
    <p>
      <strong>Japanische Fast-Treffer.</strong> Japanische Größen passen nicht sauber
      zu US-Nummern. Japanische Größe 8 ist 4,5 mm und entspricht US 7, aber japanische
      Größe 5 ist 3,6 mm und sitzt nicht ordentlich im US-System. Wenn du nach einer
      japanischen Anleitung strickst, nimm den mm-Wert, nicht die gedruckte Nummer.
    </p>
    <p>
      <strong>Halbe und ungewöhnliche Größen sind real.</strong> 2,5 mm, 3,0 mm und
      6,5 mm sind normale Produktionsgrößen, auch wenn dein Wechselnadelset sie ausgelassen
      hat.
    </p>
    <p>
      <strong>Alte Anleitunghefte nennen nicht immer das System.</strong> Eine Anleitung
      aus den 1970ern, die "size 6 needles" verlangt, kann je nach Herkunft US 6 (4,0
      mm) oder UK 6 (5,0 mm) meinen. Prüfe den Verlag und dann die Tabelle.
    </p>

    <h2>Nadelstärke und Garnstärke gehören zusammen</h2>
    <p>
      Die Tabelle bringt dich in die richtige Nähe. Die Maschenprobe entscheidet
      den genauen Wert.
    </p>
    <p>
      Das aktuelle Craft-Yarn-Council-System ordnet Lace meist 1,5-2,25 mm zu,
      Fingering / Sockengarn 2,25-3,25 mm, Sport 3,25-3,75 mm, DK / Light
      3,75-4,5 mm, Worsted / Aran / Medium 4,5-5,5 mm, Bulky 5,5-8 mm, Super
      Bulky 8-12,75 mm und Jumbo ab 12,75 mm.
    </p>
    <p>
      Diese Bereiche überlappen absichtlich. DK kann auf kleinerer Nadel eine
      feste Mütze ergeben oder auf größerer Nadel ein luftiges Tuch. Die
      Maschenprobe der Anleitung zeigt, welche Richtung gemeint ist. Wenn du
      unsicher bist, welche Garnstärke du vor dir hast, starte mit der <a
        href="/de/werkzeuge/garnstaerken-tabelle/">Garnstärken-Tabelle</a
      >.
    </p>

    <h2>Wie misst du unmarkierte Nadeln?</h2>
    <p>
      Vintage-Nadeln, handgedrechselte Holznadeln und viel benutzte
      Wechselnadeln verlieren irgendwann ihre Markierung. Ein Nadelmaß löst das:
      Schiebe den Schaft durch die Löcher, bis du die Größe findest, die sauber
      passt, ohne zu klemmen.
    </p>
    <p>
      Miss am Schaft, nicht an der Spitze. Die verjüngte Spitze ist dünner als
      der arbeitende Teil der Nadel und liefert sonst den falschen Wert.
    </p>
    <p>
      Die meisten Nadelmaße zeigen metrische und US-Größen, manche auch
      japanische Größen. Wenn deins das nicht tut, findest du hier den
      mm-Gegenwert und strickst danach eine kurze <a
        href="/de/artikel/maschenprobe-messen/">Maschenprobe</a
      >, bevor du das ganze Projekt beginnst. Wenn du zusätzlich noch das <a
        href="/de/artikel/stricknadeln-metall-holz-bambus/">Nadelmaterial</a
      > auswählst, ist das eine eigene Entscheidung neben der Größe.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const searchInput = document.getElementById(
    "needle-search",
  ) as HTMLInputElement | null;
  const table = document.getElementById("needle-table");
  const noResults = document.getElementById("no-results");

  if (searchInput && table && noResults) {
    const rows = table.querySelectorAll<HTMLElement>("tbody tr");

    searchInput.addEventListener("input", () => {
      const raw = searchInput.value.trim().toLowerCase();

      if (!raw) {
        rows.forEach((row) => {
          row.style.display = "";
        });
        noResults.hidden = true;
        return;
      }

      let targetCol: string | null = null;
      let query = raw;
      const normalizeNumber = (value: string) => value.replace(",", ".");

      if (raw.startsWith("us ")) {
        targetCol = "us";
        query = raw.slice(3).trim();
      } else if (raw.startsWith("uk ")) {
        targetCol = "uk";
        query = raw.slice(3).trim();
      } else if (
        raw.startsWith("jp ") ||
        raw.startsWith("japan ") ||
        raw.startsWith("japanisch ")
      ) {
        targetCol = "jp";
        query = raw.replace(/^(jp|japan|japanisch)\s+/, "").trim();
      }

      let visibleCount = 0;

      rows.forEach((row) => {
        const mm = row.dataset.mm || "";
        const us = row.dataset.us || "";
        const uk = row.dataset.uk || "";
        const jp = row.dataset.jp || "";

        const normalizedQuery = normalizeNumber(query);
        const match =
          targetCol === "us"
            ? normalizeNumber(us) === normalizedQuery
            : targetCol === "uk"
              ? normalizeNumber(uk) === normalizedQuery
              : targetCol === "jp"
                ? normalizeNumber(jp) === normalizedQuery
                : normalizeNumber(mm).startsWith(normalizedQuery) ||
                  normalizeNumber(us) === normalizedQuery ||
                  normalizeNumber(uk) === normalizedQuery ||
                  normalizeNumber(jp) === normalizedQuery;

        row.style.display = match ? "" : "none";
        if (match) visibleCount++;
      });

      noResults.hidden = visibleCount > 0;
    });
  }
</script>
