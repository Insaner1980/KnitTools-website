---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import ArticleCard from '../../../components/ArticleCard.astro';
import ClosingCTA from '../../../components/ClosingCTA.astro';
import {
  CATEGORY_ORDER,
  getCategoryDescription,
  getCategoryLabel,
} from '../../../lib/categories';
import { isGermanArticle } from '../../../i18n/articles';
import { routes } from '../../../i18n/routes';

const articles = await getCollection('articles', ({ data }) =>
  data.lang === 'de' && (import.meta.env.DEV ? true : !data.draft)
);
const germanArticles = articles.filter(isGermanArticle);

const byCategoryOrder = (a: typeof articles[number], b: typeof articles[number]) =>
  (a.data.categoryOrder ?? 999) - (b.data.categoryOrder ?? 999);

const sections = CATEGORY_ORDER.map((slug) => {
  const categoryArticles = germanArticles
    .filter((article) => article.data.category === slug)
    .sort(byCategoryOrder);
  const previewArticles = categoryArticles.slice(0, 3);

  return {
    slug,
    label: getCategoryLabel(slug, 'de'),
    description: getCategoryDescription(slug, 'de'),
    articles: previewArticles,
    remainingCount: Math.max(categoryArticles.length - previewArticles.length, 0),
  };
}).filter((section) => section.articles.length > 0);
---

<PageLayout
  title="Strickartikel und praktische Tipps"
  description="Praktische Strickartikel zu Maschenprobe, Garn, Nadeln, Techniken und KnitTools."
  canonicalPath={routes.articlesIndex.de}
  lang="de"
  alternates={routes.articlesIndex}
  showStripe={false}
>
  <section class="articles-header">
    <div class="articles-header-inner">
      <p class="eyebrow">Artikel</p>
      <h1>Strickwissen für die Praxis.</h1>
      <p class="articles-intro">Artikel für alle, die beim Stricken klare Antworten brauchen: Maschenprobe, Garnwahl, Nadelstärke, Anleitungen, Rechner und hilfreiche Werkzeuge.</p>

      {sections.length > 0 && (
        <nav class="cat-nav" aria-label="Artikelkategorien">
          {sections.map((section) => (
            <a href={`#${section.slug}`} class="cat-nav-link">{section.label}</a>
          ))}
        </nav>
      )}
    </div>
  </section>

  {sections.length === 0 ? (
    <section class="empty-section">
      <div class="empty-state">
        <p class="empty-eyebrow">In Arbeit</p>
        <p class="empty-text">Die deutschen Artikel werden gerade übersetzt.</p>
        <a href={routes.toolsIndex.de} class="empty-link">Werkzeuge ansehen &rarr;</a>
      </div>
    </section>
  ) : (
    sections.map((section) => (
      <section class="cat-section" id={section.slug}>
        <div class="cat-section-inner">
          <header class="cat-header">
            <div class="cat-header-text">
              <p class="cat-eyebrow">{section.label}</p>
              <p class="cat-description">{section.description}</p>
            </div>
            {section.remainingCount > 0 && (
              <a href={routes.category[section.slug].de} class="cat-all-link">
                {section.remainingCount} weitere anzeigen &rarr;
              </a>
            )}
          </header>
          <div class="articles-grid">
            {section.articles.map((article) => (
              <ArticleCard article={article} showCategory={false} lang="de" />
            ))}
          </div>
        </div>
      </section>
    ))
  )}
  <ClosingCTA variant="page" lang="de" />
</PageLayout>

<style>
  .articles-header {
    color: var(--ink);
    padding: 80px 40px 40px;
    border-bottom: 1px solid var(--ink);
  }

  .articles-header-inner,
  .cat-section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 20px;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
  }

  .articles-intro,
  .cat-description {
    font-family: var(--body-ed);
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.55;
    max-width: 680px;
    margin: 0;
  }

  .cat-nav {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
  }

  .cat-nav-link,
  .cat-all-link {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--ink);
    padding: 6px 14px;
  }

  .cat-all-link {
    color: var(--terracotta);
    border: 0;
    border-bottom: 1px solid var(--terracotta);
    padding: 0 0 2px;
    white-space: nowrap;
  }

  .cat-section {
    padding: 56px 40px 24px;
    border-bottom: 1px solid rgba(42, 30, 23, 0.15);
  }

  .cat-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .cat-eyebrow {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 2.6vw, 2.5rem);
    line-height: 1.05;
    margin: 0 0 8px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
  }

  .empty-section {
    padding: 56px 40px 100px;
  }

  .empty-state {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 40px;
    border: 1px solid var(--ink);
    background: var(--paper-2);
  }

  .empty-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 14px;
  }

  .empty-text {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.15;
    margin: 0 0 20px;
  }

  .empty-link {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
    padding-bottom: 2px;
  }

  @media (max-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .articles-header,
    .cat-section,
    .empty-section {
      padding-left: 20px;
      padding-right: 20px;
    }

    .articles-grid { grid-template-columns: 1fr; gap: 12px; }
    .cat-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .empty-state { padding: 40px 24px; }
  }
</style>
