---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getArticleAlternates, getArticlePath, getArticleSlug, getFinnishArticleRouteSlug, isFinnishArticle } from '../../../i18n/articles';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) =>
    data.lang === 'fi' && (import.meta.env.DEV ? true : !data.draft)
  );
  return articles.map((article) => ({
    params: { slug: getFinnishArticleRouteSlug(article.data.translationKey ?? getArticleSlug(article.id), getArticleSlug(article.id)) },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  category={article.data.category}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  tags={article.data.tags}
  lang="fi"
  canonicalPath={getArticlePath(article, 'fi')}
  alternates={getArticleAlternates(article)}
>
  <Content />
</ArticleLayout>
