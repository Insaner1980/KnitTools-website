const filterOrder: Array<Category | "all"> = [
  "all",
  "cast-on-bind-off",
  "increases",
  "decreases",
  "cables",
  "lace",
  "general",
  "stitch-patterns",
];

const faqs = [
  {
    q: "Ovatko englannin ja suomen lyhenteet samoja?",
    a: "Eivät yleensä. Suomenkielisissä ohjeissa käytetään usein o, n, krs ja s -tyyppisiä lyhenteitä. Englanninkielisissä ohjeissa vastaan tulevat k, p, yo, ssk ja muut kansainväliset lyhenteet.",
  },
  {
    q: "Mitä tähti tarkoittaa neuleohjeessa?",
    a: 'Tähti merkitsee yleensä toistoa. Kaikki tähdestä seuraavaan toisto-ohjeeseen, kuten "toista *-kohdasta", neulotaan uudelleen kerroksen tai jakson yli. Sulkeet ja hakasulkeet ryhmittelevät samalla tavalla ohjeen osia, jotka tehdään useamman kerran.',
  },
  {
    q: "Mitä jos ohje käyttää omaa lyhennettä?",
