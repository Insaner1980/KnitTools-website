const faqs = [
  {
    q: "Mikä lankavahvuus on yleisin?",
    a: "Pohjoisamerikkalaisissa ohjeissa worsted on hyvin yleinen. Euroopassa ja UK-ohjeissa DK tulee vastaan jatkuvasti. Molemmilla tekee paljon perusvaatteita ja asusteita.",
  },
  {
    q: "Voiko yhden lankavahvuuden korvata toisella?",
    a: "Voi, mutta silloin muuttuvat neuletiheys, laskeutuvuus ja menekki. Lähivahvuudet ovat helpompia kuin iso hyppy ohuesta paksuun.",
  },
  {
    q: "Mitä kaksinkertaisena neulominen tarkoittaa?",
    a: "Kaksi lankaa neulotaan yhdessä kuin yksi paksumpi lanka. Kaksi fingering-lankaa voi lähestyä DK-vahvuutta, mutta kuitu, kierre ja ilmavuus vaikuttavat paljon.",
  },
  {
    q: "Miksi lanka näyttää ohuemmalta tai paksummalta kuin vyöte sanoo?",
