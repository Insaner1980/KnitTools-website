---
import LocalizedToolPage from "../../../components/LocalizedToolPage.astro";
import { routes } from "../../../i18n/routes";
import { getNeedleSizeRows } from "../../../lib/toolReferenceData";

const rows = getNeedleSizeRows("comma");

const faqs = [
  {
    q: "Voinko käyttää melkein samaa puikkokokoa?",
    a: "Voit kokeilla, mutta jo 0,5 mm muutos voi näkyä neuletiheydessä. Istuviin vaatteisiin kannattaa neuloa uusi mallitilkku.",
  },
  {
    q: "Ovatko puikkokoot samoja kaikilla merkeillä?",
    a: "Niiden pitäisi olla, mutta vanhoissa tai halvoissa puikoissa voi olla pientä heittoa. Jos neuletiheys ei millään täsmää, mittaa puikko puikkomitalla.",
  },
  {
    q: "Onko pyöröpuikon koko eri asia kuin suoran puikon?",
    a: "Ei. Koko kertoo kärjen halkaisijan. Kaapelin pituus on erillinen asia.",
  },
  {
    q: "Tarvitsenko jokaisen puikkokoon?",
    a: "Et. Useimmat neulojat käyttävät toistuvasti vain muutamia kokoja, jotka sopivat heidän tavallisimpiin lankoihinsa. Jos neulot paljon DK- ja worsted-vahvuisilla langoilla, 3,75-5,5 mm puikot tulevat vastaan usein.",
  },
];
---

<LocalizedToolPage
  lang="fi"
  title="Puikkokoot: US, UK ja millimetrit"
  description="Muunna neulepuikkojen koot metrisen, US-, UK- ja japanilaisen järjestelmän välillä. Hae kokoja ja katso suositellut lankavahvuudet."
  canonicalPath={routes.tool.needleSizeChart.fi}
  alternates={routes.tool.needleSizeChart}
  intro="Tarkista puikkokoko millimetreinä ja vertaa sitä US-, UK- ja japanilaisiin kokomerkintöihin. Hae millimetreillä tai esimerkiksi muodossa US 7."
  schemaName="Puikkokokotaulukko"
  schemaDescription="Muuntaa neulepuikkojen koot metrisen, US-, UK- ja japanilaisen järjestelmän välillä ja näyttää suositellut lankavahvuudet."
  faqs={faqs}
  variant="teal"
>
  <div slot="tool">
    <div class="table-wrapper">
      <input
        type="text"
        id="needle-search"
        class="search-input"
        aria-label="Hae puikkokokoja"
        placeholder='Hae kokoa, esim. "4,5", "US 7" tai "UK 7"'
        autocomplete="off"
      />
      <div class="table-scroll">
        <table class="needle-table" id="needle-table">
          <thead>
            <tr>
              <th>Millimetrit</th>
              <th>US</th>
              <th>UK/Canada</th>
              <th>Japani</th>
              <th>Lankavahvuus</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((row) => (
                <tr
                  data-mm={row[0]}
                  data-us={row[1] === "-" ? "" : row[1]}
                  data-uk={row[2] === "-" ? "" : row[2]}
                  data-jp={row[3] === "-" ? "" : row[3]}
                >
                  <td class="col-mm">{row[0]}</td>
                  {row.slice(1).map((cell) => (
                    <td>{cell === "-" ? "—" : cell}</td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="no-results" id="no-results" hidden>Kokoa ei löytynyt.</p>
    </div>
  </div>

  <div slot="content">
    <h2>Miksi järjestelmiä on monta?</h2>
    <p>
      Millimetrit kertovat puikon todellisen halkaisijan. 4,0 mm puikko on 4,0
      mm puikko riippumatta siitä, mitä muita merkintöjä siinä on.
    </p>
    <p>
      US-koot ovat nimilappuja. US 7 tarkoittaa 4,5 mm ja US 8 tarkoittaa 5,0
      mm, mutta numero ei itsessään kerro halkaisijaa.
    </p>
    <p>
      Vanhat UK- ja kanadalaiset koot kulkevat toiseen suuntaan: pienempi numero
      tarkoittaa paksumpaa puikkoa. Japanilaiset koot taas seuraavat
      millimetrejä melko läheltä, mutta eivät täydellisesti.
    </p>

    <h2>Millimetrit ovat varmin valinta</h2>
    <p>
      Jos ohje antaa sekä nimikoon että millimetrit, seuraa millimetrejä.
      Millimetrikoko on todellinen mitta ja ohittaa muunnosvirheet.
    </p>
    <p>
      Kun ohje pyytää "US 7" -puikkoa, kädessä tarvitaan 4,5 mm puikko. Osa
      merkeistä painaa molemmat luvut puikkoon, osa ei. Vanhoista puikoista
      merkinnät voivat kulua pois, jolloin puikkomitta on nopeampi kuin
      arvaaminen.
    </p>

    <h2>Yleiset muunnosvirheet</h2>
    <p>
      <strong>UK-järjestelmä on käänteinen.</strong> US-koko kasvaa, kun puikko paksunee.
      Vanha UK-koko pienenee. US 6 on 4,0 mm, mutta UK 6 on 5,0 mm.
    </p>
    <p>
      <strong>Kaikille milleille ei ole yhtä vastinetta.</strong> 3,0 mm puikko voi
      olla joissakin merkeissä US 2,5, kun toinen taulukko sijoittaa sen US 2:n ja
      US 3:n väliin. Kun vastine on epäselvä, palaa millimetrikokoon.
    </p>
    <p>
      <strong>Japanilaiset lähikoot eivät osu aina US-numeroihin.</strong>
      Japanilainen koko 8 on 4,5 mm eli sama kuin US 7, mutta koko 5 on 3,6 mm eikä
      istu siististi US-järjestelmään.
    </p>
    <p>
      <strong>Puolikkaat ja välikoot ovat todellisia.</strong> 2,5 mm, 3,0 mm ja 6,5
      mm ovat tavallisia tuotantokokoja, vaikka jokainen vaihtopääsetti ei sisällä
      niitä.
    </p>
    <p>
      <strong>Vanha ohje ei aina kerro järjestelmää.</strong> 1970-luvun ohjeen "size
      6 needles" voi tarkoittaa US 6 (4,0 mm) tai UK 6 (5,0 mm) julkaisumaasta riippuen.
    </p>

    <h2>Puikkokoko ja lankavahvuus kulkevat yhdessä</h2>
    <p>Taulukko vie oikealle lähialueelle. Mallitilkku päättää tarkan koon.</p>
    <p>
      CYC:n nykyiset lankavahvuusalueet yhdistävät Lace-langan 1,5-2,25 mm
      puikkoihin, Super Fine -langan 2,25-3,25 mm puikkoihin, Fine-langan
      3,25-3,75 mm puikkoihin, Light-langan 3,75-4,5 mm puikkoihin,
      Medium-langan 4,5-5,5 mm puikkoihin, Bulky-langan 5,5-8 mm puikkoihin,
      Super Bulky -langan 8-12,75 mm puikkoihin ja Jumbo-langan vähintään 12,75
      mm puikkoihin.
    </p>
    <p>
      Rajat menevät päällekkäin tarkoituksella. Sama DK-lanka voi olla napakka
      pipossa pienemmällä puikolla ja ilmava huivissa suuremmalla puikolla.
      Ohjeen neuletiheys kertoo, kumpaan suuntaan suunnittelija on tähdännyt.
    </p>

    <h2>Miten merkitsemätön puikko mitataan?</h2>
    <p>
      Käytä puikkomittaa eli levyä, jossa on millimetrireiät. Työnnä puikko
      reikään, johon se istuu puhtaasti ilman puristamista.
    </p>
    <p>
      Mittaa varresta, älä kärjestä. Kapeneva kärki näyttää liian pieneltä.
      Pyöröpuikon kaapelia ei mitata: koko tarkoittaa puikon kärjen halkaisijaa.
    </p>
  </div>
</LocalizedToolPage>

<script>
  const searchInput = document.getElementById(
    "needle-search",
  ) as HTMLInputElement | null;
  const table = document.getElementById("needle-table");
  const noResults = document.getElementById("no-results");

  if (searchInput && table && noResults) {
    const rows = table.querySelectorAll<HTMLElement>("tbody tr");

    searchInput.addEventListener("input", () => {
      const raw = searchInput.value.trim().toLowerCase();

      if (!raw) {
        rows.forEach((row) => {
          row.style.display = "";
        });
        noResults.hidden = true;
        return;
      }

      let targetCol: string | null = null;
      let query = raw;
      const normalizeNumber = (value: string) => value.replace(",", ".");

      if (raw.startsWith("us ")) {
        targetCol = "us";
        query = raw.slice(3).trim();
      } else if (raw.startsWith("uk ")) {
        targetCol = "uk";
        query = raw.slice(3).trim();
      } else if (
        raw.startsWith("jp ") ||
        raw.startsWith("japani ") ||
        raw.startsWith("japanese ")
      ) {
        targetCol = "jp";
        query = raw.replace(/^(jp|japani|japanese)\s+/, "").trim();
      }

      let visibleCount = 0;

      rows.forEach((row) => {
        const mm = row.dataset.mm || "";
        const us = row.dataset.us || "";
        const uk = row.dataset.uk || "";
        const jp = row.dataset.jp || "";

        const normalizedQuery = normalizeNumber(query);
        const match =
          targetCol === "us"
            ? normalizeNumber(us) === normalizedQuery
            : targetCol === "uk"
              ? normalizeNumber(uk) === normalizedQuery
              : targetCol === "jp"
                ? normalizeNumber(jp) === normalizedQuery
                : normalizeNumber(mm).startsWith(normalizedQuery) ||
                  normalizeNumber(us) === normalizedQuery ||
                  normalizeNumber(uk) === normalizedQuery ||
                  normalizeNumber(jp) === normalizedQuery;

        row.style.display = match ? "" : "none";
        if (match) visibleCount++;
      });

      noResults.hidden = visibleCount > 0;
    });
  }
</script>
