---
import ToolsIndexPage from "../../../components/ToolsIndexPage.astro";
import { routes } from "../../../i18n/routes";

const tools = [
  {
    tag: "Silmukat",
    title: "Silmukkalaskuri",
    description:
      "Laske, montako silmukkaa pitää luoda haluttuun leveyteen omalla neuletiheydellä.",
    href: routes.tool.castOnCalculator.fi,
    className: "card-terracotta card-top-left",
  },
  {
    tag: "Lankamuunnin",
    title: "Lankamuunnin",
    description:
      "Arvioi ja muunna langan tarve työn tyypin, koon ja lankavahvuuden perusteella.",
    href: routes.tool.yarnEstimator.fi,
    className: "card-rust card-top-right",
  },
  {
    tag: "Lankavahvuudet",
    title: "Lankavahvuustaulukko",
    description:
      "Lankavahvuudet, neuletiheydet, puikkosuositukset ja WPI yhdessä paikassa.",
    href: routes.tool.yarnWeightChart.fi,
    className: "card-sand card-bl1",
  },
  {
    tag: "Puikot",
    title: "Puikkokoot",
    description:
      "Muunna puikkokoot metrisen, US-, UK- ja japanilaisen järjestelmän välillä.",
    href: routes.tool.needleSizeChart.fi,
    className: "card-teal card-br1",
  },
  {
    tag: "Koot",
    title: "Neulekokotaulukot",
    description:
      "Vartalon mittoja vauvoista aikuisiin senttimetreinä ja tuumina.",
    href: routes.tool.knittingSizeCharts.fi,
    className: "card-terracotta card-bl2",
  },
  {
    tag: "Sanasto",
    title: "Neulelyhenteet",
    description:
      "Hae neuleohjeiden lyhenteitä tai etsi termejä tekniikan mukaan.",
    href: routes.tool.knittingAbbreviations.fi,
    className: "card-brown card-br2",
  },
];
---

<ToolsIndexPage
  title="Ilmaiset neuletyökalut: laskurit ja taulukot"
  description="Ilmaiset neulelaskurit ja taulukot: silmukat, langanmenekki, puikkokoot, lankavahvuudet, lyhenteet ja kokotaulukot."
  canonicalPath={routes.toolsIndex.fi}
  lang="fi"
  alternates={routes.toolsIndex}
  collectionName="Ilmaiset neuletyökalut"
  collectionDescription="Ilmaiset neulelaskurit ja neulonnan viitetaulukot."
  eyebrow="Ilmaiset työkalut"
  heading="Neuletyökalut verkossa."
  intro="Laskureita ja taulukoita neuleprojektien suunnitteluun. Ei kirjautumista, ei sovelluksen asennusta."
  tools={tools}
/>
