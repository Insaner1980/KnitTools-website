---
import ToolsIndexPage from "../../../components/ToolsIndexPage.astro";
import { routes } from "../../../i18n/routes";

const tools = [
  {
    tag: "Masker",
    title: "Oppleggskalkulator",
    description:
      "Regn ut hvor mange masker du skal legge opp for ønsket bredde og strikkefasthet.",
    href: routes.tool.castOnCalculator.no,
    className: "card-terracotta card-top-left",
  },
  {
    tag: "Garnmengde",
    title: "Garnberegner",
    description:
      "Beregn garnforbruk etter prosjekttype, størrelse og garntykkelse.",
    href: routes.tool.yarnEstimator.no,
    className: "card-rust card-top-right",
  },
  {
    tag: "Tykkelser",
    title: "Garntykkelser",
    description:
      "CYC-kategorier for garntykkelse med strikkefasthet, pinner og WPI.",
    href: routes.tool.yarnWeightChart.no,
    className: "card-sand card-bl1",
  },
  {
    tag: "Pinner",
    title: "Pinnestørrelser",
    description:
      "Gjør om mellom US-, UK-, metriske og japanske pinnestørrelser.",
    href: routes.tool.needleSizeChart.no,
    className: "card-teal card-br1",
  },
  {
    tag: "Størrelser",
    title: "Størrelsestabeller",
    description: "Kroppsmål fra baby til voksen, i cm og tommer.",
    href: routes.tool.knittingSizeCharts.no,
    className: "card-terracotta card-bl2",
  },
  {
    tag: "Ordliste",
    title: "Strikkeforkortelser",
    description: "Søk etter en forkortelse eller finn termer etter teknikk.",
    href: routes.tool.knittingAbbreviations.no,
    className: "card-brown card-br2",
  },
];
---

<ToolsIndexPage
  title="Gratis strikkeverktøy: kalkulatorer og tabeller"
  description="Gratis strikkekalkulatorer og referansetabeller på nett: opplegg, garnberegner, pinnestørrelser, garntykkelser, forkortelser og kroppsmål."
  canonicalPath={routes.toolsIndex.no}
  lang="no"
  alternates={routes.toolsIndex}
  collectionName="Gratis strikkeverktøy"
  collectionDescription="Gratis strikkekalkulatorer og referansetabeller på nett."
  eyebrow="Gratis verktøy"
  heading="Strikkeverktøy på nett."
  intro="Kalkulatorer og referansetabeller for strikkeprosjektene dine. Ingen innlogging, ingen app nødvendig."
  tools={tools}
/>
