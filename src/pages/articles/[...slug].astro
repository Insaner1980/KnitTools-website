---
import { getCollection, render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import {
  getArticleAlternates,
  getArticlePath,
  getArticleSlug,
  isArticleVisibleForLang,
  isArticleVisibleInCurrentBuild,
} from "../../i18n/articles";

export async function getStaticPaths() {
  const visibleArticles = (await getCollection("articles")).filter(
    isArticleVisibleInCurrentBuild,
  );
  const articles = visibleArticles.filter((article) =>
    isArticleVisibleForLang(article, "en"),
  );
  return articles.map((article) => ({
    params: { slug: getArticleSlug(article.id) },
    props: { article, visibleArticles },
  }));
}

const { article, visibleArticles } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  browserTitle={article.data.browserTitle}
  description={article.data.description}
  category={article.data.category}
  publishDate={article.data.publishDate}
  updatedDate={article.data.updatedDate}
  tags={article.data.tags}
  lang="en"
  canonicalPath={getArticlePath(article, "en")}
  alternates={getArticleAlternates(article, visibleArticles)}
>
  <Content />
</ArticleLayout>
