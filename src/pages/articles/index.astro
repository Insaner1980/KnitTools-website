---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import ClosingCTA from "../../components/ClosingCTA.astro";
import { CATEGORY_ORDER, getCategoryLabel } from "../../lib/categories";
import { PRICING } from "../../config/pricing";
import {
  buildArticleCategorySections,
  isArticleVisibleInCurrentBuild,
  isEnglishArticle,
} from "../../i18n/articles";
import { routes } from "../../i18n/routes";

const articles = (await getCollection("articles")).filter(
  isArticleVisibleInCurrentBuild,
);
const englishArticles = articles.filter(isEnglishArticle);
const sections = buildArticleCategorySections(englishArticles, "en");

const totalCount = englishArticles.length;
---

<PageLayout
  title="Knitting Guides & Tips"
  description="Helpful knitting guides, tips, and tutorials for knitters of all levels. Gauge, yarn, needles, techniques, and app know-how."
  canonicalPath="/articles/"
  alternates={routes.articlesIndex}
>
  <section class="articles-header">
    <div class="articles-header-inner">
      <p class="eyebrow">Articles</p>
      <h1>Knitting guides &amp; tips.</h1>
      <p class="articles-intro">
        Practical writing for working knitters. Gauge math, yarn choices, needle
        picks, technique walk-throughs, and how to get the most out of the app.
      </p>

      {
        totalCount > 0 && (
          <nav class="cat-nav" aria-label="Article categories">
            {CATEGORY_ORDER.map((slug) => (
              <a href={`#${slug}`} class="cat-nav-link">
                {getCategoryLabel(slug)}
              </a>
            ))}
          </nav>
        )
      }
    </div>
  </section>

  {
    totalCount === 0 ? (
      <section class="empty-section">
        <div class="empty-state">
          <p class="empty-eyebrow">Coming {PRICING.launchMonthLabel}</p>
          <p class="empty-text">
            Articles are being written. In the meantime, try the calculators.
          </p>
          <a href="/tools/" class="empty-link">
            Browse free tools &rarr;
          </a>
        </div>
      </section>
    ) : (
      sections.map((section) => (
        <section class="cat-section" id={section.slug}>
          <div class="cat-section-inner">
            <header class="cat-header">
              <div class="cat-header-text">
                <h2 class="cat-eyebrow">{section.label}</h2>
                <p class="cat-description">{section.description}</p>
              </div>
              {section.remainingCount > 0 && (
                <a
                  href={`/articles/category/${section.slug}/`}
                  class="cat-all-link"
                >
                  View {section.remainingCount} more &rarr;
                </a>
              )}
            </header>
            <div class="articles-grid">
              {section.articles.map((article) => (
                <ArticleCard article={article} showCategory={false} />
              ))}
            </div>
          </div>
        </section>
      ))
    )
  }
  <ClosingCTA variant="page" />
</PageLayout>

<style>
  .articles-header {
    color: var(--ink);
    padding: 80px 40px 40px;
    border-bottom: 1px solid var(--ink);
  }

  .articles-header-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 20px;
  }

  .articles-header h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: none;
    margin: 0 0 20px;
    padding-bottom: 0.08em;
  }

  .articles-intro {
    font-family: var(--body-ed);
    font-weight: 400;
    font-size: clamp(17px, 1.5vw, 20px);
    color: var(--ink);
    max-width: 620px;
    line-height: 1.55;
    margin: 0;
  }

  .cat-nav {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 20px;
  }

  .cat-nav-link {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid var(--ink);
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }

  .cat-nav-link:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .cat-section {
    padding: 56px 40px 24px;
    scroll-margin-top: 96px;
  }

  .cat-section + .cat-section {
    border-top: 1px solid rgba(42, 30, 23, 0.15);
  }

  .cat-section:last-of-type {
    padding-bottom: 100px;
  }

  .cat-section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .cat-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .cat-header-text {
    flex: 1;
    min-width: 0;
  }

  .cat-eyebrow {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.6rem, 2.6vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 8px;
  }

  .cat-description {
    font-family: var(--body-ed);
    font-size: clamp(15px, 1.2vw, 17px);
    color: var(--ink-soft);
    margin: 0;
    max-width: 640px;
    line-height: 1.5;
  }

  .cat-all-link {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cat-all-link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
  }

  .empty-section {
    padding: 56px 40px 100px;
  }

  .empty-state {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 40px;
    border: 1px solid var(--ink);
    background: var(--paper-2);
  }

  .empty-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin: 0 0 14px;
  }

  .empty-text {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 20px;
  }

  .empty-link {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
    padding-bottom: 2px;
  }

  .empty-link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  @media (max-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .articles-header {
      padding: 60px 20px 32px;
    }
    .cat-section {
      padding: 40px 20px 16px;
    }
    .cat-section:last-of-type {
      padding-bottom: 72px;
    }
    .empty-section {
      padding: 40px 20px 72px;
    }
    .articles-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .cat-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .empty-state {
      padding: 40px 24px;
    }
  }
</style>
