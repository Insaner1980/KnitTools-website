{
  "name": "knittoolsapp",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "lint": "eslint \"src/**/*.{astro,js,ts}\" \"astro.config.mjs\" \"eslint.config.mjs\"",
    "format": "prettier --write \"src/**/*.{astro,js,ts,css,md}\" \"*.{js,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{astro,js,ts,css,md}\" \"*.{js,mjs,json}\"",
    "build": "astro build",
    "preview": "astro preview",
    "verify": "npm run check && npm run lint && npm run format:check && npm run build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.3",
    "gsap": "^3.15.0",
    "sharp": "^0.33.5"
  },
  "overrides": {
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-astro": "1.7.0",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3"
  }
}
